    {
      "_id": "guide_demo_001",
      "elderId": "elder_demo_001",
      "title": "电饭煲煮饭",
      "itemName": "电饭煲",
      "steps": [
        {
          "image": "",
          "text": "先把米放进内胆里，用清水淘洗两遍。",
          "order": 0
        },
        {
          "image": "",
          "text": "加入适量清水，水面大约高出米面一指节。",
          "order": 1
        },
        {
          "image": "",
          "text": "把内胆放回电饭煲，盖好盖子，按下煮饭键。",
          "order": 2
        },
        {
          "image": "",
          "text": "等跳到保温后焖 10 分钟，再打开盛饭。",
          "order": 3
        }
      ],
      "videoFileID": "",
      "createdAt": "2026-03-24T12:00:00.000Z",
      "updatedAt": "2026-03-24T12:00:00.000Z",
      "createdBy": "family_demo_001"
    },
    {
      "_id": "guide_demo_002",
      "elderId": "elder_demo_001",
      "title": "热水器洗澡前怎么开",
      "itemName": "热水器",
      "steps": [
        {
          "image": "",
          "text": "先确认热水器电源已打开，面板有亮灯。",
          "order": 0
        },
        {
          "image": "",
          "text": "把温度调到 40 度左右，不要调得太高。",
          "order": 1
        },
        {
          "image": "",
          "text": "打开淋浴喷头，先用手试水温，合适后再洗澡。",
          "order": 2
        }
      ],

{
  "envId": "{{env.ENV_ID}}",
  "functionRoot": "./cloudfunctions",
  "functions": [
    {
      "name": "yizhanService",
      "runtime": "Nodejs16.13",
      "handler": "index.main",
      "timeout": 60,
      "memorySize": 256,
      "installDependency": true
    }
  ],
  "ai": {
    "defaultAgent": "{{env.AI_DEFAULT_AGENT}}",
    "agents": {
      "codebuddy": {
        "type": "none"
      }
    }
  }
}

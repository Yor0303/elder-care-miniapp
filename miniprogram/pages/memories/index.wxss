.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.header {
  margin-bottom: 22rpx;
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  background: var(--yz-gradient-hero);
  box-shadow: var(--yz-shadow-soft);
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
  letter-spacing: 1rpx;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: var(--yz-text-secondary);
  line-height: 1.7;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin: 12rpx 0 28rpx;
}

.filter-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--yz-border);
  color: var(--yz-text-secondary);
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.03);
}

.filter-btn.active {
  border-color: var(--yz-brand-primary-border);
  color: var(--yz-brand-primary);
  background: var(--yz-brand-primary-soft);
}

.loading-card,
.memory-card,
.empty {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.loading-card {
  display: flex;
  justify-content: center;
  padding: 64rpx 0;
  background: rgba(255, 255, 255, 0.96);
}

.timeline {
  position: relative;
  padding-left: 110rpx;
}

.timeline::before {
  content: "";
  position: absolute;
  left: 48rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: var(--yz-brand-primary-border);
}

.timeline-item {
  position: relative;
  margin-bottom: 80rpx;
}

.year {
  position: absolute;
  left: -98rpx;
  top: 4rpx;
  font-size: 32rpx;
  color: var(--yz-brand-primary);
  font-weight: bold;
  background: var(--yz-brand-primary-soft);
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  z-index: 2;
}

.memory-card {
  background: rgba(255, 255, 255, 0.96);
  padding: 22rpx;
}

.memory-img {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: var(--yz-bg-section);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--yz-text-secondary);
}

.memory-img.placeholder {
  font-size: 26rpx;
}

.memory-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.memory-title {
  font-size: 34rpx;
  margin-top: 14rpx;
  color: var(--yz-text-primary);
  font-weight: 600;
  flex: 1;
}

.tag {
  margin-top: 14rpx;
  padding: 4rpx 12rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.tag-self {
  color: var(--yz-success);
  background: var(--yz-success-soft);
  border: 1rpx solid var(--yz-brand-primary-border);
}

.tag-other {
  color: var(--yz-accent-warm);
  background: var(--yz-accent-warm-soft);
  border: 1rpx solid rgba(215, 155, 60, 0.3);
}

.memory-story {
  font-size: 28rpx;
  color: var(--yz-text-secondary);
  margin-top: 10rpx;
  line-height: 1.6;
}

.memory-meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.memory-meta-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.memory-person {
  font-size: 26rpx;
  color: var(--yz-text-secondary);
}

.memory-date {
  font-size: 24rpx;
  color: var(--yz-text-tertiary);
}

.edit-btn {
  font-size: 26rpx;
  color: var(--yz-brand-primary);
  border: 1rpx solid var(--yz-brand-primary-border);
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
}

.empty {
  text-align: center;
  color: var(--yz-text-secondary);
  font-size: 30rpx;
  margin-top: 60rpx;
  background: rgba(255, 255, 255, 0.96);
  padding: 40rpx 24rpx;
}

.floating-btn {
  position: fixed;
  right: 30rpx;
  bottom: 40rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  padding: 22rpx 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(111, 143, 200, 0.24);
  font-size: 28rpx;
  font-weight: 700;
}

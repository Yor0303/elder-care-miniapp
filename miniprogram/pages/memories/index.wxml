<!-- pages/memories/index.wxml -->
<view class="page">
  <view class="header">
    <view class="title">回忆管理</view>
    <view class="subtitle">像老人端一样按时间线查看</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:else class="timeline">
    <block wx:for="{{list}}" wx:key="id">
      <view class="timeline-item">
        <view class="year">{{item.year}}</view>
        <view class="memory-card">
          <view wx:if="{{item.img}}">
            <image class="memory-img" src="{{item.img}}" mode="aspectFill"></image>
          </view>
          <view wx:else class="memory-img placeholder">暂无图片</view>

          <view class="memory-title">{{item.title}}</view>
          <view class="memory-story" wx:if="{{item.story}}">{{item.story}}</view>

          <view class="memory-meta">
            <text class="memory-person">{{item.person || '未填写人物'}}</text>
            <view class="edit-btn" bindtap="editMemory" data-id="{{item.id}}">修改</view>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{list.length === 0}}" class="empty">暂无回忆</view>
  </view>

  <view class="floating-btn" bindtap="uploadMemory">
    <text class="plus">+</text>
    <text class="label">上传回忆</text>
  </view>
</view>

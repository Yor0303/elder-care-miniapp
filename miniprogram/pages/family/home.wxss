.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.preview-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid var(--yz-border-soft);
  box-shadow: var(--yz-shadow-soft);
}

.preview-copy {
  flex: 1;
  min-width: 0;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.preview-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.preview-btn {
  min-width: 172rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: var(--yz-brand-primary);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
}

.preview-btn::after {
  border: none;
}

.hero-card,
.section-card {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-medium);
}

.hero-card {
  padding: 30rpx;
  margin-bottom: 22rpx;
  background: var(--yz-gradient-hero);
  border: 1rpx solid var(--yz-border-soft);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-label,
.hero-state,
.section-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  white-space: nowrap;
}

.hero-label {
  padding: 10rpx 18rpx;
  background: rgba(255, 255, 255, 0.9);
  color: var(--yz-accent-warm);
  font-size: 22rpx;
  font-weight: 700;
}

.hero-state {
  padding: 10rpx 18rpx;
  background: var(--yz-warning-soft);
  color: var(--yz-warning);
  font-size: 22rpx;
  font-weight: 700;
}

.hero-state.ready {
  background: var(--yz-success-soft);
  color: var(--yz-success);
}

.hero-name {
  margin-top: 20rpx;
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 29rpx;
  line-height: 1.65;
  color: var(--yz-text-secondary);
}

.hero-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 24rpx;
  border: none;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 22rpx rgba(124, 152, 200, 0.16);
}

.hero-btn::after {
  border: none;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-actions .hero-btn {
  flex: 1;
}

.ghost-btn {
  background: var(--yz-warning-soft);
  color: var(--yz-warning);
  box-shadow: none;
}

.today-card {
  padding: 24rpx 24rpx 18rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: var(--yz-shadow-soft);
  border: 1rpx solid var(--yz-border-soft);
}

.today-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.today-card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.today-card-count {
  min-width: 56rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--yz-success-soft);
  color: var(--yz-success);
  font-size: 24rpx;
  font-weight: 700;
}

.today-loading {
  padding: 28rpx 0 12rpx;
  display: flex;
  justify-content: center;
}

.today-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--yz-border-soft);
}

.today-item:last-child {
  border-bottom: none;
  padding-bottom: 6rpx;
}

.today-item-check {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yz-success-soft);
  color: var(--yz-success);
  font-size: 28rpx;
  font-weight: 700;
}

.today-item-copy {
  flex: 1;
  min-width: 0;
}

.today-item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.today-item-meta,
.today-empty {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--yz-text-secondary);
}

.board-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 178rpx;
  padding: 28rpx 26rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid var(--yz-border-soft);
}

.section-aura {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  right: -40rpx;
  top: -32rpx;
  border-radius: 50%;
  opacity: 0.7;
}

.section-copy {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 1;
}

.section-serial {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--yz-text-tertiary);
}

.section-title {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.section-summary {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: var(--yz-text-secondary);
}

.section-side {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 18rpx;
}

.section-count {
  min-width: 88rpx;
  height: 46rpx;
  padding: 0 14rpx;
  background: rgba(255, 255, 255, 0.88);
  color: var(--yz-info);
  font-size: 22rpx;
  font-weight: 700;
}

.section-arrow-shell {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.92);
}

.section-arrow {
  font-size: 34rpx;
  color: var(--yz-text-tertiary);
}

.tone-amber {
  background: #fffaf4;
  border-color: #f2e4cf;
}

.tone-amber .section-aura {
  background: rgba(226, 164, 95, 0.12);
}

.tone-amber .section-count {
  background: var(--yz-warning-soft);
  color: var(--yz-warning);
}

.tone-amber .section-arrow-shell {
  background: rgba(226, 164, 95, 0.12);
}

.tone-rose {
  background: #fff8f8;
  border-color: #f0dcda;
}

.tone-rose .section-aura {
  background: rgba(216, 120, 114, 0.12);
}

.tone-rose .section-count {
  background: var(--yz-danger-soft);
  color: var(--yz-danger);
}

.tone-rose .section-arrow-shell {
  background: rgba(216, 120, 114, 0.12);
}

.tone-sage {
  background: #f8fcfa;
  border-color: #dceddf;
}

.tone-sage .section-aura {
  background: rgba(127, 200, 160, 0.14);
}

.tone-sage .section-count {
  background: var(--yz-success-soft);
  color: var(--yz-success);
}

.tone-sage .section-arrow-shell {
  background: rgba(127, 200, 160, 0.14);
}

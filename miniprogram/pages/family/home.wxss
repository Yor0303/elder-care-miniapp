/* pages/family/home.wxss */
.page{
  padding:40rpx;
  background:#F8F9FB;
  min-height:100vh;
}

.header{
  font-size:36rpx;
  font-weight:bold;
  text-align:center;
  margin-bottom:40rpx;
}

.card{
  display:flex;
  align-items:center;
  background:#FFFFFF;
  padding:50rpx 40rpx;
  margin-bottom:40rpx;
  border-radius:30rpx;
  box-shadow:0 10rpx 30rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}

.card:active{
  transform: scale(0.97);
  background:#F0F4F8;
}

.icon{
  font-size:80rpx;
  margin-right:40rpx;
}

.title{
  font-size:36rpx;
  font-weight:600;
  color:#333;
  margin-bottom:10rpx;
}

.desc{
  font-size:28rpx;
  color:#888;
}

/* 不同卡片配色区分 */
.upload{
  border-left:6rpx solid #4A90E2;
}

.manage{
  border-left:6rpx solid #50E3C2;
}
.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(229, 195, 149, 0.22), transparent 28%),
    linear-gradient(180deg, #fbf7f1 0%, #f3eee6 100%);
}

.hero-card,
.primary-card,
.service-card,
.tip-card {
  border-radius: 32rpx;
  box-shadow: 0 18rpx 42rpx rgba(54, 42, 27, 0.08);
}

.hero-card {
  padding: 34rpx 30rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, #6b4f3b 0%, #8b6a4d 58%, #b08863 100%);
  color: #fffaf3;
}

.hero-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(255, 250, 243, 0.88);
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 24rpx;
  color: rgba(255, 250, 243, 0.92);
}

.hero-tag.active {
  background: rgba(255, 255, 255, 0.2);
}

.hero-tag.soft {
  color: rgba(255, 250, 243, 0.82);
}

.hero-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 28rpx;
  border: none;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #6b4f3b;
  font-size: 30rpx;
  font-weight: 700;
}

.hero-btn::after {
  border: none;
}

.section {
  margin-bottom: 28rpx;
}

.section-head {
  margin-bottom: 18rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #4d3a2a;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #7b6d5f;
  line-height: 1.6;
}

.primary-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.primary-card {
  padding: 28rpx;
  background: #fffdf9;
}

.primary-card.memory {
  background: linear-gradient(145deg, #fff4e6 0%, #fffdf9 72%);
}

.primary-card.members {
  background: linear-gradient(145deg, #f5efe7 0%, #fffdf9 72%);
}

.primary-card.health {
  background: linear-gradient(145deg, #eef5ea 0%, #fffdf9 72%);
}

.primary-icon,
.service-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.primary-icon {
  margin-bottom: 18rpx;
  background: linear-gradient(145deg, #8a6547 0%, #5f4736 100%);
}

.primary-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3f3023;
}

.primary-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6f6255;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.service-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 26rpx 24rpx;
  background: rgba(255, 253, 249, 0.98);
}

.service-card:active,
.primary-card:active {
  transform: scale(0.99);
}

.service-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.service-copy {
  flex: 1;
}

.service-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #3f3023;
}

.service-desc {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.65;
  color: #7b6d5f;
}

.service-icon.profile {
  background: #f5eee5;
}

.service-icon.message {
  background: #fff1e5;
}

.service-icon.guide {
  background: #eef4ea;
}

.service-icon.bind {
  background: #f3eee7;
}

.service-arrow {
  font-size: 30rpx;
  color: #a39281;
}

.tip-card {
  padding: 28rpx 26rpx;
  background: linear-gradient(145deg, #fff7e2 0%, #fffdf6 100%);
}

.tip-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #8c6a1f;
}

.tip-line {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #7d6327;
}

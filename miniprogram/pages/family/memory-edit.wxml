<view class="page">
  <view class="hero-card">
    <view class="title">{{isEdit ? "编辑回忆" : "新增回忆"}}</view>
    <view class="subtitle">把时间、人物和照片整理好，老人端回看时会更自然。</view>
  </view>

  <view class="form">
    <view class="form-item">
      <view class="form-label">标题 *</view>
      <input
        class="form-input"
        placeholder="给这段回忆起个名字"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="50"
      />
    </view>

    <view class="form-item">
      <view class="form-label">故事内容 *</view>
      <textarea
        class="form-textarea"
        placeholder="写下这段回忆的故事..."
        value="{{story}}"
        bindinput="onStoryInput"
        maxlength="500"
      />
    </view>

    <view class="form-item">
      <view class="form-label">回忆日期 *</view>
      <picker mode="date" value="{{eventDate}}" bindchange="onDateChange">
        <view class="form-picker">
          <text class="{{eventDate ? '' : 'placeholder'}}">{{eventDate || "请选择具体日期，用于那年今日展示"}}</text>
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">相关人物</view>
      <picker
        mode="selector"
        range="{{personOptions}}"
        range-key="label"
        value="{{personIndex < 0 ? 0 : personIndex}}"
        bindchange="onPersonChange"
      >
        <view class="form-picker">
          <view class="picker-value {{personIndex < 0 ? 'placeholder' : ''}}">
            {{personIndex < 0 ? "请选择人物" : personOptions[personIndex].label}}
          </view>
          <text class="arrow">></text>
        </view>
      </picker>
      <view wx:if="{{personIndex >= 0}}" class="field-helper">当前已选：{{personOptions[personIndex].label}}</view>
    </view>

    <view class="form-item" bindtap="showTypePicker">
      <view class="form-label">类型</view>
      <view class="form-picker">
        <view class="picker-value {{type ? '' : 'placeholder'}}">{{typeLabels[type] || "请选择类型"}}</view>
        <text class="arrow">></text>
      </view>
      <view wx:if="{{type}}" class="field-helper">当前已选：{{typeLabels[type]}}</view>
    </view>

    <view class="form-item">
      <view class="form-label">照片</view>
      <view class="image-section">
        <view wx:if="{{fileList.length > 0}}" class="image-preview">
          <image src="{{fileList[0].url}}" mode="aspectFill" class="preview-img"></image>
          <view class="remove-btn" catchtap="removeImage">X</view>
        </view>
        <view wx:else class="image-upload" bindtap="chooseImage">
          <text class="upload-icon">+</text>
          <text class="upload-text">🖼️ 添加照片</text>
        </view>
      </view>
    </view>
  </view>

  <button class="save-btn" bindtap="save" disabled="{{saving}}">
    {{saving ? "保存中..." : "保存"}}
  </button>

  <button wx:if="{{isEdit}}" class="delete-btn" bindtap="delete">删除回忆</button>

  <mp-actionSheet
    show="{{showTypePicker}}"
    title="选择回忆类型"
    actions="{{typeActionItems}}"
    bindclose="hideTypePicker"
    bindactiontap="onTypeSelect"
  ></mp-actionSheet>

  <mp-dialog
    title="确认删除"
    show="{{showDeleteDialog}}"
    buttons="{{deleteDialogButtons}}"
    bindclose="closeDeleteDialog"
    bindbuttontap="onDeleteDialogTap"
  >
    删除后无法恢复，确定要删除这条回忆吗？
  </mp-dialog>
</view>

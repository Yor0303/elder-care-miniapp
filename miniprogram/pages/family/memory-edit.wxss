.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.hero-card,
.form {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.hero-card {
  padding: 32rpx 28rpx;
  margin-bottom: 22rpx;
  background: var(--yz-gradient-hero);
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.form {
  background: rgba(255, 255, 255, 0.96);
  padding: 10rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.form-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid var(--yz-border-soft);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: var(--yz-info);
  font-weight: 700;
  margin-bottom: 15rpx;
}

.form-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--yz-text-primary);
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
  border: 2rpx solid var(--yz-border-soft);
  box-sizing: border-box;
}

.form-textarea {
  display: block;
  width: 100%;
  font-size: 32rpx;
  line-height: 1.6;
  color: var(--yz-text-primary);
  height: 200rpx;
  padding: 24rpx;
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
  border: 2rpx solid var(--yz-border-soft);
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
  border: 2rpx solid var(--yz-border-soft);
  font-size: 32rpx;
  box-sizing: border-box;
}

.form-picker .placeholder {
  color: var(--yz-text-tertiary);
}

.form-picker .arrow {
  color: var(--yz-text-tertiary);
  font-size: 36rpx;
}

.image-section {
  margin-top: 10rpx;
}

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.remove-btn {
  position: absolute;
  top: -15rpx;
  right: -15rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--yz-danger);
  color: var(--yz-bg-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--yz-brand-primary-border);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--yz-text-secondary);
  background: var(--yz-bg-card-soft);
}

.upload-icon {
  font-size: 60rpx;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  margin-top: 10rpx;
}

.save-btn {
  width: 100%;
  height: 100rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 34rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn::after,
.delete-btn::after {
  border: none;
}

.save-btn[disabled] {
  background: var(--yz-text-tertiary);
}

.delete-btn {
  width: 100%;
  height: 100rpx;
  background: var(--yz-bg-card);
  color: var(--yz-danger);
  font-size: 34rpx;
  border-radius: 24rpx;
  margin-top: 20rpx;
  border: 2rpx solid rgba(216, 92, 74, 0.32);
}

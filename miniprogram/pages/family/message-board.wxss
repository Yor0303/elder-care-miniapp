.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.hero,
.composer-card,
.list-card {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-medium);
}

.hero {
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
  background: var(--yz-gradient-hero);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  color: var(--yz-accent-warm);
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 52rpx;
  line-height: 1.14;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--yz-text-secondary);
}

.composer-card,
.list-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.95);
}

.composer-tabs {
  display: flex;
  gap: 12rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-section);
}

.composer-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--yz-text-secondary);
  font-size: 28rpx;
  font-weight: 700;
}

.composer-tab-active {
  background: var(--yz-bg-card);
  color: var(--yz-brand-primary);
  box-shadow: 0 8rpx 20rpx rgba(111, 143, 200, 0.08);
}

.composer-panel,
.reminder-config,
.recording-panel,
.draft-panel {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: var(--yz-bg-card-soft);
}

.composer-head,
.draft-head,
.list-head,
.message-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.composer-title,
.list-title,
.draft-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.composer-state,
.list-subtitle,
.draft-desc,
.message-time {
  font-size: 24rpx;
  color: var(--yz-text-tertiary);
}

.note-input {
  width: 100%;
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: var(--yz-bg-card);
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--yz-text-primary);
}

.config-row + .config-row {
  margin-top: 22rpx;
}

.config-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: var(--yz-text-secondary);
}

.schedule-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: var(--yz-bg-card);
}

.schedule-trigger-text {
  font-size: 28rpx;
  color: var(--yz-text-primary);
}

.schedule-trigger-arrow {
  font-size: 30rpx;
  color: var(--yz-text-tertiary);
}

.field-input,
.picker-field {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: var(--yz-bg-card);
  color: var(--yz-text-primary);
  font-size: 28rpx;
}

.schedule-options,
.weekday-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.schedule-chip,
.weekday-chip {
  padding: 14rpx 20rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-section);
  color: var(--yz-text-secondary);
  font-size: 26rpx;
  line-height: 1;
}

.schedule-chip-active,
.weekday-chip-active {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-bar button,
.play-btn,
.text-tag {
  border: none;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.text-btn,
.record-btn,
.stop-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  border: none;
}

.text-btn {
  background: var(--yz-bg-section);
  color: var(--yz-text-secondary);
}

.record-btn {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}

.stop-btn {
  margin-top: 18rpx;
  background: var(--yz-danger);
  color: var(--yz-bg-card);
}

.recording-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.record-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--yz-danger);
}

.record-text {
  font-size: 28rpx;
  color: var(--yz-text-secondary);
}

.empty-state {
  padding: 56rpx 0 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--yz-text-tertiary);
}

.loading-state {
  display: flex;
  justify-content: center;
}

.message-list {
  margin-top: 18rpx;
}

.message-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-card-soft);
}

.message-item:last-child {
  margin-bottom: 0;
}

.message-main {
  flex: 1;
  min-width: 0;
}

.message-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.message-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.message-type {
  padding: 6rpx 14rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-section);
  color: var(--yz-text-secondary);
  font-size: 22rpx;
}

.message-type-reminder {
  background: var(--yz-warning-soft);
  color: var(--yz-warning);
}

.message-desc {
  font-size: 24rpx;
  color: var(--yz-text-tertiary);
}

.message-note {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--yz-info);
}

.message-schedule {
  margin-top: 14rpx;
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 24rpx;
  background: var(--yz-success-soft);
  color: var(--yz-success);
  font-size: 24rpx;
}

.play-btn {
  min-width: 128rpx;
  padding: 0 24rpx;
  background: var(--yz-info-soft);
  color: var(--yz-info);
}

.text-tag {
  min-width: 128rpx;
  padding: 0 24rpx;
  text-align: center;
  background: var(--yz-bg-section);
  color: var(--yz-text-secondary);
}

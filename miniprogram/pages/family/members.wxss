.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.hero-card,
.loading-card,
.member-card,
.empty-state {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 22rpx;
  background: var(--yz-gradient-hero);
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.subtitle,
.meta,
.desc,
.empty-text {
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.subtitle {
  margin-top: 10rpx;
}

.hero-btn,
.add-member-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 24rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
}

.hero-btn::after,
.add-member-btn::after {
  border: none;
}

.hero-btn {
  flex-shrink: 0;
  padding: 0 28rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}

.loading-card {
  display: flex;
  justify-content: center;
  padding: 64rpx 0;
  margin-bottom: 22rpx;
  background: rgba(255, 255, 255, 0.96);
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.member-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: var(--yz-info-soft);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-text-tertiary);
  font-size: 24rpx;
  font-weight: 700;
}

.info {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
}

.relation {
  color: var(--yz-brand-primary);
  font-weight: 700;
}

.desc {
  margin-top: 8rpx;
}

.edit-btn {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 26rpx;
  font-weight: 700;
}

.empty-state {
  padding: 56rpx 32rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.96);
}

.empty-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 136rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.empty-text {
  margin-top: 10rpx;
}

.add-member-btn {
  width: 100%;
  margin-top: 18rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

.container {
  min-height: 100vh;
  padding: 28rpx;
  background: var(--yz-bg-page);
  box-sizing: border-box;
}

.hero-card,
.panel-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-medium);
}

.hero-card {
  padding: 34rpx 32rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
  margin-bottom: 14rpx;
}

.hero-desc,
.panel-desc,
.approval-desc,
.tip-line,
.scan-text,
.pending-meta,
.invite-address {
  font-size: 27rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.mode-tabs {
  display: flex;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 0 0 2rpx rgba(207, 217, 230, 0.55);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 24rpx;
  background: transparent;
  color: var(--yz-text-secondary);
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}

.mode-tab.active {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  box-shadow: 0 8rpx 20rpx rgba(111, 143, 200, 0.2);
}

.panel-card {
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.current-card {
  margin-top: 4rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
  margin-bottom: 12rpx;
}

.phone-input {
  margin: 28rpx 0 22rpx;
  background: var(--yz-bg-card-soft);
  border: 2rpx solid var(--yz-border);
  border-radius: 24rpx;
  height: 92rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: var(--yz-text-primary);
  box-sizing: border-box;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 24rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.primary-btn::after {
  border: none;
}

.flow-tip,
.approval-box,
.state-card,
.invite-card,
.scan-preview,
.pending-item {
  background: var(--yz-bg-card-soft);
  border: 2rpx solid var(--yz-border);
  border-radius: 24rpx;
}

.flow-tip {
  margin-top: 24rpx;
  padding: 24rpx 24rpx 18rpx;
}

.tip-title,
.approval-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
  margin-bottom: 10rpx;
}

.tip-line {
  margin-bottom: 8rpx;
}

.scan-preview {
  margin: 28rpx 0 22rpx;
  padding: 38rpx 24rpx;
  text-align: center;
}

.scan-icon {
  font-size: 72rpx;
  color: var(--yz-brand-primary);
  margin-bottom: 12rpx;
}

.invite-card {
  padding: 28rpx 26rpx;
}

.invite-badge,
.pending-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: var(--yz-info-soft);
  color: var(--yz-info);
  font-size: 24rpx;
  margin-bottom: 18rpx;
}

.invite-name,
.pending-name {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.invite-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 27rpx;
  color: var(--yz-text-secondary);
  margin: 14rpx 0;
}

.approval-box {
  margin-top: 24rpx;
  padding: 22rpx;
}

.relation-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 84rpx;
  padding: 0 8rpx;
  font-size: 29rpx;
  color: var(--yz-text-primary);
}

.placeholder {
  color: var(--yz-text-tertiary);
}

.arrow {
  color: var(--yz-text-tertiary);
}

.state-card {
  padding: 28rpx 24rpx;
  margin-top: 20rpx;
}

.state-card.success {
  background: var(--yz-success-soft);
  border-color: var(--yz-brand-primary-border);
  color: var(--yz-success);
}

.pending-card {
  margin-top: 10rpx;
}

.pending-item {
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
}

.pending-main {
  flex: 1;
  min-width: 0;
}

.success-badge {
  background: var(--yz-success-soft);
  color: var(--yz-success);
}

.pending-badge.pending {
  background: var(--yz-info-soft);
  color: var(--yz-info);
}

.pending-badge.approved {
  background: var(--yz-success-soft);
  color: var(--yz-success);
}

.pending-badge.rejected {
  background: var(--yz-danger-soft);
  color: var(--yz-danger);
}

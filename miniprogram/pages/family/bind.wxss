.container {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef3f8 100%);
  box-sizing: border-box;
}

.hero-card,
.panel-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.hero-card {
  padding: 34rpx 32rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #18324b;
  margin-bottom: 14rpx;
}

.hero-desc,
.panel-desc,
.approval-desc,
.tip-line,
.scan-text,
.pending-meta,
.invite-address {
  font-size: 27rpx;
  line-height: 1.7;
  color: #667085;
}

.mode-tabs {
  display: flex;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 0 0 2rpx rgba(207, 217, 230, 0.55);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  background: transparent;
  color: #51606f;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}

.mode-tab.active {
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(31, 111, 235, 0.2);
}

.panel-card {
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2a37;
  margin-bottom: 12rpx;
}

.phone-input {
  margin: 28rpx 0 22rpx;
  background: #f8fafc;
  border: 2rpx solid #dbe5f0;
  border-radius: 24rpx;
  height: 92rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1f2a37;
  box-sizing: border-box;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.primary-btn::after {
  border: none;
}

.flow-tip,
.approval-box,
.state-card,
.invite-card,
.scan-preview,
.pending-item {
  background: #f8fbff;
  border: 2rpx solid #d9e7f7;
  border-radius: 24rpx;
}

.flow-tip {
  margin-top: 24rpx;
  padding: 24rpx 24rpx 18rpx;
}

.tip-title,
.approval-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2a37;
  margin-bottom: 10rpx;
}

.tip-line {
  margin-bottom: 8rpx;
}

.scan-preview {
  margin: 28rpx 0 22rpx;
  padding: 38rpx 24rpx;
  text-align: center;
}

.scan-icon {
  font-size: 72rpx;
  color: #1f6feb;
  margin-bottom: 12rpx;
}

.invite-card {
  padding: 28rpx 26rpx;
}

.invite-badge,
.pending-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eaf3ff;
  color: #2563eb;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}

.invite-name,
.pending-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2a37;
}

.invite-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 27rpx;
  color: #667085;
  margin: 14rpx 0;
}

.approval-box {
  margin-top: 24rpx;
  padding: 22rpx;
}

.state-card {
  padding: 28rpx 24rpx;
  margin-top: 20rpx;
}

.state-card.success {
  background: #effaf3;
  border-color: #b8e5c6;
  color: #276749;
}

.pending-card {
  margin-top: 10rpx;
}

.pending-item {
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
}

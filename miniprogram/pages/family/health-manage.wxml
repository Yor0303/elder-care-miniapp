<view class="page">
  <view class="title">健康数据管理</view>

  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading">加载中...</view>
  </view>

  <view wx:else>
    <view class="section hero-section">
      <view class="section-header">
        <view>
          <view class="section-title">今日健康概览</view>
          <view class="section-subtitle">家属可以代录每日数据，系统会自动生成提醒</view>
        </view>
        <view class="add-btn primary" bindtap="showAddMeasurement">+ 代录数据</view>
      </view>

      <view class="health-grid">
        <view wx:for="{{todayCards}}" wx:key="key" class="overview-card">
          <view class="overview-label">{{item.label}}</view>
          <view class="overview-value">{{item.value}}</view>
          <view wx:if="{{item.unit}}" class="overview-unit">{{item.unit}}</view>
          <view class="status-pill status-{{item.status.type}}">{{item.status.text}}</view>
        </view>
      </view>

      <view wx:if="{{latestMeasurement}}" class="latest-note">
        最近一次记录：{{latestMeasurement.recordDate || "--"}}<text wx:if="{{latestMeasurement.notes}}"> · {{latestMeasurement.notes}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">异常提醒</view>
      </view>

      <view wx:if="{{!healthAlerts.length}}" class="empty-tip">当前没有明显异常提醒</view>

      <view wx:for="{{healthAlerts}}" wx:key="text" class="alert-card alert-{{item.level}}">
        <view class="alert-text">{{item.text}}</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">血压趋势</view>
      </view>

      <view wx:if="{{!bloodPressureTrend.length}}" class="empty-tip">录入几次血压后，这里会显示趋势图</view>

      <view wx:else class="trend-card">
        <view wx:for="{{bloodPressureTrend}}" wx:key="date" class="trend-row">
          <view class="trend-date">{{item.label}}</view>
          <view class="trend-bars">
            <view class="trend-bar-track">
              <view class="trend-bar trend-bar-primary" style="width: {{item.systolicWidth}};"></view>
            </view>
            <view class="trend-bar-track">
              <view class="trend-bar trend-bar-secondary" style="width: {{item.diastolicWidth}};"></view>
            </view>
          </view>
          <view class="trend-value">{{item.systolic}}/{{item.diastolic}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">血糖趋势</view>
      </view>

      <view wx:if="{{!bloodSugarTrend.length}}" class="empty-tip">录入几次血糖后，这里会显示趋势图</view>

      <view wx:else class="trend-card">
        <view wx:for="{{bloodSugarTrend}}" wx:key="date" class="trend-row single-trend-row">
          <view class="trend-date">{{item.label}}</view>
          <view class="trend-bars">
            <view class="trend-bar-track single-track">
              <view class="trend-bar trend-bar-accent" style="width: {{item.width}};"></view>
            </view>
          </view>
          <view class="trend-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">代录历史</view>
      </view>

      <view wx:if="{{measurementHistory.length === 0}}" class="empty-tip">还没有代录记录</view>

      <view wx:for="{{measurementHistory}}" wx:key="id" class="record-card">
        <view class="record-info">
          <view class="record-name">{{item.recordDate || "--"}}</view>
          <view class="record-meta">
            血压：{{item.bloodPressure || "--/--"}} · 心率：{{item.heartRate || "--"}} · 血糖：{{item.bloodSugar || "--"}}
          </view>
          <view wx:if="{{item.notes}}" class="record-notes">备注：{{item.notes}}</view>
        </view>
        <view class="delete-btn" catchtap="deleteRecord" data-id="{{item.id}}">删除</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">既往病史</view>
        <view class="add-btn" bindtap="showAddHistory">+ 添加</view>
      </view>

      <view wx:if="{{medicalHistory.length === 0}}" class="empty-tip">暂无病史记录</view>

      <view wx:for="{{medicalHistory}}" wx:key="id" class="record-card">
        <view class="record-info">
          <view class="record-name">{{item.name}}</view>
          <view class="record-meta">{{item.diagnoseYear}} 年确诊</view>
          <view wx:if="{{item.notes}}" class="record-notes">{{item.notes}}</view>
        </view>
        <view class="delete-btn" catchtap="deleteRecord" data-id="{{item.id}}">删除</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">当前用药</view>
        <view class="add-btn" bindtap="showAddMedication">+ 添加</view>
      </view>

      <view wx:if="{{medications.length === 0}}" class="empty-tip">暂无用药记录</view>

      <view wx:for="{{medications}}" wx:key="id" class="record-card">
        <view class="record-info">
          <view class="record-name">{{item.name}}</view>
          <view class="record-meta">{{item.frequency || "未填写频率"}}</view>
          <view wx:if="{{item.dosage}}" class="record-notes">剂量：{{item.dosage}}</view>
          <view wx:if="{{item.time}}" class="record-notes">服用时间：{{item.time}}</view>
          <view wx:if="{{item.notes}}" class="record-notes">备注：{{item.notes}}</view>
        </view>
        <view class="delete-btn" catchtap="deleteRecord" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="noop">
      <view class="modal-title">
        {{addType === "measurement" ? "代录健康数据" : addType === "history" ? "添加病史" : "添加用药"}}
      </view>

      <view wx:if="{{addType === 'measurement'}}">
        <view class="modal-item">
          <view class="modal-label">记录日期</view>
          <picker mode="date" value="{{newRecord.recordDate}}" bindchange="onDateChange">
            <view class="modal-picker">{{newRecord.recordDate || "请选择日期"}}</view>
          </picker>
        </view>
        <view class="modal-item">
          <view class="modal-label">血压</view>
          <input class="modal-input" placeholder="例如 128/82" data-field="bloodPressure" value="{{newRecord.bloodPressure}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <view class="modal-label">心率</view>
          <input class="modal-input" type="number" placeholder="例如 72" data-field="heartRate" value="{{newRecord.heartRate}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <view class="modal-label">血糖</view>
          <input class="modal-input" type="digit" placeholder="例如 5.6" data-field="bloodSugar" value="{{newRecord.bloodSugar}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <view class="modal-label">备注</view>
          <input class="modal-input" placeholder="例如 饭后两小时" data-field="notes" value="{{newRecord.notes}}" bindinput="onInputChange" />
        </view>
      </view>

      <view wx:if="{{addType === 'history'}}">
        <view class="modal-item">
          <input class="modal-input" placeholder="病史名称，例如高血压" data-field="name" value="{{newRecord.name}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" type="number" placeholder="确诊年份" data-field="diagnoseYear" value="{{newRecord.diagnoseYear}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="备注，可选" data-field="notes" value="{{newRecord.notes}}" bindinput="onInputChange" />
        </view>
      </view>

      <view wx:if="{{addType === 'medication'}}">
        <view class="modal-item">
          <input class="modal-input" placeholder="药物名称" data-field="name" value="{{newRecord.name}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="服用频率" data-field="frequency" value="{{newRecord.frequency}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="剂量" data-field="dosage" value="{{newRecord.dosage}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="服用时间" data-field="time" value="{{newRecord.time}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="备注，可选" data-field="notes" value="{{newRecord.notes}}" bindinput="onInputChange" />
        </view>
      </view>

      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeModal">取消</button>
        <button class="modal-btn confirm" bindtap="submitNewRecord">保存</button>
      </view>
    </view>
  </view>
</view>

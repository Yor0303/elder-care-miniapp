<view class="page">
  <view class="title">健康数据管理</view>

  <view wx:if="{{loading}}" class="loading-container">
    <mp-loading type="circle" tips="加载健康数据中"></mp-loading>
  </view>

  <view wx:else>
    <view class="section">
      <view class="section-header">
        <view class="section-title">趋势概览</view>
        <text class="tip">更新今日健康后会自动沉淀趋势记录</text>
      </view>

      <view class="overview-card">
        <view class="overview-main-card" bindtap="editTodayHealth">
          <view class="overview-label">血压</view>
          <view class="overview-value">{{pressureOverview.current}}</view>
          <view class="overview-subtitle">适合快速查看最近状态</view>
        </view>
        <view class="overview-side">
          <view class="overview-side-card" catchtap="editHeartRate">
            <text class="mini-metric-label">心率</text>
            <text class="mini-metric-value">{{todayHealth.heartRate || "--"}} 次/分</text>
          </view>
          <view class="overview-side-card" catchtap="editBloodSugar">
            <text class="mini-metric-label">血糖</text>
            <text class="mini-metric-value">{{todayHealth.bloodSugar || "--"}} mmol/L</text>
          </view>
        </view>
      </view>

      <view class="chart-card">
        <view class="chart-header">
          <view>
            <view class="chart-title">血压变化</view>
            <view class="chart-subtitle">最近 {{pressureTrend.length || 0}} 条记录</view>
          </view>
        </view>

        <view wx:if="{{pressureTrend.length === 0}}" class="chart-empty">
          暂无历史趋势，录入今日数据后会自动生成血压图表。
        </view>

        <scroll-view wx:else class="pressure-track" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="pressure-items">
            <view wx:for="{{pressureTrend}}" wx:key="label" class="pressure-item">
              <view class="pressure-value">{{item.displayValue}}</view>
              <view class="pressure-sticks">
                <view class="pressure-stick systolic animate-rise" style="height: {{item.systolicHeight}}rpx;"></view>
                <view class="pressure-stick diastolic animate-rise" style="height: {{item.diastolicHeight}}rpx;"></view>
              </view>
              <view class="pressure-label">{{item.label}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view wx:for="{{chartCards}}" wx:key="key" class="chart-card">
        <view class="chart-header">
          <view>
            <view class="chart-title">{{item.title}}</view>
            <view class="chart-subtitle">{{item.changeText}}</view>
          </view>
          <view class="chart-current">{{item.latestValue}}{{item.empty ? "" : item.unit}}</view>
        </view>

        <view wx:if="{{item.empty}}" class="chart-empty">
          暂无{{item.title}}数据。
        </view>

        <scroll-view wx:else class="bar-track" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="bar-list">
            <view wx:for="{{item.bars}}" wx:key="label" class="bar-item">
              <view class="bar-value">{{item.valueText}}</view>
              <view class="bar-column">
                <view class="bar-fill animate-rise" style="height: {{item.height}}rpx;"></view>
              </view>
              <view class="bar-label">{{item.label}}</view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">今日健康</view>
        <text class="tip">点击卡片可直接编辑</text>
      </view>

      <view class="data-card" bindtap="editTodayHealth">
        <view class="data-label">血压</view>
        <view class="data-value">{{todayHealth.bloodPressure || "--/--"}}</view>
        <view class="edit-icon">编辑</view>
      </view>

      <view class="data-card" bindtap="editHeartRate">
        <view class="data-label">心率</view>
        <view class="data-value">{{todayHealth.heartRate || "--"}} 次/分</view>
        <view class="edit-icon">编辑</view>
      </view>

      <view class="data-card" bindtap="editBloodSugar">
        <view class="data-label">血糖</view>
        <view class="data-value">{{todayHealth.bloodSugar || "--"}} mmol/L</view>
        <view class="edit-icon">编辑</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">既往病史</view>
        <view class="add-btn" bindtap="showAddHistory">添加</view>
      </view>

      <view wx:if="{{medicalHistory.length === 0}}" class="empty-tip">
        暂无病史记录，点击右上角添加
      </view>

      <view wx:for="{{medicalHistory}}" wx:key="id" class="data-card record-card">
        <view class="record-info">
          <view class="record-name">{{item.name}}</view>
          <view class="record-meta">{{item.diagnoseYear}} 年确诊</view>
          <view wx:if="{{item.notes}}" class="record-notes">{{item.notes}}</view>
        </view>
        <view class="record-actions">
          <view class="delete-btn" catchtap="deleteRecord" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title">当前用药</view>
        <view class="add-btn" bindtap="showAddMedication">添加</view>
      </view>

      <view wx:if="{{medications.length === 0}}" class="empty-tip">
        暂无用药记录，点击右上角添加
      </view>

      <view wx:for="{{medications}}" wx:key="id" class="data-card record-card">
        <view class="record-info">
          <view class="record-name">{{item.name}}</view>
          <view class="record-meta">{{item.frequency || "未填写频率"}}</view>
          <view wx:if="{{item.dosage}}" class="record-notes">剂量：{{item.dosage}}</view>
          <view wx:if="{{item.time}}" class="record-notes">服用时间：{{item.time}}</view>
          <view wx:if="{{item.reminderEnabled && item.reminderScheduleText}}" class="record-tag">{{item.reminderScheduleText}}</view>
          <view wx:if="{{item.notes}}" class="record-notes">备注：{{item.notes}}</view>
        </view>
        <view class="record-actions">
          <view class="edit-btn" catchtap="editMedication" data-id="{{item.id}}">编辑</view>
          <view class="delete-btn" catchtap="deleteRecord" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>
  </view>

  <mp-dialog
    title="{{addType === 'history' ? '添加病史' : (editingMedicationId ? '编辑用药' : '添加用药')}}"
    show="{{showAddModal}}"
    buttons="{{formDialogButtons}}"
    bindclose="closeModal"
    bindbuttontap="onFormDialogButtonTap"
  >
    <view class="dialog-body">
      <view wx:if="{{addType === 'history'}}">
        <view class="modal-item">
          <input class="modal-input" placeholder="病史名称，如：高血压" data-field="name" value="{{newRecord.name}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" type="number" placeholder="确诊年份，如：2020" data-field="diagnoseYear" value="{{newRecord.diagnoseYear}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="备注，可选" data-field="notes" value="{{newRecord.notes}}" bindinput="onInputChange" />
        </view>
      </view>

      <view wx:if="{{addType === 'medication'}}">
        <view class="modal-item">
          <input class="modal-input" placeholder="药物名称，如：降压药" data-field="name" value="{{newRecord.name}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="服用频率，如：每日 1 次" data-field="frequency" value="{{newRecord.frequency}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="剂量，如：1 片" data-field="dosage" value="{{newRecord.dosage}}" bindinput="onInputChange" />
        </view>
        <view class="modal-item">
          <picker mode="time" value="{{newRecord.time || '09:00'}}" bindchange="onMedicationTimeChange">
            <view class="picker-field">{{newRecord.time || "选择用药时间"}}</view>
          </picker>
        </view>
        <view class="modal-item switch-item">
          <view class="switch-copy">
            <view class="switch-title">开启用药提醒</view>
            <view class="switch-desc">老人端备忘录会按照你设置的规则显示</view>
          </view>
          <switch color="#8b6a4d" checked="{{newRecord.reminderEnabled}}" bindchange="onReminderSwitch" />
        </view>
        <view wx:if="{{newRecord.reminderEnabled}}" class="modal-item">
          <picker mode="time" value="{{newRecord.reminderTime || '09:00'}}" bindchange="onReminderTimeChange">
            <view class="picker-field">{{newRecord.reminderTime || "选择提醒时间"}}</view>
          </picker>
        </view>
        <view wx:if="{{newRecord.reminderEnabled}}" class="modal-item">
          <view class="schedule-label">提醒规则</view>
          <view class="schedule-options">
            <view
              wx:for="{{reminderScheduleOptions}}"
              wx:key="value"
              class="schedule-chip {{newRecord.reminderScheduleType === item.value ? 'schedule-chip-active' : ''}}"
              data-value="{{item.value}}"
              bindtap="onReminderScheduleSelect"
            >
              {{item.label}}
            </view>
          </view>
        </view>
        <view wx:if="{{newRecord.reminderEnabled && newRecord.reminderScheduleType === 'once'}}" class="modal-item">
          <picker mode="date" value="{{newRecord.reminderDate}}" bindchange="onReminderDateChange">
            <view class="picker-field">{{newRecord.reminderDate || "选择提醒日期"}}</view>
          </picker>
        </view>
        <view wx:if="{{newRecord.reminderEnabled && newRecord.reminderScheduleType === 'weekly'}}" class="modal-item">
          <view class="schedule-label">选择星期</view>
          <view class="weekday-options">
            <view
              wx:for="{{weekdayOptions}}"
              wx:key="value"
              class="weekday-chip {{newRecord.reminderWeekdays.indexOf(item.value) !== -1 ? 'weekday-chip-active' : ''}}"
              data-day="{{item.value}}"
              bindtap="toggleReminderWeekday"
            >
              {{item.label}}
            </view>
          </view>
        </view>
        <view class="modal-item">
          <input class="modal-input" placeholder="备注，可选" data-field="notes" value="{{newRecord.notes}}" bindinput="onInputChange" />
        </view>
      </view>
    </view>
  </mp-dialog>

  <mp-dialog
    title="确认删除"
    show="{{showDeleteDialog}}"
    buttons="{{deleteDialogButtons}}"
    bindclose="closeDeleteDialog"
    bindbuttontap="onDeleteDialogButtonTap"
  >
    删除后无法恢复，确定要删除这条记录吗？
  </mp-dialog>
</view>

<view class="page">
  <view class="header">
    <view class="welcome">{{guideId ? "编辑教程" : "新增教程"}}</view>
    <view class="subtitle">一个教程可以有很多步骤，每一步都配一张图片和一段说明。</view>
  </view>

  <view wx:if="{{loading}}" class="card loading-card">
    <mp-loading type="dot-gray"></mp-loading>
  </view>

  <view wx:else class="card form-card">
    <view class="form-item">
      <view class="label">教程标题</view>
      <input class="input" data-field="title" value="{{title}}" bindinput="onInput" />
      <view class="helper-text">例如：电饭煲怎么煮饭</view>
    </view>

    <view class="form-item">
      <view class="label">适用物品</view>
      <input class="input" data-field="itemName" value="{{itemName}}" bindinput="onInput" />
      <view class="helper-text">例如：电饭煲、热水器、微波炉</view>
    </view>

    <view class="form-item">
      <view class="label">图文步骤</view>
      <view class="step-list">
        <block wx:for="{{steps}}" wx:key="uid">
          <view class="step-card">
            <view class="step-head">
              <view class="step-title">步骤 {{index + 1}}</view>
              <button class="secondary-btn remove-btn" bindtap="removeStep" data-index="{{index}}">删除</button>
            </view>

            <view class="upload-box" bindtap="chooseStepImage" data-index="{{index}}">
              <image wx:if="{{item.imagePreview}}" class="preview-image" src="{{item.imagePreview}}" mode="aspectFill" />
              <view wx:else class="upload-placeholder">点击上传这一步的图片</view>
            </view>
            <view class="helper-text">建议拍清楚按钮位置或操作界面，老人更容易看懂。</view>

            <textarea
              class="textarea step-textarea"
              value="{{item.text}}"
              bindinput="onStepTextInput"
              data-index="{{index}}"
              maxlength="-1"
            />
            <view class="helper-text">例如：先把米洗干净，再放入电饭煲。</view>
          </view>
        </block>
      </view>
      <button class="secondary-btn add-step-btn" bindtap="addStep">新增一步</button>
    </view>

    <view class="form-item">
      <view class="label">可选视频</view>
      <view wx:if="{{videoPreview}}" class="video-panel">
        <video class="preview-video" src="{{videoPreview}}" controls></video>
        <button class="secondary-btn small-btn" bindtap="clearVideo">移除视频</button>
      </view>
      <button wx:else class="secondary-btn upload-btn" bindtap="chooseVideo">上传视频</button>
    </view>

    <button class="primary-btn submit-btn" bindtap="saveGuide" disabled="{{saving}}">
      {{saving ? "保存中..." : "保存教程"}}
    </button>
  </view>
</view>

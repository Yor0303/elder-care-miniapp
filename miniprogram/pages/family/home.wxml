<view class="page">
  <view wx:if="{{previewMode}}" class="preview-banner">
    <view class="preview-copy">
      <view class="preview-title">{{copy.guestPreviewTitle}}</view>
      <view class="preview-desc">{{copy.guestPreviewDesc}}</view>
    </view>
    <button class="preview-btn" bindtap="goToLogin">{{copy.guestPreviewAction}}</button>
  </view>

  <view class="hero-card">
    <view class="hero-top">
      <view class="hero-label">家属端</view>
      <view class="hero-state {{hasBoundElder && !guestMode ? 'ready' : ''}}">
        {{guestMode ? copy.guestState : (hasBoundElder ? "已连接" : "待绑定")}}
      </view>
    </view>

    <view class="hero-name">{{guestMode ? copy.guestElderName : (hasBoundElder ? elderName : "未绑定老人")}}</view>
    <view class="hero-desc">
      {{guestMode ? copy.guestHeroDesc : (hasBoundElder ? "围绕建档、陪伴和照护整理好全部功能入口。" : "先完成绑定，再开始管理资料、回忆和健康内容。")}}
    </view>

    <view class="hero-actions">
      <button class="hero-btn" bindtap="goToBindPage">
        {{guestMode ? copy.guestPrimaryFeature : (hasBoundElder ? "管理绑定" : "立即绑定")}}
      </button>
      <button class="hero-btn ghost-btn" bindtap="goToElderPreview">
        {{guestMode ? copy.guestSecondaryFeature : "进入老人端"}}
      </button>
    </view>
  </view>

  <view wx:if="{{hasBoundElder}}" class="today-card">
    <view class="today-card-head">
      <view class="today-card-title">今天已完成</view>
      <view wx:if="{{todayCompletedTasks.length}}" class="today-card-count">{{todayCompletedTasks.length}}</view>
    </view>

    <view wx:if="{{tasksLoading}}" class="today-loading">
      <mp-loading type="dot-gray"></mp-loading>
    </view>

    <block wx:elif="{{todayCompletedTasks.length}}">
      <view wx:for="{{todayCompletedTasks}}" wx:key="id" class="today-item">
        <view class="today-item-check">
          <app-icon name="check" size="28rpx" color="#2f8f54"></app-icon>
        </view>
        <view class="today-item-copy">
          <view class="today-item-title">{{item.title}}</view>
          <view wx:if="{{item.subtitle}}" class="today-item-meta">{{item.subtitle}}</view>
        </view>
      </view>
    </block>

    <view wx:else class="today-empty">今天还没有完成记录</view>
  </view>

  <view class="board-list">
    <view
      wx:for="{{sectionCards}}"
      wx:key="key"
      class="section-card tone-{{item.tone}}"
      data-section="{{item.key}}"
      bindtap="openSectionPopup"
    >
      <view class="section-aura"></view>
      <view class="section-copy">
        <view class="section-serial">{{item.serial}}</view>
        <view class="section-title">{{item.title}}</view>
        <view class="section-summary">{{item.summary}}</view>
      </view>

      <view class="section-side">
        <view class="section-count">{{item.count}} 项</view>
        <view class="section-arrow-shell">
          <view class="section-arrow">
            <app-icon name="chevron-right" size="30rpx" color="#96a4ae"></app-icon>
          </view>
        </view>
      </view>
    </view>
  </view>

  <mp-actionSheet
    show="{{sectionSheetVisible}}"
    title="{{sectionSheetTitle}}"
    actions="{{sectionSheetActions}}"
    bindclose="closeSectionPopup"
    bindactiontap="onSelectSectionAction"
  ></mp-actionSheet>
</view>

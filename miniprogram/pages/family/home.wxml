<view class="page">
  <view class="header">
    <view class="welcome">欢迎回来</view>
    <view class="subtitle">您可以在这里为 {{elderName}} 上传和管理信息</view>
  </view>

  <view class="menu-section">
    <view class="card" bindtap="goToProfile">
      <view class="card-left">
        <view class="icon">🪪</view>
        <view class="card-content">
          <view class="card-title">老人资料</view>
          <view class="card-desc">完善身份信息与紧急联系人</view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>

    <view class="card" bindtap="goToMemoryManage">
      <view class="card-left">
        <view class="icon">🖼</view>
        <view class="card-content">
          <view class="card-title">回忆管理</view>
          <view class="card-desc">像时间线一样查看与修改回忆</view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>

    <view class="card" bindtap="goToHealthManage">
      <view class="card-left">
        <view class="icon">💊</view>
        <view class="card-content">
          <view class="card-title">健康管理</view>
          <view class="card-desc">健康数据、病史和用药提醒</view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>

    <view class="card" bindtap="goToMembers">
      <view class="card-left">
        <view class="icon">👨‍👩‍👧</view>
        <view class="card-content">
          <view class="card-title">家庭成员</view>
          <view class="card-desc">查看和管理家人信息</view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>

    <view class="card" bindtap="goToMessageBoard">
      <view class="card-left">
        <view class="icon">🎙</view>
        <view class="card-content">
          <view class="card-title">家人留言板</view>
          <view class="card-desc">录制语音留言，给 {{elderName}} 送去问候</view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>

    <view class="card" bindtap="goToLifeGuides">
      <view class="card-left">
        <view class="icon">📘</view>
        <view class="card-content">
          <view class="card-title">生活小助手</view>
          <view class="card-desc">上传家电和常用物品的图文教程</view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>

    <view class="card" bindtap="goToBindPage">
      <view class="card-left">
        <view class="icon">🔆</view>
        <view class="card-content">
          <view class="card-title">绑定老人</view>
          <view class="card-desc">绑定老人信息</view>
        </view>
      </view>
      <view class="arrow">›</view>
    </view>
  </view>

  <view class="tips">
    <view class="tips-title">温馨提示</view>
    <view class="tips-content">
      上传的内容会同步显示在老人端小程序中，方便老人随时查看家人的关爱。
    </view>
  </view>
</view>

<view class="page">
  <view class="hero-card">
    <view class="hero-top">
      <view class="hero-label">家属端</view>
      <view class="hero-state {{hasBoundElder ? 'ready' : ''}}">
        {{hasBoundElder ? "已连接" : "待绑定"}}
      </view>
    </view>

    <view class="hero-name">{{hasBoundElder ? elderName : "未绑定老人"}}</view>
    <view class="hero-desc">
      {{hasBoundElder ? "围绕建档、陪伴和照护整理好全部功能入口。" : "先完成绑定，再开始管理资料、回忆和健康内容。"}}
    </view>

    <view class="hero-actions">
      <button class="hero-btn" bindtap="goToBindPage">{{hasBoundElder ? "管理绑定" : "立即绑定"}}</button>
      <button class="hero-btn ghost-btn" bindtap="goToElderPreview">测试老人端</button>
    </view>
  </view>

  <view wx:if="{{hasBoundElder}}" class="today-card">
    <view class="today-card-head">
      <view class="today-card-title">今天已完成</view>
      <view wx:if="{{todayCompletedTasks.length}}" class="today-card-count">{{todayCompletedTasks.length}}</view>
    </view>

    <block wx:if="{{todayCompletedTasks.length}}">
      <view wx:for="{{todayCompletedTasks}}" wx:key="id" class="today-item">
        <view class="today-item-check">✓</view>
        <view class="today-item-copy">
          <view class="today-item-title">{{item.title}}</view>
          <view wx:if="{{item.subtitle}}" class="today-item-meta">{{item.subtitle}}</view>
        </view>
      </view>
    </block>

    <view wx:else class="today-empty">今天还没有完成记录</view>
  </view>

  <view class="board-list">
    <view
      wx:for="{{sectionCards}}"
      wx:key="key"
      class="section-card tone-{{item.tone}}"
      data-section="{{item.key}}"
      bindtap="openSectionPopup"
    >
      <view class="section-aura"></view>
      <view class="section-copy">
        <view class="section-serial">{{item.serial}}</view>
        <view class="section-title">{{item.title}}</view>
        <view class="section-summary">{{item.summary}}</view>
      </view>

      <view class="section-side">
        <view class="section-count">{{item.count}} 项</view>
        <view class="section-arrow-shell">
          <view class="section-arrow">></view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{popupVisible}}" class="popup-mask" bindtap="closeSectionPopup">
    <view class="popup-sheet tone-{{popupTone}}" catchtap="noop">
      <view class="popup-handle"></view>

      <view class="popup-head">
        <view class="popup-head-copy">
          <view class="popup-title">{{popupTitle}}</view>
          <view class="popup-subtitle">{{popupSubtitle}}</view>
        </view>
        <view class="popup-close" bindtap="closeSectionPopup">x</view>
      </view>

      <view class="popup-list">
        <view
          wx:for="{{popupItems}}"
          wx:key="key"
          wx:for-index="idx"
          class="popup-item"
          data-action="{{item.key}}"
          bindtap="onSelectPopupItem"
        >
          <view class="popup-index">{{idx + 1 < 10 ? "0" + (idx + 1) : idx + 1}}</view>
          <view class="popup-copy">
            <view class="popup-item-title">{{item.title}}</view>
            <view class="popup-item-desc">{{item.desc}}</view>
          </view>
          <view class="popup-item-arrow">></view>
        </view>
      </view>
    </view>
  </view>
</view>

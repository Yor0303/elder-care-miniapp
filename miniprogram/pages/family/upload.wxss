.page {
  min-height: 100vh;
  background: var(--yz-bg-page);
}

.mode-switch {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-section);
}

.mode-pill {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--yz-text-secondary);
}

.mode-pill-active {
  background: var(--yz-bg-card);
  color: var(--yz-brand-primary);
  font-weight: 600;
}

.cell-trigger {
  display: block;
}

.picker-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 26rpx 32rpx;
  border-bottom: 1rpx solid var(--yz-border-soft);
  background: var(--yz-bg-card);
}

.picker-cell-label {
  font-size: 32rpx;
  color: var(--yz-text-primary);
}

.picker-cell-value-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.picker-cell-arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--yz-text-tertiary);
}

.uploader-cell,
.textarea-cell,
.video-cell {
  align-items: flex-start;
}

.form-input-control,
.form-textarea-control {
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--yz-text-primary);
  background: transparent;
}

.form-input-control {
  min-height: 48rpx;
  text-align: right;
}

.form-textarea-control {
  min-height: 180rpx;
  line-height: 1.7;
  padding-top: 10rpx;
}

.picker-text {
  display: block;
  max-width: 360rpx;
  text-align: right;
  word-break: break-word;
  color: var(--yz-text-primary);
}

.picker-placeholder {
  color: var(--yz-text-tertiary);
}

.field-helper {
  padding: 12rpx 32rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--yz-text-secondary);
  background: var(--yz-bg-card);
}

.video-row {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
  width: 100%;
}

.secondary-btn {
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  border: none;
  background: var(--yz-bg-section);
  color: var(--yz-text-primary);
  font-size: 26rpx;
}

.secondary-btn::after {
  border: none;
}

.video-copy {
  font-size: 24rpx;
  color: var(--yz-text-secondary);
}

.video-preview-card {
  margin: 24rpx 0 8rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-card);
}

.preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--yz-text-primary);
}

.preview-remove {
  font-size: 24rpx;
  color: var(--yz-danger);
}

.preview-video {
  width: 100%;
  margin-top: 18rpx;
  border-radius: 18rpx;
}

.page-tips {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.button-wrap {
  width: 100%;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--yz-radius-sm);
  border: none;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.65;
}

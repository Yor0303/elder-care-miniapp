/* pages/family/upload.wxss */
/* 页面整体 */
.page {
  padding: 40rpx;
  background-color: #F8F9FB;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面标题 */
.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1A3A5F;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 模式切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #666;
}
.tab.active {
  background: #4A90E2;
  color: #fff;
}

/* 上传按钮区域 */
.upload-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.upload-btn {
  flex: 1;
  flex-direction: column;
  padding: 40rpx 20rpx;
}

.upload-btn .icon {
  font-size: 60rpx;
  margin-right: 0;
  margin-bottom: 10rpx;
}

.upload-btn .text {
  font-size: 30rpx;
}

/* 预览区域 */
.preview-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  font-size: 28rpx;
  color: #666;
}

.remove-btn {
  color: #ff4d4f;
}

.preview-content {
  padding: 20rpx;
}

.preview-image {
  width: 100%;
  max-height: 420rpx;
  border-radius: 10rpx;
}

.preview-video {
  width: 100%;
  border-radius: 10rpx;
}

/* 表单区域 */
.form-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.form-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #F8F9FB;
  padding: 0 30rpx;
  border-radius: 15rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  background: #F8F9FB;
  padding: 25rpx 30rpx;
  border-radius: 15rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-picker .placeholder {
  color: #999;
}

.form-picker .arrow {
  color: #ccc;
  font-size: 36rpx;
}

.form-textarea {
  display: block;
  background: #F8F9FB;
  padding: 24rpx 30rpx;
  border-radius: 15rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #333;
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 100rpx;
  background: #4A90E2;
  color: #fff;
  font-size: 36rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn:active {
  background: #3A78C0;
}

.submit-btn.disabled {
  background: #ccc;
}

/* 配对上传 */
.pair-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}
.pair-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.pair-card {
  flex: 1;
  height: 420rpx;
  background: #F2F4F8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pair-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.pair-placeholder {
  color: #999;
  font-size: 28rpx;
}

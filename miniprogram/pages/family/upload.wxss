/* pages/family/upload.wxss */
/* 页面整体 */
.page {
  padding: 80rpx 40rpx;
  background-color: #F8F9FB;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面标题 */
.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1A3A5F;
  text-align: center;
  margin-bottom: 60rpx;
}

/* 上传卡片 */
.card {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

/* 点击反馈 */
.card:active {
  transform: scale(0.97);
  background: #F0F4F8;
}

/* 图标 */
.icon {
  font-size: 70rpx;
  margin-right: 20rpx;
}

/* 文字 */
.text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 预览区域 */
.preview {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.preview image {
  width: 100%;
  border-radius: 20rpx;
}

.preview video {
  width: 100%;
  border-radius: 20rpx;
}

/* 输入框 */
.input {
  background: #FFFFFF;
  padding: 30rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

/* 上传按钮 */
.btn {
  width: 100%;
  height: 100rpx;
  background: #4A90E2;
  color: #fff;
  font-size: 36rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 点击反馈 */
.btn:active {
  background: #3A78C0;
}
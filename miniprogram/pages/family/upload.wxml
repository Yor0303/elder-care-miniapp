<view class="page">
  <view class="title">🖼️ 上传回忆</view>

  <view class="tabs">
    <view class="tab {{mode==='single'?'active':''}}" bindtap="switchToSingle">📷 单图上传</view>
    <view class="tab {{mode==='pair'?'active':''}}" bindtap="switchToPair">🧩 配对上传</view>
  </view>

  <view wx:if="{{mode==='single'}}">
    <view class="upload-section">
      <view class="card upload-btn" bindtap="chooseImage">
        <view class="icon">🖼️</view>
        <view class="text">上传照片</view>
      </view>

      <view class="card upload-btn" bindtap="chooseVideo">
        <view class="icon">🎬</view>
        <view class="text">上传视频</view>
      </view>
    </view>

    <view class="preview-section" wx:if="{{fileUrl}}">
      <view class="preview-header">
        <text>已选择文件</text>
        <text class="remove-btn" bindtap="removeFile">删除</text>
      </view>
      <view class="preview-content">
        <image wx:if="{{mediaType === 'photo'}}" src="{{fileUrl}}" mode="aspectFit" class="preview-image"></image>
        <video wx:if="{{mediaType === 'video'}}" src="{{fileUrl}}" controls class="preview-video"></video>
      </view>
    </view>

    <view class="form-section">
      <view class="form-item">
        <view class="form-label">标题 *</view>
        <input
          class="form-input"
          placeholder="给这段回忆起个名字"
          value="{{title}}"
          bindinput="onTitleInput"
          maxlength="50"
        />
      </view>

      <view class="form-item">
        <view class="form-label">回忆内容 *</view>
        <textarea
          class="form-textarea"
          placeholder="写下这段回忆的故事..."
          value="{{story}}"
          bindinput="onStoryInput"
          maxlength="500"
        />
      </view>

      <view class="form-item" bindtap="showTypePicker">
        <view class="form-label">回忆类型</view>
        <view class="form-picker">
          <text class="{{memoryType ? '' : 'placeholder'}}">{{typeLabels[memoryType] || "请选择类型"}}</text>
          <text class="arrow">></text>
        </view>
      </view>

      <view class="form-row">
        <view class="form-item half">
          <view class="form-label">回忆日期 *</view>
          <picker mode="date" value="{{eventDate}}" bindchange="onDateChange">
            <view class="form-picker">
              <text class="{{eventDate ? '' : 'placeholder'}}">
                {{eventDate || "请选择日期"}}
              </text>
              <text class="arrow">></text>
            </view>
          </picker>
        </view>

        <view class="form-item half">
          <view class="form-label">相关人物</view>
          <picker
            mode="selector"
            range="{{personOptions}}"
            range-key="label"
            value="{{personIndex < 0 ? 0 : personIndex}}"
            bindchange="onPersonChange"
          >
            <view class="form-picker">
              <text class="{{personIndex < 0 ? 'placeholder' : ''}}">
                {{personIndex < 0 ? "请选择人物" : personOptions[personIndex].label}}
              </text>
              <text class="arrow">></text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <button
      class="submit-btn {{uploading ? 'disabled' : ''}}"
      bindtap="submitMemory"
      disabled="{{uploading}}"
    >
      {{uploading ? "保存中..." : "💾 保存回忆"}}
    </button>
  </view>

  <view wx:if="{{mode==='pair'}}">
    <view class="pair-section">
      <view class="pair-row">
        <view class="pair-card" bindtap="chooseLeftImage">
          <image wx:if="{{leftFileUrl}}" src="{{leftFileUrl}}" mode="aspectFill" class="pair-image"></image>
          <view wx:else class="pair-placeholder">🖼️ 选择左侧图片</view>
        </view>
        <view class="pair-card" bindtap="chooseRightImage">
          <image wx:if="{{rightFileUrl}}" src="{{rightFileUrl}}" mode="aspectFill" class="pair-image"></image>
          <view wx:else class="pair-placeholder">🖼️ 选择右侧图片</view>
        </view>
      </view>

      <view class="form-row">
        <view class="form-item half">
          <view class="form-label">左侧名称</view>
          <input class="form-input" placeholder="如：王大爷" value="{{leftLabel}}" bindinput="onLeftLabelInput" />
        </view>
        <view class="form-item half">
          <view class="form-label">右侧名称</view>
          <input class="form-input" placeholder="如：王大妈" value="{{rightLabel}}" bindinput="onRightLabelInput" />
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">提示/描述（可选）</view>
        <textarea class="form-textarea" placeholder="给这对卡片写点提示..." value="{{notes}}" bindinput="onNotesInput" maxlength="200" />
      </view>
    </view>

    <button
      class="submit-btn {{pairUploading ? 'disabled' : ''}}"
      bindtap="submitPair"
      disabled="{{pairUploading}}"
    >
      {{pairUploading ? "保存中..." : "🧩 保存配对"}}
    </button>
  </view>

  <view class="picker-mask" wx:if="{{showTypePicker}}" bindtap="hideTypePicker">
    <view class="picker-content" catchtap="noop">
      <view class="picker-title">选择回忆类型</view>
      <view class="picker-list">
        <view
          wx:for="{{typeOptions}}"
          wx:key="*this"
          class="picker-item {{memoryType === item ? 'active' : ''}}"
          bindtap="onTypeSelect"
          data-type="{{item}}"
        >
          {{typeLabels[item]}}
        </view>
      </view>
    </view>
  </view>
</view>

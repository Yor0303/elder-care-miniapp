<!-- pages/family/upload.wxml -->
<view class="page">

<view class="title">上传新的回忆</view>

<!-- 选择照片/视频 -->
<view class="upload-section">
  <view class="card upload-btn" bindtap="chooseImage">
    <view class="icon">图</view>
    <view class="text">上传照片</view>
  </view>

  <view class="card upload-btn" bindtap="chooseVideo">
    <view class="icon">影</view>
    <view class="text">上传视频</view>
  </view>
</view>

<!-- 预览已选文件 -->
<view class="preview-section" wx:if="{{fileUrl}}">
  <view class="preview-header">
    <text>已选择文件</text>
    <text class="remove-btn" bindtap="removeFile">删除</text>
  </view>
  <view class="preview-content">
    <image wx:if="{{type=='photo'}}" src="{{fileUrl}}" mode="aspectFit" class="preview-image"></image>
    <video wx:if="{{type=='video'}}" src="{{fileUrl}}" controls class="preview-video"></video>
  </view>
</view>

<!-- 表单输入 -->
<view class="form-section">
  <view class="form-item">
    <view class="form-label">标题 *</view>
    <input
      class="form-input"
      placeholder="给这段回忆起个名字"
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="50"
    />
  </view>

  <view class="form-item">
    <view class="form-label">回忆故事 *</view>
    <textarea
      class="form-textarea"
      placeholder="写下这段回忆的故事..."
      value="{{story}}"
      bindinput="onStoryInput"
      maxlength="500"
    />
  </view>

  <view class="form-row">
    <view class="form-item half">
      <view class="form-label">年份</view>
      <input
        class="form-input"
        type="number"
        placeholder="如 2020"
        value="{{year}}"
        bindinput="onYearChange"
      />
    </view>

    <view class="form-item half">
      <view class="form-label">相关人物</view>
      <picker
        mode="selector"
        range="{{personOptions}}"
        value="{{personIndex < 0 ? 0 : personIndex}}"
        bindchange="onPersonChange"
      >
        <view class="form-picker">
          <text class="{{personIndex < 0 ? 'placeholder' : ''}}">
            {{personIndex < 0 ? "请选择人物" : personOptions[personIndex]}}
          </text>
          <text class="arrow">></text>
        </view>
      </picker>
    </view>
  </view>
</view>

<!-- 提交按钮 -->
<button
  class="submit-btn {{uploading ? 'disabled' : ''}}"
  bindtap="submitMemory"
  disabled="{{uploading}}"
>
  {{uploading ? "上传中..." : "保存回忆"}}
</button>

</view>

.page {
  min-height: 100vh;
  background: var(--yz-bg-page);
}

.loading-shell {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-trigger {
  display: block;
}

.uploader-cell,
.textarea-cell {
  align-items: flex-start;
}

.form-input-control,
.form-textarea-control {
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--yz-text-primary);
  background: transparent;
}

.form-input-control {
  min-height: 48rpx;
  text-align: right;
}

.form-textarea-control {
  min-height: 180rpx;
  line-height: 1.7;
  padding-top: 10rpx;
}

.picker-text {
  color: var(--yz-text-primary);
}

.picker-placeholder {
  color: var(--yz-text-tertiary);
}

.page-tips {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.button-wrap {
  width: 100%;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--yz-radius-sm);
  border: none;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.65;
}

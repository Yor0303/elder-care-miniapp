/* pages/family/profile.wxss */
.page {
  padding: 32rpx;
  background: #F8F9FB;
  min-height: 100vh;
}

.loading {
  text-align: center;
  color: #888;
  font-size: 30rpx;
  margin-top: 40rpx;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5F;
  margin-bottom: 20rpx;
}

.avatar-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
  background: #f2f2f2;
}

.avatar-btn {
  font-size: 28rpx;
  color: #4A90E2;
  border: 1rpx solid #4A90E2;
  border-radius: 18rpx;
  padding: 8rpx 20rpx;
  background: #fff;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #F8F9FB;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  display: block;
  background: #F8F9FB;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item.half {
  flex: 1;
}

.form-picker {
  background: #F8F9FB;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.form-picker .placeholder {
  color: #999;
}

.form-picker .arrow {
  color: #ccc;
  font-size: 34rpx;
}

.save-btn {
  width: 100%;
  height: 100rpx;
  background: #4A90E2;
  color: #fff;
  font-size: 34rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn[disabled] {
  background: #ccc;
}

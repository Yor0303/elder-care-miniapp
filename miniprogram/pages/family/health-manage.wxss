.page {
  min-height: 100vh;
  padding: 40rpx;
  background: #f8f9fb;
  box-sizing: border-box;
}

.title {
  margin-bottom: 36rpx;
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  color: #1a3a5f;
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading {
  font-size: 30rpx;
  color: #999;
}

.section {
  margin-bottom: 36rpx;
}

.hero-section,
.trend-card,
.record-card,
.empty-tip,
.alert-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.hero-section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7c8b9a;
  line-height: 1.6;
}

.add-btn {
  padding: 12rpx 22rpx;
  font-size: 26rpx;
  color: #4a90e2;
  border: 1rpx solid #4a90e2;
  border-radius: 999rpx;
  background: #fff;
  white-space: nowrap;
}

.add-btn.primary {
  background: #4a90e2;
  color: #fff;
}

.health-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.overview-card {
  width: calc((100% - 36rpx) / 3);
  background: #f5f8fc;
  border-radius: 22rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.overview-label {
  font-size: 26rpx;
  color: #7c8b9a;
}

.overview-value {
  margin-top: 16rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.overview-unit {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #98a5b3;
}

.status-pill {
  display: inline-block;
  margin-top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-normal {
  background: #e9f7ef;
  color: #268a53;
}

.status-high {
  background: #fff1f0;
  color: #d95c54;
}

.status-low {
  background: #eef5ff;
  color: #4a79c8;
}

.latest-note {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #7c8b9a;
}

.alert-card {
  padding: 24rpx 26rpx;
  margin-bottom: 16rpx;
}

.alert-high {
  border-left: 8rpx solid #ff8b7b;
}

.alert-low {
  border-left: 8rpx solid #7ca8ff;
}

.alert-text {
  font-size: 28rpx;
  color: #4f5f73;
  line-height: 1.6;
}

.trend-card {
  padding: 20rpx 24rpx;
}

.trend-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f6;
}

.trend-row:last-child {
  border-bottom: none;
}

.trend-date {
  width: 84rpx;
  font-size: 24rpx;
  color: #7c8b9a;
}

.trend-bars {
  flex: 1;
}

.trend-bar-track {
  width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  background: #eef3f8;
  overflow: hidden;
}

.trend-bar-track + .trend-bar-track {
  margin-top: 10rpx;
}

.single-track {
  height: 18rpx;
}

.trend-bar {
  height: 100%;
  border-radius: 999rpx;
}

.trend-bar-primary {
  background: linear-gradient(90deg, #ff8b7b 0%, #ffb06b 100%);
}

.trend-bar-secondary {
  background: linear-gradient(90deg, #7ca8ff 0%, #8fd3ff 100%);
}

.trend-bar-accent {
  background: linear-gradient(90deg, #4a90e2 0%, #7fd4c1 100%);
}

.trend-value {
  width: 120rpx;
  text-align: right;
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.record-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.record-meta {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.record-notes {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b97a7;
  line-height: 1.6;
}

.delete-btn {
  padding: 10rpx 18rpx;
  font-size: 24rpx;
  color: #ff6b6b;
  border-radius: 999rpx;
  background: #fff2f2;
}

.empty-tip {
  padding: 36rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.45);
}

.modal-content {
  width: 100%;
  max-width: 680rpx;
  padding: 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-sizing: border-box;
}

.modal-title {
  margin-bottom: 28rpx;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  color: #1a3a5f;
}

.modal-item {
  margin-bottom: 22rpx;
}

.modal-label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.modal-input,
.modal-picker {
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: #f8f9fb;
  border-radius: 15rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.modal-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
}

.modal-btn.cancel {
  background: #f1f3f6;
  color: #666;
}

.modal-btn.confirm {
  background: #4a90e2;
  color: #fff;
}

.page {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(180deg, #faf6ef 0%, #f7f2ea 34%, #f7f5f1 100%);
}

.title {
  margin-bottom: 40rpx;
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  color: #4e3a28;
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading {
  font-size: 30rpx;
  color: #7b8ba1;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #7f6347;
}

.tip {
  font-size: 24rpx;
  color: #8b9bb0;
}

.overview-card,
.chart-card,
.data-card,
.empty-tip {
  margin-bottom: 20rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(25, 61, 108, 0.07);
}

.overview-card {
  display: flex;
  gap: 24rpx;
  background: linear-gradient(135deg, #fff9f1 0%, #f6efe2 100%);
}

.overview-main {
  flex: 1;
}

.overview-label {
  font-size: 28rpx;
  color: #5d7ca8;
}

.overview-value {
  margin-top: 12rpx;
  font-size: 60rpx;
  font-weight: 700;
  color: #7d5a34;
}

.overview-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7d8ca4;
}

.overview-side {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
  width: 220rpx;
}

.mini-metric {
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff;
}

.mini-metric-label {
  display: block;
  font-size: 24rpx;
  color: #7d8ca4;
}

.mini-metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #6b563d;
}

.chart-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #22395e;
}

.chart-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7d8ca4;
}

.chart-current {
  font-size: 40rpx;
  font-weight: 700;
  color: #377be7;
}

.chart-empty,
.empty-tip {
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
  color: #95a3b7;
}

.pressure-track,
.bar-track {
  width: 100%;
  white-space: nowrap;
}

.pressure-items,
.bar-list {
  display: inline-flex;
  align-items: flex-end;
  gap: 28rpx;
  min-width: 100%;
  padding: 8rpx 8rpx 12rpx;
}

.pressure-item,
.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 116rpx;
}

.pressure-value,
.bar-value {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #5a6f8d;
}

.pressure-sticks {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  height: 280rpx;
}

.pressure-stick {
  width: 24rpx;
  min-height: 16rpx;
  border-radius: 999rpx;
  transform-origin: bottom center;
  box-shadow: 0 10rpx 18rpx rgba(55, 123, 231, 0.16);
}

.pressure-stick.systolic {
  background: linear-gradient(180deg, #5a9bff 0%, #3979cf 100%);
}

.pressure-stick.diastolic {
  background: linear-gradient(180deg, #80d7cb 0%, #41b9a5 100%);
}

.pressure-label,
.bar-label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8d9bb0;
}

.bar-column {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 72rpx;
  height: 280rpx;
  padding: 6rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #f2f6fd 0%, #edf3fb 100%);
}

.bar-fill {
  width: 100%;
  min-height: 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #6fa9ff 0%, #377be7 100%);
  transform-origin: bottom center;
  box-shadow: inset 0 10rpx 18rpx rgba(255, 255, 255, 0.28), 0 12rpx 22rpx rgba(55, 123, 231, 0.14);
}

.animate-rise {
  animation: rise-up 700ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

@keyframes rise-up {
  0% {
    opacity: 0.25;
    transform: scaleY(0.08);
  }

  65% {
    opacity: 1;
    transform: scaleY(1.04);
  }

  100% {
    opacity: 1;
    transform: scaleY(1);
  }
}

.data-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.data-label {
  font-size: 32rpx;
  color: #333;
}

.data-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.edit-icon {
  font-size: 26rpx;
  color: #4a90e2;
}

.add-btn {
  padding: 12rpx 22rpx;
  font-size: 26rpx;
  color: #4a90e2;
  border: 1rpx solid #4a90e2;
  border-radius: 999rpx;
  background: #fff;
}

.record-card {
  align-items: flex-start;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.record-meta {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.record-notes {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #999;
}

.record-tag {
  display: inline-block;
  margin-top: 10rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #2f7c59;
  border-radius: 999rpx;
  background: #ecfbf4;
}

.delete-btn {
  margin-left: 20rpx;
  padding: 10rpx 18rpx;
  font-size: 26rpx;
  color: #ff4d4f;
  border-radius: 999rpx;
  background: #fff5f5;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.45);
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  padding: 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.16);
}

.modal-title {
  margin-bottom: 30rpx;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  color: #1a3a5f;
}

.modal-item {
  margin-bottom: 24rpx;
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 8rpx 0;
}

.switch-copy {
  flex: 1;
}

.switch-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #22395e;
}

.switch-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #8a97ab;
}

.modal-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  background: #f8f9fb;
  border-radius: 15rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 20rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #4a90e2;
  color: #fff;
}

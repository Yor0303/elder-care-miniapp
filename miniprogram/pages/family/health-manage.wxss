/* pages/family/health-manage.wxss */
.page {
  min-height: 100vh;
  padding: 40rpx;
  background: #f8f9fb;
}

.title {
  margin-bottom: 40rpx;
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  color: #1a3a5f;
  letter-spacing: 1rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading {
  font-size: 30rpx;
  color: #999;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #4a90e2;
}

.tip {
  font-size: 24rpx;
  color: #999;
}

.add-btn {
  padding: 12rpx 22rpx;
  font-size: 26rpx;
  color: #4a90e2;
  border: 1rpx solid #4a90e2;
  border-radius: 999rpx;
  background: #fff;
}

.card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.label {
  font-size: 32rpx;
  color: #333;
}

.value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.edit-icon {
  font-size: 26rpx;
  color: #4a90e2;
}

.record-card {
  align-items: flex-start;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.record-meta {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.record-notes {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.delete-btn {
  margin-left: 20rpx;
  padding: 10rpx 18rpx;
  font-size: 26rpx;
  color: #ff4d4f;
  border-radius: 999rpx;
  background: #fff5f5;
}

.empty-tip {
  padding: 40rpx 0;
  font-size: 28rpx;
  text-align: center;
  color: #999;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.45);
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  padding: 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.16);
  box-sizing: border-box;
}

.modal-title {
  margin-bottom: 30rpx;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  color: #1a3a5f;
}

.modal-item {
  margin-bottom: 24rpx;
}

.modal-label {
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.modal-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  background: #f8f9fb;
  border-radius: 15rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 20rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #4a90e2;
  color: #fff;
}

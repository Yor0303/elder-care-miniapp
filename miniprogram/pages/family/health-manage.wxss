/* pages/family/health-manage.wxss */
.page {
  padding: 40rpx;
  background: #F8F9FB;
  min-height: 100vh;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading {
  font-size: 30rpx;
  color: #999;
}

/* 区块 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #4A90E2;
}

.tip {
  font-size: 24rpx;
  color: #999;
}

.add-btn {
  font-size: 28rpx;
  color: #4A90E2;
  padding: 10rpx 20rpx;
  border: 1rpx solid #4A90E2;
  border-radius: 20rpx;
}

/* 卡片 */
.card {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.label {
  font-size: 32rpx;
  color: #333;
}

.value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A3A5F;
}

.edit-icon {
  font-size: 28rpx;
  opacity: 0.6;
}

/* 记录卡片 */
.record-card {
  align-items: flex-start;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.record-meta {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

.record-notes {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.delete-btn {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 10rpx 20rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 40rpx 0;
  background: #fff;
  border-radius: 20rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-item {
  margin-bottom: 25rpx;
}

.modal-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.modal-input {
  background: #F8F9FB;
  padding: 25rpx;
  border-radius: 15rpx;
  font-size: 30rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #4A90E2;
  color: #fff;
}

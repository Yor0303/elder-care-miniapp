.page {
  min-height: 100vh;
  padding: 40rpx;
  background: var(--yz-bg-page);
}

.title {
  margin-bottom: 40rpx;
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  color: var(--yz-text-primary);
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.tip {
  font-size: 24rpx;
  color: var(--yz-text-tertiary);
}

.overview-card,
.chart-card,
.data-card,
.empty-tip {
  margin-bottom: 20rpx;
  padding: 32rpx;
  background: var(--yz-bg-card);
  border-radius: 20rpx;
  box-shadow: var(--yz-shadow-soft);
}

.overview-card {
  display: flex;
  gap: 24rpx;
  background: var(--yz-accent-warm-soft);
}

.overview-main {
  flex: 1;
}

.overview-label {
  font-size: 28rpx;
  color: var(--yz-brand-primary);
}

.overview-value {
  margin-top: 12rpx;
  font-size: 60rpx;
  font-weight: 700;
  color: var(--yz-accent-warm);
}

.overview-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--yz-text-secondary);
}

.overview-side {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
  width: 220rpx;
}

.mini-metric {
  padding: 18rpx;
  border-radius: 20rpx;
  background: var(--yz-bg-card);
}

.mini-metric-label {
  display: block;
  font-size: 24rpx;
  color: var(--yz-text-secondary);
}

.mini-metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.chart-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.chart-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--yz-text-secondary);
}

.chart-current {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--yz-brand-primary);
}

.chart-empty,
.empty-tip {
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
  color: var(--yz-text-tertiary);
}

.pressure-track,
.bar-track {
  width: 100%;
  white-space: nowrap;
}

.pressure-items,
.bar-list {
  display: inline-flex;
  align-items: flex-end;
  gap: 28rpx;
  min-width: 100%;
  padding: 8rpx 8rpx 12rpx;
}

.pressure-item,
.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 116rpx;
}

.pressure-value,
.bar-value {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--yz-brand-primary);
}

.pressure-sticks {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  height: 280rpx;
}

.pressure-stick {
  width: 24rpx;
  min-height: 16rpx;
  border-radius: 0;
  transform-origin: bottom center;
  box-shadow: 0 10rpx 18rpx rgba(111, 143, 200, 0.16);
}

.pressure-stick.systolic {
  background: #78c3a7;
}

.pressure-stick.diastolic {
  background: #f4c97c;
}

.pressure-label,
.bar-label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--yz-text-tertiary);
}

.bar-column {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 72rpx;
  height: 280rpx;
  padding: 6rpx;
  border-radius: 0;
  background: var(--yz-bg-card-soft);
}

.bar-fill {
  width: 100%;
  min-height: 18rpx;
  border-radius: 0;
  background: var(--yz-brand-primary);
  transform-origin: bottom center;
  box-shadow: inset 0 10rpx 18rpx rgba(255, 255, 255, 0.28), 0 12rpx 22rpx rgba(111, 143, 200, 0.14);
}

.animate-rise {
  animation: rise-up 700ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

@keyframes rise-up {
  0% {
    opacity: 0.25;
    transform: scaleY(0.08);
  }

  65% {
    opacity: 1;
    transform: scaleY(1.04);
  }

  100% {
    opacity: 1;
    transform: scaleY(1);
  }
}

.data-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.data-label {
  font-size: 32rpx;
  color: var(--yz-text-primary);
}

.data-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.edit-icon {
  font-size: 26rpx;
  color: var(--yz-brand-primary);
}

.add-btn {
  padding: 12rpx 22rpx;
  font-size: 26rpx;
  color: var(--yz-brand-primary);
  border: 1rpx solid var(--yz-brand-primary);
  border-radius: 24rpx;
  background: var(--yz-bg-card);
}

.record-card {
  align-items: flex-start;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-left: 20rpx;
}

.record-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.record-meta {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: var(--yz-text-secondary);
}

.record-notes {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--yz-text-tertiary);
}

.record-tag {
  display: inline-block;
  margin-top: 10rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: var(--yz-success);
  border-radius: 24rpx;
  background: var(--yz-success-soft);
}

.delete-btn {
  padding: 10rpx 18rpx;
  font-size: 26rpx;
  color: var(--yz-danger);
  border-radius: 24rpx;
  background: var(--yz-danger-soft);
}

.edit-btn {
  padding: 10rpx 18rpx;
  font-size: 26rpx;
  color: var(--yz-brand-primary);
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
}

.dialog-body {
  max-height: 70vh;
  overflow-y: auto;
  text-align: left;
}

.modal-item {
  margin-bottom: 24rpx;
}

.modal-item:last-child {
  margin-bottom: 0;
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 8rpx 0;
}

.switch-copy {
  flex: 1;
}

.switch-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.switch-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--yz-text-tertiary);
}

.modal-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--yz-text-primary);
  background: var(--yz-bg-card-soft);
  border-radius: 15rpx;
  box-sizing: border-box;
}

.picker-field {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--yz-text-primary);
  background: var(--yz-bg-card-soft);
  border-radius: 15rpx;
  box-sizing: border-box;
}

.schedule-label {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: var(--yz-text-secondary);
}

.schedule-options,
.weekday-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.schedule-chip,
.weekday-chip {
  padding: 14rpx 20rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-section);
  color: var(--yz-text-secondary);
  font-size: 26rpx;
  line-height: 1;
}

.schedule-chip-active,
.weekday-chip-active {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

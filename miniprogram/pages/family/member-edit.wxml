<view class="page">
  <view class="title">{{isEdit ? "✏️ 编辑成员" : "➕ 新增成员"}}</view>

  <view class="form">
    <view class="form-item">
      <view class="form-label">展示照片</view>
      <view class="avatar-section">
        <view wx:if="{{avatar}}" class="avatar-preview">
          <image class="avatar-image" src="{{avatar}}" mode="aspectFill"></image>
          <view class="remove-avatar" catchtap="removeAvatar">X</view>
        </view>
        <view wx:else class="avatar-upload" bindtap="chooseAvatar">
          <text class="avatar-plus">+</text>
          <text class="avatar-text">🖼️ 上传照片</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">识别人脸照</view>
      <view class="field-tip">建议上传清晰正脸照，便于摄像头识别时命中。</view>
      <view class="avatar-section">
        <view wx:if="{{facePhoto}}" class="avatar-preview">
          <image class="avatar-image" src="{{facePhoto}}" mode="aspectFill"></image>
          <view class="remove-avatar" catchtap="removeFacePhoto">X</view>
        </view>
        <view wx:else class="avatar-upload" bindtap="chooseFacePhoto">
          <text class="avatar-plus">+</text>
          <text class="avatar-text">📸 上传人脸照</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">姓名 *</view>
      <input class="form-input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item" bindtap="showRelationPicker">
      <view class="form-label">家庭关系</view>
      <view class="form-picker">
        <text class="{{relation ? '' : 'placeholder'}}">{{relation || "请选择关系"}}</text>
        <text class="arrow">></text>
      </view>
    </view>

    <view class="form-item" bindtap="showGenderPicker">
      <view class="form-label">性别</view>
      <view class="form-picker">
        <text class="{{gender ? '' : 'placeholder'}}">{{gender || "请选择性别"}}</text>
        <text class="arrow">></text>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">年龄</view>
      <input class="form-input" type="number" placeholder="请输入年龄" value="{{age}}" bindinput="onAgeInput" />
    </view>

    <view class="form-item">
      <view class="form-label">健康状况</view>
      <input class="form-input" placeholder="如：良好、一般" value="{{health}}" bindinput="onHealthInput" />
    </view>

    <view class="form-item">
      <view class="form-label">简介</view>
      <textarea class="form-textarea" placeholder="简单介绍一下这位家人..." value="{{description}}" bindinput="onDescriptionInput" />
    </view>
  </view>

  <button class="save-btn" bindtap="save" disabled="{{saving}}">
    {{saving ? "保存中..." : "💾 保存"}}
  </button>

  <button wx:if="{{isEdit}}" class="delete-btn" bindtap="delete">🗑️ 删除成员</button>

  <view class="picker-mask" wx:if="{{showRelationPicker}}" bindtap="hideRelationPicker">
    <view class="picker-content" catchtap="noop">
      <view class="picker-title">选择关系</view>
      <scroll-view scroll-y class="picker-list">
        <view
          wx:for="{{relationOptions}}"
          wx:key="*this"
          class="picker-item {{relation === item ? 'active' : ''}}"
          bindtap="onRelationChange"
          data-index="{{index}}"
        >
          {{item}}
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="picker-mask" wx:if="{{showGenderPicker}}" bindtap="hideGenderPicker">
    <view class="picker-content" catchtap="noop">
      <view class="picker-title">选择性别</view>
      <view class="picker-list">
        <view
          wx:for="{{genderOptions}}"
          wx:key="*this"
          class="picker-item {{gender === item ? 'active' : ''}}"
          bindtap="onGenderChange"
          data-index="{{index}}"
        >
          {{item}}
        </view>
      </view>
    </view>
  </view>
</view>

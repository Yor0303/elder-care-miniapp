<view class="page">
  <view class="title">👨‍👩‍👧 家庭成员</view>

  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading">加载中...</view>
  </view>

  <view wx:else>
    <view class="member-list" wx:if="{{members.length > 0}}">
      <view wx:for="{{members}}" wx:key="id" class="member-card">
        <image
          wx:if="{{item.avatar}}"
          class="avatar"
          src="{{item.avatar}}"
          mode="aspectFill"
        ></image>
        <view wx:else class="avatar avatar-placeholder">🙂</view>

        <view class="info">
          <view class="name">{{item.name || "未命名成员"}}</view>
          <view class="meta">
            <text class="relation">{{item.relation || "关系未填"}}</text>
            <text class="age" wx:if="{{item.age}}">{{item.age}}岁</text>
          </view>
          <view wx:if="{{item.description}}" class="desc">{{item.description}}</view>
        </view>

        <view class="edit-btn" catchtap="editMember" data-id="{{item.id}}">✏️ 编辑</view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-icon">👪</view>
      <view class="empty-text">暂无家庭成员</view>
    </view>

    <view class="add-member-btn" bindtap="addMember">
      <text class="add-icon">＋</text>
      <text>添加家庭成员</text>
    </view>
  </view>
</view>

<!--pages/family/members.wxml-->
<view class="page">

<view class="title">家庭成员</view>

<!-- 加载状态 -->
<view wx:if="{{loading}}" class="loading-container">
  <view class="loading">加载中...</view>
</view>

<view wx:else>

<!-- 成员列表 -->
<view class="member-list">
  <view
    wx:for="{{members}}"
    wx:key="id"
    class="member-card"
  >
    <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
    <view class="info">
      <view class="name">{{item.name}}</view>
      <view class="meta">
        <text class="relation">{{item.relation}}</text>
        <text class="age" wx:if="{{item.age}}">{{item.age}}岁</text>
      </view>
      <view wx:if="{{item.description}}" class="desc">{{item.description}}</view>
    </view>
    <view class="edit-btn" catchtap="editMember" data-id="{{item.id}}">编辑</view>
  </view>
</view>

<!-- 空状态 -->
<view wx:if="{{members.length === 0}}" class="empty-state">
  <view class="empty-icon">👨‍👩‍👧‍👦</view>
  <view class="empty-text">暂无家庭成员</view>
</view>

<!-- 添加按钮 -->
<view class="add-member-btn" bindtap="addMember">
  <text class="add-icon">+</text>
  <text>添加家庭成员</text>
</view>

</view>

</view>

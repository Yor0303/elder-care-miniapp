.container {
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(132, 189, 255, 0.18), transparent 26%),
    linear-gradient(180deg, #f7fafc 0%, #edf3f7 100%);
}

.bind-shell,
.inline-card,
.state-card,
.pending-item {
  border-radius: 28rpx;
  box-shadow: 0 14rpx 36rpx rgba(20, 38, 63, 0.08);
}

.bind-shell {
  min-height: 100vh;
  padding: 34rpx 28rpx 40rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 0;
  box-shadow: none;
}

.shell-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.shell-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.shell-subtitle,
.panel-subtitle,
.pending-meta,
.person-meta,
.empty-inline,
.state-card {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #6f8092;
}

.shell-badge,
.status-pill,
.pending-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.shell-badge,
.status-pill,
.pending-badge.pending {
  background: #eaf3ff;
  color: #2563eb;
}

.status-pill.success,
.pending-badge.approved {
  background: #effaf3;
  color: #276749;
}

.pending-badge.rejected {
  background: #fff1f0;
  color: #d14343;
}

.mode-tabs {
  display: flex;
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.demo-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  margin-bottom: 22rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2458c0;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.demo-btn::after {
  border: none;
}

.mode-chip {
  flex: 1;
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f5f8;
  color: #6d7c8c;
  font-size: 28rpx;
  font-weight: 700;
}

.mode-chip.active {
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
}

.inline-card {
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  background: #f8fbfd;
  border: 2rpx solid #e4edf6;
}

.action-area {
  margin-bottom: 22rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.compact-head {
  margin-bottom: 14rpx;
}

.panel-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.panel-title.center,
.panel-subtitle.center {
  text-align: center;
}

.person-summary {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.strong-summary {
  margin-bottom: 18rpx;
}

.person-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  background: #eef4ff;
  flex-shrink: 0;
}

.person-avatar.accent {
  background: #fff1e4;
}

.person-main {
  flex: 1;
  min-width: 0;
}

.person-name,
.pending-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.person-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scan-card {
  text-align: center;
  background: linear-gradient(145deg, #f8fbff 0%, #ffffff 72%);
}

.scan-visual {
  width: 170rpx;
  height: 170rpx;
  margin: 16rpx auto 26rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  background: linear-gradient(145deg, #2557ba 0%, #1e6cde 100%);
  color: #fff;
  box-shadow: 0 16rpx 30rpx rgba(34, 97, 201, 0.22);
}

.phone-input {
  background: #ffffff;
  border: 2rpx solid #dbe5f0;
  border-radius: 24rpx;
  height: 100rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #1f2a37;
  box-sizing: border-box;
}

.picker-card {
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e2eaf3;
  margin-bottom: 18rpx;
}

.picker-label {
  font-size: 25rpx;
  font-weight: 700;
  color: #4d5d70;
}

.relation-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  margin-top: 8rpx;
  font-size: 29rpx;
  color: #1f2a37;
}

.placeholder,
.arrow {
  color: #98a2b3;
}

.primary-btn,
.secondary-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
}

.secondary-btn {
  margin-top: 18rpx;
  background: #eef4ff;
  color: #2458c0;
}

.large-btn {
  margin-top: 4rpx;
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.state-card {
  padding: 22rpx 24rpx;
  text-align: center;
  background: #ffffff;
  border: 2rpx solid #e2eaf3;
}

.state-card.success {
  background: #effaf3;
  color: #276749;
  border-color: #c8ead3;
}

.pending-card {
  margin-bottom: 0;
}

.pending-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 22rpx;
  margin-top: 14rpx;
  background: #ffffff;
  border: 2rpx solid #e3ebf3;
}

.pending-main {
  flex: 1;
  min-width: 0;
}

.empty-inline {
  padding: 12rpx 4rpx 2rpx;
}

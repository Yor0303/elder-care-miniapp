.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 227, 170, 0.5), transparent 32%),
    linear-gradient(180deg, #f8f4ea 0%, #f2f7f5 42%, #eef3f6 100%);
}

.hero-card,
.card,
.pending-item,
.state-card {
  border-radius: 32rpx;
  box-shadow: 0 14rpx 36rpx rgba(39, 53, 66, 0.08);
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 22rpx;
  background:
    radial-gradient(circle at top right, rgba(132, 191, 163, 0.2), transparent 28%),
    linear-gradient(135deg, #fff1cf 0%, #fffaf1 58%, #f1fbf7 100%);
}

.hero-top,
.section-row,
.pending-item,
.relation-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-top {
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.hero-badge,
.status-pill,
.pending-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.hero-badge {
  background: rgba(255, 255, 255, 0.88);
  color: #8d5b1a;
  font-weight: 700;
}

.demo-link {
  margin: 0;
  padding: 0 22rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #46645b;
  font-size: 24rpx;
  border: none;
}

.demo-link::after,
.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2a33;
}

.hero-desc,
.section-note,
.person-meta,
.pending-meta,
.empty-inline,
.state-card,
.action-desc {
  font-size: 25rpx;
  line-height: 1.7;
  color: #70808d;
}

.hero-desc {
  margin-top: 10rpx;
}

.card {
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  background: rgba(255, 255, 255, 0.96);
}

.bound-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 250, 247, 0.96) 100%);
}

.section-row {
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.section-row-tight {
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2a33;
}

.section-note {
  margin-top: 6rpx;
}

.status-pill {
  background: #edf4ef;
  color: #356b57;
}

.status-pill.success,
.pending-badge.approved {
  background: #e7f5ec;
  color: #2f7a54;
}

.pending-badge.pending {
  background: #eef3f7;
  color: #476277;
}

.pending-badge.rejected {
  background: #fff1ef;
  color: #c35649;
}

.person-summary {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: #f7faf8;
}

.person-summary-strong {
  margin-bottom: 18rpx;
}

.person-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f3ec;
  color: #356b57;
  font-size: 24rpx;
  font-weight: 700;
}

.person-avatar.accent {
  background: #fff3da;
  color: #a5641f;
}

.person-main {
  flex: 1;
  min-width: 0;
}

.person-name,
.pending-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2a33;
}

.person-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
}

.secondary-btn,
.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #2c7b63 0%, #20624e 100%);
  color: #ffffff;
}

.secondary-btn,
.soft-btn {
  background: #eef4f1;
  color: #2d6b57;
}

.mode-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.mode-chip {
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f5f4;
  color: #667784;
  font-size: 28rpx;
  font-weight: 700;
}

.mode-chip.active {
  background: #e3f0ea;
  color: #245e4d;
}

.action-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f8fbfa;
  border: 2rpx solid #e7efea;
}

.scan-card {
  text-align: center;
  background: linear-gradient(180deg, #f7fbf6 0%, #ffffff 100%);
}

.action-mark {
  width: 132rpx;
  height: 132rpx;
  margin: 4rpx auto 18rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2d7a63 0%, #3d9277 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.action-title,
.field-label,
.picker-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #24313a;
}

.action-title {
  margin-bottom: 8rpx;
}

.phone-input {
  height: 92rpx;
  margin-top: 16rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #dce7e1;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #1f2a33;
}

.result-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 240, 0.96) 100%);
}

.picker-block {
  padding: 20rpx 22rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e7ece8;
}

.relation-picker {
  min-height: 74rpx;
  margin-top: 8rpx;
  font-size: 29rpx;
  color: #1f2a33;
}

.placeholder,
.arrow {
  color: #98a3aa;
}

.state-card {
  padding: 22rpx 24rpx;
  margin-top: 14rpx;
  border: 2rpx solid #e3ebe6;
  background: #ffffff;
  text-align: center;
}

.state-card.success {
  background: #ebf8ef;
  border-color: #cde8d6;
  color: #2f7a54;
}

.pending-item {
  padding: 22rpx 20rpx;
  margin-top: 14rpx;
  background: #f9fbfa;
}

.pending-main {
  flex: 1;
  min-width: 0;
}

.empty-inline {
  padding: 18rpx 6rpx 4rpx;
}

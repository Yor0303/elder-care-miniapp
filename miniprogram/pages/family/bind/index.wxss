.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.hero-card,
.card,
.pending-item,
.state-card {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 22rpx;
  background: var(--yz-gradient-hero);
}

.hero-top,
.section-row,
.pending-item,
.relation-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-top {
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.hero-badge,
.status-pill,
.pending-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.hero-badge {
  background: rgba(255, 255, 255, 0.88);
  color: var(--yz-accent-warm);
  font-weight: 700;
}

.demo-link {
  margin: 0;
  padding: 0 22rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  color: var(--yz-brand-primary);
  font-size: 24rpx;
  border: none;
}

.demo-link::after,
.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.hero-desc,
.section-note,
.person-meta,
.pending-meta,
.empty-inline,
.state-card,
.action-desc {
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.hero-desc {
  margin-top: 10rpx;
}

.card {
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  background: rgba(255, 255, 255, 0.96);
}

.bound-card {
  background: rgba(255, 255, 255, 0.96);
}

.section-row {
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.section-row-tight {
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.section-note {
  margin-top: 6rpx;
}

.status-pill {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

.status-pill.success,
.pending-badge.approved {
  background: var(--yz-success-soft);
  color: var(--yz-success);
}

.pending-badge.pending {
  background: var(--yz-info-soft);
  color: var(--yz-info);
}

.pending-badge.rejected {
  background: var(--yz-danger-soft);
  color: var(--yz-danger);
}

.person-summary {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: var(--yz-bg-card-soft);
}

.person-summary-strong {
  margin-bottom: 18rpx;
}

.person-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.person-avatar.accent {
  background: var(--yz-accent-warm-soft);
  color: var(--yz-accent-warm);
}

.person-main {
  flex: 1;
  min-width: 0;
}

.person-name,
.pending-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.person-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
}

.secondary-btn,
.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 18rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.primary-btn {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}

.secondary-btn,
.soft-btn {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

.mode-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.mode-chip {
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yz-bg-section);
  color: var(--yz-text-secondary);
  font-size: 28rpx;
  font-weight: 700;
}

.mode-chip.active {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary-pressed);
}

.action-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: var(--yz-bg-card-soft);
  border: 2rpx solid var(--yz-border-soft);
}

.scan-card {
  text-align: center;
  background: var(--yz-bg-card-soft);
}

.action-mark {
  width: 132rpx;
  height: 132rpx;
  margin: 4rpx auto 18rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 30rpx;
  font-weight: 700;
}

.action-title,
.field-label,
.picker-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.action-title {
  margin-bottom: 8rpx;
}

.phone-input {
  height: 92rpx;
  margin-top: 16rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-card);
  border: 2rpx solid var(--yz-border);
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--yz-text-primary);
}

.result-card {
  background: var(--yz-accent-warm-soft);
}

.picker-block {
  padding: 20rpx 22rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-card);
  border: 2rpx solid var(--yz-border-soft);
}

.relation-picker {
  min-height: 74rpx;
  margin-top: 8rpx;
  font-size: 29rpx;
  color: var(--yz-text-primary);
}

.loading-state {
  display: flex;
  justify-content: center;
}

.placeholder,
.arrow {
  color: var(--yz-text-tertiary);
}

.state-card {
  padding: 22rpx 24rpx;
  margin-top: 14rpx;
  border: 2rpx solid var(--yz-border-soft);
  background: var(--yz-bg-card);
  text-align: center;
}

.state-card.success {
  background: var(--yz-success-soft);
  border-color: var(--yz-brand-primary-border);
  color: var(--yz-success);
}

.pending-item {
  padding: 22rpx 20rpx;
  margin-top: 14rpx;
  background: var(--yz-bg-card-soft);
}

.pending-main {
  flex: 1;
  min-width: 0;
}

.empty-inline {
  padding: 18rpx 6rpx 4rpx;
}

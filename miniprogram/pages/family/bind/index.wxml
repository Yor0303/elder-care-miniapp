<view class="page">

  <view wx:if="{{currentBoundElder}}" class="card bound-card">
    <view class="section-row">
      <view>
        <view class="section-title">当前已绑定</view>
      </view>
      <view class="status-pill success">已绑定</view>
    </view>

    <view class="person-summary">
      <view class="person-avatar">长者</view>
      <view class="person-main">
        <view class="person-name">{{currentBoundElder.name || "未命名老人"}}</view>
        <view class="person-meta">
          <text wx:if="{{currentBoundElder.gender}}">{{currentBoundElder.gender}}</text>
          <text wx:if="{{currentBoundElder.age}}">{{currentBoundElder.age}} 岁</text>
          <text wx:if="{{currentBoundElder.phone}}">{{currentBoundElder.phone}}</text>
        </view>
      </view>
    </view>

    <button class="secondary-btn" bindtap="enterFamilyHome">进入家属首页</button>
  </view>

  <view class="card">
    <view class="section-row section-row-tight">
      <view>
        <view class="section-title">选择绑定方式</view>
        <view class="section-note">如需更换绑定，直接重新发起即可</view>
      </view>
    </view>

    <view class="mode-tabs">
      <view class="mode-chip {{mode === 'scan' ? 'active' : ''}}" data-mode="scan" bindtap="setMode">扫码</view>
      <view class="mode-chip {{mode === 'phone' ? 'active' : ''}}" data-mode="phone" bindtap="setMode">手机号</view>
      <view class="mode-chip {{mode === 'invite' ? 'active' : ''}}" data-mode="invite" bindtap="setMode">邀请链接</view>
    </view>

    <view wx:if="{{mode === 'scan'}}" class="action-card scan-card">
      <view class="action-mark">扫码</view>
      <view class="action-title">扫描老人端二维码</view>
      <view class="action-desc">面对面绑定更快</view>
      <button class="primary-btn" bindtap="scanBindCode">立即扫码</button>
    </view>

    <view wx:if="{{mode === 'phone'}}" class="action-card">
      <view class="field-label">老人绑定手机号</view>
      <input
        class="phone-input"
        type="number"
        maxlength="11"
        placeholder="请输入老人手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
      <button class="primary-btn soft-btn" bindtap="lookupByPhone" loading="{{loading}}">查找老人</button>
    </view>

    <view wx:if="{{mode === 'invite'}}" class="action-card">
      <view class="action-title">通过邀请链接进入</view>
      <view wx:if="{{loading && requestSource === 'share'}}" class="state-card">正在读取邀请信息</view>
      <view wx:elif="{{!loading && !sharedElder}}" class="state-card">暂无可用邀请信息</view>
    </view>
  </view>

  <view wx:if="{{sharedElder}}" class="card result-card">
    <view class="section-row">
      <view>
        <view class="section-title">确认老人信息</view>
        <view class="section-note">确认无误后提交申请</view>
      </view>
      <view class="status-pill">
        {{requestSource === 'phone' ? '手机号' : requestSource === 'scan' ? '扫码' : '邀请'}}
      </view>
    </view>

    <view class="person-summary person-summary-strong">
      <view class="person-avatar accent">匹配</view>
      <view class="person-main">
        <view class="person-name">{{sharedElder.name}}</view>
        <view class="person-meta">
          <text wx:if="{{sharedElder.gender}}">{{sharedElder.gender}}</text>
          <text wx:if="{{sharedElder.age}}">{{sharedElder.age}} 岁</text>
          <text wx:if="{{sharedElder.maskedPhone}}">{{sharedElder.maskedPhone}}</text>
        </view>
      </view>
    </view>

    <view class="picker-block">
      <view class="picker-label">你与老人的关系</view>
      <picker mode="selector" range="{{relationOptions}}" value="{{relationIndex < 0 ? 0 : relationIndex}}" bindchange="onRelationChange">
        <view class="relation-picker">
          <text class="{{relation ? '' : 'placeholder'}}">{{relation || "请选择关系"}}</text>
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <button wx:if="{{!requestSent}}" class="primary-btn" bindtap="submitInviteRequest">提交绑定申请</button>
    <view wx:else class="state-card success">申请已提交，等待老人确认</view>
  </view>

  <view class="card">
    <view class="section-row section-row-tight">
      <view class="section-title">我的申请</view>
    </view>

    <block wx:if="{{pendingRequests.length}}">
      <view wx:for="{{pendingRequests}}" wx:key="id" class="pending-item">
        <view class="pending-main">
          <view class="pending-name">{{item.elderName}}</view>
          <view class="pending-meta">{{item.relation}} · {{item.statusText}}</view>
        </view>
        <view class="pending-badge {{item.statusClass}}">{{item.statusText}}</view>
      </view>
    </block>

    <view wx:else class="empty-inline">暂无申请记录</view>
  </view>
</view>

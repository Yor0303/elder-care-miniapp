<view class="page">
  <view wx:if="{{loading}}" class="loading-shell">
    <mp-loading type="circle" tips="加载资料中"></mp-loading>
  </view>

  <mp-form-page wx:else title="老人资料" subtitle="整理清楚基础信息，方便家属查找、绑定和后续照护。">
    <mp-form>
      <mp-cells title="头像">
        <mp-cell ext-class="uploader-cell" has-footer="{{false}}">
          <mp-uploader
            title="老人头像"
            tips="建议上传清晰正面照，便于识别和家属确认。"
            files="{{avatarFiles}}"
            max-count="1"
            select="{{selectAvatarFile}}"
            upload="{{uploadAvatarFile}}"
            bindsuccess="onAvatarUploadSuccess"
            bindfail="onAvatarUploadFail"
            binddelete="onAvatarDelete"
          ></mp-uploader>
        </mp-cell>
      </mp-cells>

      <mp-cells title="基本信息">
        <mp-cell title="姓名" has-footer="{{false}}">
          <input class="form-input-control" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
        </mp-cell>

        <mp-cell title="绑定手机号" has-footer="{{false}}">
          <input class="form-input-control" type="number" maxlength="11" placeholder="用于家属查找绑定" value="{{phone}}" bindinput="onPhoneInput" />
        </mp-cell>

        <view class="cell-trigger picker-cell" bindtap="openGenderSheet">
          <view class="picker-cell-label">性别</view>
          <view class="picker-cell-value-wrap">
            <view class="picker-text {{gender ? '' : 'picker-placeholder'}}">
              {{gender || "请选择性别"}}
            </view>
            <view class="picker-cell-arrow">></view>
          </view>
        </view>

        <mp-cell title="年龄" has-footer="{{false}}">
          <input class="form-input-control" type="number" placeholder="如 76" value="{{age}}" bindinput="onAgeInput" />
        </mp-cell>

        <mp-cell title="出生年份" has-footer="{{false}}">
          <input class="form-input-control" type="number" placeholder="如 1948" value="{{birthYear}}" bindinput="onBirthYearInput" />
        </mp-cell>

        <mp-cell title="籍贯" has-footer="{{false}}">
          <input class="form-input-control" placeholder="如 上海" value="{{hometown}}" bindinput="onHometownInput" />
        </mp-cell>

        <mp-cell title="常住地址" has-footer="{{false}}">
          <input class="form-input-control" placeholder="请输入地址" value="{{address}}" bindinput="onAddressInput" />
        </mp-cell>
      </mp-cells>

      <mp-cells title="紧急联系人">
        <mp-cell title="联系人姓名" has-footer="{{false}}">
          <input class="form-input-control" placeholder="请输入联系人姓名" value="{{emergencyContactName}}" bindinput="onEmergencyContactNameInput" />
        </mp-cell>

        <mp-cell title="联系人电话" has-footer="{{false}}">
          <input class="form-input-control" type="number" maxlength="11" placeholder="请输入电话号码" value="{{emergencyContactPhone}}" bindinput="onEmergencyContactPhoneInput" />
        </mp-cell>
      </mp-cells>

      <mp-cells title="健康备注">
        <mp-cell title="过敏史" has-footer="{{false}}">
          <input class="form-input-control" placeholder="如 青霉素过敏" value="{{allergies}}" bindinput="onAllergiesInput" />
        </mp-cell>

        <mp-cell title="常用药" has-footer="{{false}}">
          <input class="form-input-control" placeholder="如 降压药" value="{{medications}}" bindinput="onMedicationsInput" />
        </mp-cell>

        <mp-cell title="补充备注" inline="{{false}}" has-footer="{{false}}" ext-class="textarea-cell">
          <textarea class="form-textarea-control" placeholder="补充说明老人需要特别注意的事情..." value="{{notes}}" bindinput="onNotesInput" maxlength="300" />
        </mp-cell>
      </mp-cells>
    </mp-form>

    <view slot="tips" class="page-tips">手机号和紧急联系人建议保持最新，方便家属和照护者及时联系。</view>

    <view slot="button" class="button-wrap">
      <button class="submit-btn" bindtap="save" loading="{{saving}}" disabled="{{saving}}">保存资料</button>
    </view>
  </mp-form-page>

  <mp-actionSheet
    show="{{showGenderSheet}}"
    title="选择性别"
    actions="{{genderActionItems}}"
    bindclose="closeGenderSheet"
    bindactiontap="onGenderActionTap"
  ></mp-actionSheet>
</view>

.page {
  min-height: 100vh;
  background: var(--yz-bg-page);
}

.loading-shell {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-trigger {
  display: block;
}

.picker-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 26rpx 32rpx;
  border-bottom: 1rpx solid var(--yz-border-soft);
  background: var(--yz-bg-card);
}

.picker-cell-label {
  font-size: 32rpx;
  color: var(--yz-text-primary);
}

.picker-cell-value-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.picker-cell-arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--yz-text-tertiary);
}

.uploader-cell,
.textarea-cell {
  align-items: flex-start;
}

.form-input-control,
.form-textarea-control {
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;
  color: var(--yz-text-primary);
  background: transparent;
}

.form-input-control {
  min-height: 48rpx;
  text-align: right;
}

.form-textarea-control {
  min-height: 180rpx;
  line-height: 1.7;
  padding-top: 10rpx;
}

.picker-text {
  display: block;
  max-width: 360rpx;
  text-align: right;
  word-break: break-word;
  color: var(--yz-text-primary);
}

.picker-placeholder {
  color: var(--yz-text-tertiary);
}

.page-tips {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.button-group {
  width: 100%;
}

.submit-btn,
.delete-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--yz-radius-sm);
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.submit-btn {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}

.delete-btn {
  margin-top: 20rpx;
  background: var(--yz-danger-soft);
  color: var(--yz-danger);
}

.submit-btn::after,
.delete-btn::after {
  border: none;
}

.submit-btn[disabled],
.delete-btn[disabled] {
  opacity: 0.65;
}

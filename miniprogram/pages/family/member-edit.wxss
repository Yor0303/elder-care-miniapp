/* pages/family/member-edit.wxss */
.page {
  padding: 40rpx;
  background: #F8F9FB;
  min-height: 100vh;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40rpx;
  color: #1a3a5f;
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 40rpx;
}

.form-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.avatar-section {
  margin-top: 8rpx;
}

.avatar-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  background: #f2f2f2;
}

.remove-avatar {
  position: absolute;
  top: -14rpx;
  right: -14rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff4d4f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.avatar-upload {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d8dfe8;
  border-radius: 20rpx;
  background: #f8f9fb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.avatar-plus {
  font-size: 60rpx;
  line-height: 1;
}

.avatar-text {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.form-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333;
  background: #F8F9FB;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.form-textarea {
  display: block;
  width: 100%;
  padding: 24rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #333;
  height: 150rpx;
  background: #F8F9FB;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  background: #F8F9FB;
  border-radius: 16rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.form-picker .placeholder {
  color: #999;
}

.form-picker .arrow {
  color: #ccc;
  font-size: 36rpx;
}

.save-btn {
  width: 100%;
  height: 100rpx;
  background: #4A90E2;
  color: #fff;
  font-size: 34rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn[disabled] {
  background: #ccc;
}

.delete-btn {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 34rpx;
  border-radius: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #ff4d4f;
}

/* 选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.picker-content {
  width: 100%;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 70vh;
}

.picker-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-list {
  max-height: 60vh;
}

.picker-item {
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-item.active {
  color: #4A90E2;
  background: #f0f7ff;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.header {
  margin-bottom: 22rpx;
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  background: var(--yz-gradient-hero);
  box-shadow: var(--yz-shadow-soft);
}

.welcome {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.subtitle {
  font-size: 25rpx;
  color: var(--yz-text-secondary);
  margin-top: 10rpx;
  line-height: 1.6;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  padding: 30rpx 28rpx;
  margin-bottom: 22rpx;
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.card-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 25rpx;
  color: var(--yz-text-secondary);
  line-height: 1.6;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  border: none;
  font-weight: 700;
}

.primary-btn::after,
.secondary-btn::after,
.danger-btn::after {
  border: none;
}

.primary-btn {
  min-width: 188rpx;
  padding: 0 28rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}

.secondary-btn {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

.danger-btn {
  background: var(--yz-danger-soft);
  color: var(--yz-danger);
}

.empty-state {
  padding: 50rpx 0 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--yz-text-secondary);
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 56rpx 0 28rpx;
}

.guide-list {
  margin-top: 30rpx;
}

.guide-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: var(--yz-bg-card-soft);
  border: 2rpx solid var(--yz-border-soft);
  margin-bottom: 20rpx;
}

.guide-item:last-child {
  margin-bottom: 0;
}

.guide-cover {
  width: 100%;
  height: 280rpx;
  border-radius: 22rpx;
  background: var(--yz-info-soft);
}

.guide-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--yz-text-tertiary);
  font-size: 26rpx;
}

.guide-main {
  margin-top: 20rpx;
}

.guide-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.guide-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.guide-time {
  font-size: 22rpx;
  color: var(--yz-text-tertiary);
}

.guide-name {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--yz-brand-primary);
  font-weight: 700;
}

.guide-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--yz-text-secondary);
  line-height: 1.7;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.guide-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.guide-tag {
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 22rpx;
}

.guide-tag-video {
  background: var(--yz-warning-soft);
  color: var(--yz-warning);
}

.guide-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
}

.page {
  padding: 40rpx;
  background: #f8f9fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 50rpx;
}

.welcome {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a3a5f;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  margin-top: 15rpx;
  line-height: 1.6;
}

.card {
  background: #ffffff;
  padding: 35rpx 40rpx;
  margin-bottom: 25rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-left {
  display: flex;
  align-items: center;
}

.icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 39rpx;
  font-size: 26rpx;
  border: none;
}

.primary-btn {
  min-width: 180rpx;
  padding: 0 28rpx;
  background: #4a90e2;
  color: #fff;
}

.secondary-btn {
  background: #eef5ff;
  color: #4a90e2;
}

.danger-btn {
  background: #fff1f0;
  color: #d95c54;
}

.empty-state {
  padding: 50rpx 0 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.guide-list {
  margin-top: 30rpx;
}

.guide-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8f9fb;
  margin-bottom: 20rpx;
}

.guide-item:last-child {
  margin-bottom: 0;
}

.guide-cover {
  width: 100%;
  height: 280rpx;
  border-radius: 18rpx;
  background: #eef2f6;
}

.guide-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.guide-main {
  margin-top: 20rpx;
}

.guide-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.guide-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.guide-time {
  font-size: 22rpx;
  color: #aaa;
}

.guide-name {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #4a90e2;
}

.guide-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.guide-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.guide-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #4a90e2;
  font-size: 22rpx;
}

.guide-tag-video {
  background: #fff7e8;
  color: #d48806;
}

.guide-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
}

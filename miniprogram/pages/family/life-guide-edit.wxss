.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.header {
  margin-bottom: 22rpx;
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  background: var(--yz-gradient-hero);
  box-shadow: var(--yz-shadow-soft);
}

.welcome {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: var(--yz-text-secondary);
  line-height: 1.6;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
  padding: 30rpx 28rpx;
}

.loading-card {
  display: flex;
  justify-content: center;
  padding-top: 52rpx;
  padding-bottom: 52rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.label {
  font-size: 28rpx;
  color: var(--yz-text-primary);
  font-weight: 700;
  margin-bottom: 14rpx;
}

.helper-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--yz-text-secondary);
  line-height: 1.6;
}

.input,
.textarea {
  width: 100%;
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
  border: 2rpx solid var(--yz-border-soft);
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--yz-text-primary);
}

.input {
  display: block;
  height: 92rpx;
  line-height: 92rpx;
  padding: 0 24rpx;
}

.textarea {
  padding: 24rpx;
  min-height: 220rpx;
  line-height: 1.7;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step-card {
  background: var(--yz-bg-card-soft);
  border-radius: 24rpx;
  border: 2rpx solid var(--yz-border-soft);
  padding: 24rpx;
}

.step-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.step-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.remove-btn {
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.upload-box {
  width: 100%;
  height: 260rpx;
  background: var(--yz-bg-card);
  border-radius: 20rpx;
  border: 2rpx dashed var(--yz-brand-primary-border);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  font-size: 28rpx;
  color: var(--yz-text-secondary);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.step-textarea {
  margin-top: 18rpx;
  background: var(--yz-bg-card);
  border: 2rpx solid var(--yz-border-soft);
  min-height: 180rpx;
}

.video-panel {
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
  border: 2rpx solid var(--yz-border-soft);
  padding: 20rpx;
}

.preview-video {
  width: 100%;
  border-radius: 16rpx;
}

.primary-btn,
.secondary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 700;
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.primary-btn {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}

.secondary-btn {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

.add-step-btn,
.upload-btn,
.submit-btn {
  margin-top: 16rpx;
}

.small-btn {
  margin-top: 18rpx;
}

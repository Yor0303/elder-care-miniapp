.page {
  padding: 40rpx;
  background: #f8f9fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.welcome {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a3a5f;
}

.subtitle {
  margin-top: 15rpx;
  font-size: 28rpx;
  color: #888;
  line-height: 1.6;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 36rpx 34rpx;
}

.loading-card {
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.form-item {
  margin-bottom: 28rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.helper-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b97a7;
  line-height: 1.6;
}

.input,
.textarea {
  width: 100%;
  background: #f8f9fb;
  border-radius: 18rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.textarea {
  min-height: 220rpx;
  line-height: 1.7;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step-card {
  background: #f8f9fb;
  border-radius: 20rpx;
  padding: 24rpx;
}

.step-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.remove-btn {
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.upload-box {
  width: 100%;
  height: 260rpx;
  background: #fff;
  border-radius: 18rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  font-size: 28rpx;
  color: #999;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.step-textarea {
  margin-top: 18rpx;
  background: #fff;
  min-height: 180rpx;
}

.video-panel {
  background: #f8f9fb;
  border-radius: 18rpx;
  padding: 20rpx;
}

.preview-video {
  width: 100%;
  border-radius: 16rpx;
}

.primary-btn,
.secondary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  border: none;
}

.primary-btn {
  background: #4a90e2;
  color: #fff;
}

.secondary-btn {
  background: #eef5ff;
  color: #4a90e2;
}

.add-step-btn,
.upload-btn,
.submit-btn {
  margin-top: 16rpx;
}

.small-btn {
  margin-top: 18rpx;
}

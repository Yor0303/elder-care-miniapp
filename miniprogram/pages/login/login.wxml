<view class="page">
  <view class="nav-bar">
    <view wx:if="{{showBack}}" class="back-button" bindtap="goBack">
      <app-icon name="chevron-left" size="40rpx" color="#111111"></app-icon>
    </view>
  </view>

  <view class="brand-zone">
    <view class="brand-mark">
      <image
        class="brand-logo"
        src="https://ftp.mioz.cn/test/2026/04/13/1776081115.JPG"
        mode="aspectFit"
      ></image>
    </view>
    <view class="brand-title">{{copy.welcomeTitle}}</view>
    <view class="brand-subtitle">
      {{inviteElderId ? copy.subtitleInvite : copy.subtitleDefault}}
    </view>
  </view>

  <view class="action-zone">
    <view class="role-panel">
      <view class="role-header">
        <text class="role-title">{{copy.roleTitle}}</text>
        <text wx:if="{{inviteElderId}}" class="role-tip">{{copy.roleInviteTip}}</text>
      </view>

      <view class="role-switch">
        <view class="role-slider {{selectedRole === 'family' ? 'is-family' : ''}}"></view>
        <view
          class="role-option {{selectedRole === 'elder' ? 'active' : ''}}"
          data-role="elder"
          bindtap="selectRole"
        >
          <text class="role-option-text">{{copy.roleElder}}</text>
        </view>

        <view
          class="role-option {{selectedRole === 'family' ? 'active' : ''}}"
          data-role="family"
          bindtap="selectRole"
        >
          <text class="role-option-text">{{copy.roleFamily}}</text>
        </view>
      </view>

      <view class="role-caption">
        {{selectedRole === 'elder' ? copy.roleElderDesc : copy.roleFamilyDesc}}
      </view>
    </view>

    <view wx:if="{{!existingAccountChecked}}" class="helper-text account-checking">
      {{copy.checkingAccount}}
    </view>

    <block wx:elif="{{authMode}}">
      <view class="auth-panel">
        <view class="auth-panel-title">{{copy.authPanelTitle}}</view>
        <view class="auth-panel-desc">
          {{existingAccountRole ? (existingAccountRole === selectedRole ? copy.authExistingDesc : copy.authConflictDesc) : copy.authPanelDesc}}
        </view>

        <block wx:if="{{!existingAccountRole}}">
          <view class="auth-field auth-avatar-field">
            <text class="auth-label">{{copy.avatarLabel}}</text>
            <button
              class="avatar-picker"
              open-type="chooseAvatar"
              bindchooseavatar="handleChooseAvatar"
            >
              <image
                wx:if="{{avatar}}"
                class="avatar-image"
                src="{{avatar}}"
                mode="aspectFill"
              ></image>
              <view wx:else class="avatar-placeholder">{{copy.avatarAction}}</view>
            </button>
          </view>

          <view class="auth-field">
            <text class="auth-label">{{copy.nicknameLabel}}</text>
            <input
              class="nickname-input"
              type="nickname"
              maxlength="20"
              placeholder="{{copy.nicknamePlaceholder}}"
              value="{{nickname}}"
              bindinput="handleNicknameInput"
            />
          </view>
        </block>

        <button
          class="primary-btn auth-submit-btn"
          loading="{{loading}}"
          disabled="{{loading || (!agreed && !(existingAccountRole && existingAccountRole === selectedRole))}}"
          bindtap="handleManualRegister"
        >
          {{existingAccountRole ? (existingAccountRole === selectedRole ? copy.authPrimaryLogin : copy.authPrimarySwitch) : copy.authPrimary}}
        </button>

        <view class="helper-text auth-helper">
          {{existingAccountRole ? '' : copy.authHelper}}
        </view>
      </view>
    </block>

    <button
      wx:else
      class="primary-btn"
      loading="{{loading}}"
      disabled="{{loading}}"
      bindtap="handlePrimaryAction"
    >
      {{copy.previewPrimary}}
    </button>

    <button
      wx:if="{{existingAccountChecked && !existingAccountRole}}"
      class="secondary-btn"
      disabled="{{loading}}"
      bindtap="handleSecondaryAction"
    >
      {{authMode ? copy.switchToPreview : copy.switchToAuth}}
    </button>

    <view wx:if="{{existingAccountChecked && !authMode && !existingAccountRole}}" class="helper-text">
      {{authMode ? copy.authHelper : copy.previewHelper}}
    </view>
  </view>

  <view class="agreement-section">
    <view wx:if="{{existingAccountChecked && authMode}}" class="agreement-row" bindtap="toggleAgreement">
      <view class="agreement-check {{agreed ? 'checked' : ''}}">
        <app-icon wx:if="{{agreed}}" name="check" size="18rpx" color="#ffffff"></app-icon>
      </view>
      <view class="agreement-copy">
        {{copy.agreementPrefix}}
        <text class="agreement-link" catchtap="openAgreement">{{copy.agreementUser}}</text>
        {{copy.agreementJoiner}}
        <text class="agreement-link" catchtap="openPrivacy">{{copy.agreementPrivacy}}</text>
      </view>
    </view>

    <view class="footer-links">
      <text class="footer-link">{{copy.footerService}}</text>
      <text class="footer-link">{{copy.footerHelp}}</text>
      <text class="footer-link">{{copy.footerAbout}}</text>
    </view>
  </view>
</view>

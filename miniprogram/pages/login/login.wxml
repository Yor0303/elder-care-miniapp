<view class="page">
  <view class="logo">忆站</view>
  <view class="subtitle">帮助记住家人与回忆</view>

  <view wx:if="{{inviteElderId}}" class="invite-tip">
    家人向你发来了绑定邀请，登录家属端后可直接完成绑定
  </view>

  <view class="illustration">👨‍👩‍👧</view>

  <view class="card elder" bindtap="enterElder">
    <view class="icon">👴</view>
    <view class="info">
      <view class="title">我是老人</view>
      <view class="desc">查看家人与重要回忆</view>
    </view>
  </view>

  <view class="card family" bindtap="enterFamily">
    <view class="icon">👨‍👩‍👧</view>
    <view class="info">
      <view class="title">我是家属</view>
      <view class="desc">上传照片与重要记忆</view>
    </view>
  </view>
</view>

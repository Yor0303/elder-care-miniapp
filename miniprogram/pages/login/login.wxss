/* 页面容器：使用柔和背景，减少视觉疲劳 */
.page {
  padding: 80rpx 40rpx;
  background-color: #F8F9FB;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 品牌区：采用稳重的配色 */
.logo {
  font-size: 72rpx;
  font-weight: bold;
  color: #1A3A5F;
  text-align: center;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
}

.invite-tip {
  background: #eef6ff;
  border: 2rpx solid #b8d9ff;
  color: #1a3a5f;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.illustration {
  font-size: 120rpx;
  text-align: center;
  margin-bottom: 80rpx;
}

/* 核心卡片样式：大触控热区，适老化关键 */
.card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.card:active {
  transform: scale(0.97); /* 点击反馈，增强老人操作信心 */
  background: #F0F4F8;
}

.icon {
  font-size: 80rpx;
  margin-right: 40rpx;
}

/* 文字层级：确保清晰可读 */
.title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 30rpx;
  color: #888;
}

/* 老人端高亮区分 */
.elder {
  border: 4rpx solid #4A90E2;
}

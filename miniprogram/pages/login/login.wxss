.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 56rpx 32rpx 64rpx;
  background:
    radial-gradient(circle at top, rgba(246, 222, 190, 0.45), transparent 34%),
    linear-gradient(180deg, #f8f2e8 0%, #f3ece1 50%, #efe6d7 100%);
  color: #5a4331;
}

.hero {
  padding: 28rpx 12rpx 32rpx;
}

.brand {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #7c5639;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #4f3727;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #806657;
}

.invite-banner {
  margin-top: 12rpx;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 247, 232, 0.92);
  border: 2rpx solid rgba(165, 127, 86, 0.18);
}

.invite-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #6b4d35;
}

.invite-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #886d5c;
}

.panel {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 251, 245, 0.95);
  box-shadow: 0 22rpx 48rpx rgba(124, 86, 57, 0.08);
}

.mode-switch {
  display: flex;
  gap: 16rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: #f1e6d8;
}

.mode-chip {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #8a6d5a;
}

.mode-chip.active {
  background: #7c5639;
  color: #fffaf5;
  font-weight: 600;
}

.section-head {
  margin-top: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #523a29;
}

.section-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #8a6d5a;
}

.role-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.role-card {
  flex: 1;
  min-height: 260rpx;
  padding: 30rpx 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e8d7c4;
  background: #fffaf3;
  box-sizing: border-box;
}

.role-card.selected {
  border-color: #7c5639;
  background: #f7ecdc;
  box-shadow: 0 12rpx 28rpx rgba(124, 86, 57, 0.12);
}

.role-icon {
  font-size: 60rpx;
}

.role-title {
  margin-top: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #523a29;
}

.role-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #896b57;
}

.primary-btn {
  margin-top: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #8e6544 0%, #6d4b34 100%);
  color: #fffaf5;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-btn::after {
  border: none;
}

.registered-tip {
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #f7ecdc;
  color: #6e503c;
  font-size: 28rpx;
}

.switch-tip {
  margin-top: 26rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8a6d5a;
}

.switch-link {
  margin-left: 10rpx;
  color: #6d4b34;
  font-weight: 600;
}

page {
  background: var(--yz-bg-page);
  color: var(--yz-text-primary);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 42rpx 72rpx;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
}

.back-button {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-zone {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 20rpx;
}

.brand-logo {
  width: 420rpx;
  height: 420rpx;
}

.brand-title {
  margin-top: 28rpx;
  font-size: 46rpx;
  font-weight: 600;
  color: var(--yz-text-primary);
}

.brand-subtitle {
  margin-top: 18rpx;
  max-width: 520rpx;
  text-align: center;
  color: var(--yz-text-secondary);
  font-size: 28rpx;
  line-height: 1.7;
}

.action-zone {
  margin-top: auto;
}

.role-panel {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--yz-bg-card);
  box-shadow: var(--yz-shadow-soft);
}

.role-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.role-title {
  font-size: 28rpx;
  color: var(--yz-text-primary);
  font-weight: 600;
}

.role-tip {
  font-size: 22rpx;
  color: #07c060;
}

.role-switch {
  position: relative;
  display: flex;
  align-items: center;
  padding: 8rpx;
  border-radius: 999rpx;
  background: var(--yz-bg-card-soft);
  overflow: hidden;
}

.role-slider {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: calc(50% - 8rpx);
  height: calc(100% - 16rpx);
  border-radius: 999rpx;
  background: var(--yz-bg-card);
  box-shadow: 0 12rpx 28rpx rgba(33, 32, 33, 0.1);
  transition: transform 0.24s ease;
}

.role-slider.is-family {
  transform: translateX(100%);
}

.role-option {
  position: relative;
  z-index: 1;
  flex: 1;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.role-option-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--yz-text-secondary);
  transition: color 0.24s ease;
}

.role-option.active .role-option-text {
  color: var(--yz-text-primary);
}

.role-caption {
  margin-top: 22rpx;
  text-align: center;
  color: var(--yz-text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.primary-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 20rpx;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 96rpx;
  margin: 0;
}

.primary-btn::after {
  border: none;
}

.primary-btn {
  color: #ffffff;
  background: #07c060;
  box-shadow: 0 14rpx 28rpx rgba(7, 192, 96, 0.22);
}

.helper-text {
  text-align: center;
  margin-top: 28rpx;
  color: var(--yz-text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.agreement-section {
  padding-top: 88rpx;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  color: var(--yz-text-secondary);
  font-size: 27rpx;
  line-height: 1.8;
}

.agreement-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid var(--yz-border);
  margin-right: 18rpx;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.agreement-check.checked {
  border-color: #07c060;
  background: #07c060;
}

.agreement-copy {
  flex: 1;
}

.agreement-link {
  color: #07c060;
}

.footer-links {
  margin-top: 60rpx;
  display: flex;
  justify-content: center;
}

.footer-link + .footer-link {
  margin-left: 48rpx;
}

.footer-link {
  color: var(--yz-text-secondary);
  font-size: 28rpx;
}

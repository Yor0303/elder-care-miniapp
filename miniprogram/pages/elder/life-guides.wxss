.page {
  min-height: 100vh;
  padding: 40rpx;
  background: var(--yz-bg-page);
  box-sizing: border-box;
}

.header-card,
.empty-card,
.guide-card {
  background: var(--yz-bg-card);
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.header-card {
  padding: 34rpx 32rpx;
  margin-bottom: 28rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.subtitle {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--yz-text-secondary);
}

.empty-card {
  padding: 60rpx 30rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--yz-text-tertiary);
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-card {
  overflow: hidden;
}

.guide-cover {
  width: 100%;
  height: 320rpx;
  background: var(--yz-bg-section);
}

.guide-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--yz-text-tertiary);
  font-size: 28rpx;
}

.guide-info {
  padding: 26rpx 28rpx 30rpx;
}

.guide-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--yz-text-primary);
}

.guide-name {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--yz-brand-primary);
}

.guide-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.guide-tag {
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 22rpx;
}

.guide-tag-video {
  background: var(--yz-warning-soft);
  color: var(--yz-warning);
}

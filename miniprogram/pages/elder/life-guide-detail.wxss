.page {
  min-height: 100vh;
  padding: 40rpx;
  background: #f8f9fb;
  box-sizing: border-box;
}

.empty-card,
.guide-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.empty-card {
  padding: 60rpx 30rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
}

.guide-card {
  overflow: hidden;
}

.content-wrap {
  padding: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.item-name {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #4a90e2;
}

.section {
  margin-top: 30rpx;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step-card {
  background: #f8f9fb;
  border-radius: 20rpx;
  padding: 22rpx;
}

.step-index {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #4a90e2;
}

.step-image {
  width: 100%;
  height: 320rpx;
  border-radius: 18rpx;
  background: #eef2f6;
}

.step-text {
  margin-top: 18rpx;
  font-size: 30rpx;
  color: #4f5f73;
  line-height: 1.8;
}

.guide-video {
  width: 100%;
  border-radius: 20rpx;
}

.empty-tip {
  padding: 36rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  background: #f8f9fb;
  border-radius: 20rpx;
}

.page {
  min-height: 100vh;
  padding: 40rpx;
  background: var(--yz-bg-page);
  box-sizing: border-box;
}

.empty-card,
.guide-card {
  background: var(--yz-bg-card);
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.empty-card {
  padding: 60rpx 30rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--yz-text-tertiary);
}

.guide-card {
  overflow: hidden;
}

.content-wrap {
  padding: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.item-name {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--yz-brand-primary);
}

.section {
  margin-top: 30rpx;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--yz-text-primary);
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step-card {
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
  padding: 22rpx;
}

.step-index {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--yz-brand-primary);
}

.step-image {
  width: 100%;
  height: 320rpx;
  border-radius: 18rpx;
  background: var(--yz-bg-section);
}

.step-text {
  margin-top: 18rpx;
  font-size: 30rpx;
  color: var(--yz-info);
  line-height: 1.8;
}

.guide-video {
  width: 100%;
  border-radius: 20rpx;
}

.empty-tip {
  padding: 36rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--yz-text-tertiary);
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
}

<view class="page">
  <view class="top-bar">
    <view class="filter-btn" bindtap="openFilter">筛选</view>
    <view class="story-btn" bindtap="startStory">故事模式</view>
  </view>

  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-text">正在加载回忆...</view>
  </view>

  <view wx:elif="{{errorMsg}}" class="error-container">
    <view class="error-text">{{errorMsg}}</view>
    <view class="retry-btn" bindtap="loadMemories">重新加载</view>
  </view>

  <view wx:elif="{{!list.length}}" class="empty-container">
    <view class="empty-title">还没有回忆内容</view>
    <view class="empty-desc">家属上传照片和故事后，这里就会慢慢丰富起来。</view>
  </view>

  <view wx:else class="timeline">
    <block wx:for="{{list}}" wx:key="id">
      <view class="timeline-item">
        <view class="year">{{item.year}}</view>

        <view class="memory-card" bindtap="openMemory" data-item="{{item}}">
          <image class="memory-img" src="{{item.img}}" mode="aspectFill" />

          <view class="memory-content">
            <view class="memory-title">{{item.title}}</view>
            <view class="memory-meta">
              <text class="memory-tag">{{item.typeLabel}}</text>
              <text class="memory-person">{{item.person}}</text>
            </view>
            <view class="memory-story">{{item.story}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{showFilter}}" class="mask" bindtap="closeFilter"></view>

  <view wx:if="{{showFilter}}" class="filter-panel">
    <view class="panel-title">筛选回忆</view>

    <view class="filter-item" bindtap="toggleDecade">
      <text>年代</text>
      <text>{{activeDecade || "全部"}}</text>
    </view>
    <view wx:if="{{showDecade}}" class="options">
      <view class="option" bindtap="filterDecade" data-value="">全部年代</view>
      <view wx:for="{{decadeOptions}}" wx:key="*this" class="option" data-value="{{item}}" bindtap="filterDecade">
        {{item}}年代
      </view>
    </view>

    <view class="filter-item" bindtap="toggleType">
      <text>类型</text>
      <text>{{activeType || "全部"}}</text>
    </view>
    <view wx:if="{{showType}}" class="options">
      <view class="option" bindtap="filterType" data-value="">全部类型</view>
      <view wx:for="{{typeOptions}}" wx:key="*this" class="option" data-value="{{item}}" bindtap="filterType">
        {{item === "family" ? "家庭" : item === "travel" ? "旅行" : item === "festival" ? "节日" : item === "medical" ? "医疗" : "日常"}}
      </view>
    </view>

    <view class="reset" bindtap="resetFilter">重置筛选</view>
  </view>

  <view wx:if="{{showStory}}" class="story-mask" bindtap="closeStory"></view>
  <view wx:if="{{showStory}}" class="story-modal">
    <view class="story-header">
      <view class="story-title">{{currentMemory.title}}</view>
      <view class="story-close" bindtap="closeStory">关闭</view>
    </view>
    <image class="story-image" src="{{currentMemory.img}}" mode="aspectFill" />
    <view class="story-info">
      <text>{{currentMemory.year}}</text>
      <text>{{currentMemory.person}}</text>
      <text>{{currentMemory.typeLabel}}</text>
    </view>
    <view class="story-content">{{currentMemory.story}}</view>
  </view>
</view>

/* pages/elder/family-tree.wxss */
.page{
  padding:40rpx;
  background:#F8F9FB;
  min-height:100vh;
}

.title{
  font-size:44rpx;
  font-weight:bold;
  text-align:center;
  margin-bottom:40rpx;
}

/* 横向滑动容器 */
.tree-scroll{
  width:100%;
  overflow-x:auto;
}

/* 弹窗 */
.mask{
  position:fixed;top:0;left:0;right:0;bottom:0;
  background:rgba(0,0,0,0.4);
  display:flex;justify-content:center;align-items:center;z-index:100;
}

.card{
  width:70%;
  background:#fff;
  padding:40rpx;
  border-radius:30rpx;
  text-align:center;
  box-shadow:0 10rpx 30rpx rgba(0,0,0,0.2);
}

.card .avatar{
  width:140rpx;height:140rpx;border-radius:50%;margin-bottom:20rpx;
}

.card .name{font-size:36rpx;font-weight:bold;}
.card .relation,.card .age,.card .health{font-size:28rpx;color:#888;margin-bottom:10rpx;}
.card .desc{font-size:28rpx;margin-bottom:30rpx;}
.card .close{
  width:150rpx;height:50rpx;border-radius:25rpx;
  background:#4A90E2;color:#fff;font-size:28rpx;
}
.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.state-card,
.detail-card,
.info-card,
.memory-copy {
  border-radius: 22rpx;
  box-shadow: var(--yz-shadow-medium);
}

.state-card {
  margin: 28rpx 24rpx;
  padding: 56rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
  text-align: center;
}

.album-layout {
  padding: 28rpx 24rpx 54rpx;
}

.book-shell {
  position: relative;
  height: 840rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 241, 0.82);
  box-shadow: 0 24rpx 60rpx rgba(58, 73, 104, 0.1);
  box-sizing: border-box;
}

.album-swiper {
  height: 100%;
}

.album-page {
  height: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.page-sheet {
  position: relative;
  height: 100%;
  padding: 20rpx 20rpx 20rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: inset 0 0 0 2rpx rgba(242, 232, 214, 0.9);
  overflow: hidden;
}

.detail-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  white-space: nowrap;
}

.album-board {
  height: 100%;
  border-radius: 24rpx;
  background: var(--yz-bg-card);
  box-shadow: inset 0 0 0 2rpx rgba(242, 233, 219, 0.92);
}

.album-board--overview {
  padding: 28rpx 22rpx 24rpx;
  box-sizing: border-box;
}

.album-board--photo {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx;
  box-sizing: border-box;
}

.album-header {
  display: flex;
  justify-content: center;
}

.overview-card {
  padding-top: 20rpx;
}

.overview-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(112, 93, 67, 0.08);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.overview-desc,
.detail-copy,
.block-copy,
.memory-story {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--yz-text-secondary);
}

.relationship-map {
  position: relative;
  width: 620rpx;
  height: 620rpx;
  margin: 20rpx auto 0;
}

.center-node {
  position: absolute;
  left: 250rpx;
  top: 238rpx;
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  z-index: 3;
}

.center-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--yz-accent-warm-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(176, 142, 99, 0.16);
}

.center-avatar-shell,
.orbit-avatar-shell {
  border-radius: 50%;
  padding: 6rpx;
  background: rgba(116, 165, 255, 0.22);
}

.center-avatar,
.orbit-avatar,
.photo-image {
  background: var(--yz-info-soft);
}

.center-avatar,
.orbit-avatar {
  border-radius: 50%;
}

.center-avatar {
  width: 76rpx;
  height: 76rpx;
}

.orbit-avatar {
  width: 74rpx;
  height: 74rpx;
}

.center-avatar-fallback,
.orbit-avatar-fallback,
.photo-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: var(--yz-info);
}

.center-avatar-fallback {
  font-size: 28rpx;
}

.orbit-avatar-fallback {
  font-size: 26rpx;
}

.photo-fallback {
  font-size: 64rpx;
}

.center-name,
.orbit-name,
.detail-title,
.memory-title {
  font-weight: 700;
  color: var(--yz-text-primary);
}

.center-name {
  margin-top: 14rpx;
  font-size: 30rpx;
}

.center-relation,
.orbit-relation,
.person-relation {
  margin-top: 8rpx;
  color: var(--yz-text-secondary);
}

.center-relation {
  font-size: 24rpx;
}

.orbit-line {
  position: absolute;
  height: 4rpx;
  background: rgba(104, 137, 217, 0.34);
  transform-origin: 0 50%;
  z-index: 1;
  border-radius: 24rpx;
}

.orbit-line--active {
  background: rgba(104, 137, 217, 0.76);
}

.orbit-node {
  position: absolute;
  width: 116rpx;
  min-height: 128rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  z-index: 2;
}

.orbit-node--active {
  transform: scale(1.06);
}

.orbit-node--active .orbit-avatar-shell {
  box-shadow: 0 14rpx 28rpx rgba(96, 131, 227, 0.18);
  background: rgba(109, 147, 234, 0.34);
}

.orbit-node--active .orbit-avatar {
  box-shadow: 0 0 0 2rpx var(--yz-info) inset;
}

.orbit-name {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.3;
  word-break: break-all;
}

.orbit-relation {
  font-size: 22rpx;
  line-height: 1.3;
}

.photo-card {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.photo-frame {
  position: relative;
  width: 470rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: var(--yz-bg-card);
  box-shadow:
    0 28rpx 52rpx rgba(107, 87, 63, 0.16),
    inset 0 0 0 2rpx rgba(246, 238, 225, 0.95);
}

.photo-pin {
  position: absolute;
  top: -12rpx;
  width: 54rpx;
  height: 22rpx;
  border-radius: 24rpx;
  background: rgba(227, 208, 176, 0.72);
  box-shadow: 0 6rpx 12rpx rgba(117, 90, 58, 0.08);
}

.photo-pin--left {
  left: 44rpx;
  transform: rotate(-14deg);
}

.photo-pin--right {
  right: 44rpx;
  transform: rotate(14deg);
}

.photo-image {
  width: 426rpx;
  height: 548rpx;
}

.photo-image--square {
  display: block;
  border-radius: 18rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.56);
}

.corner-btn {
  position: absolute;
  top: 50%;
  margin-top: -44rpx;
  z-index: 5;
  width: 88rpx;
  height: 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.42);
  color: var(--yz-info);
  border-radius: 50%;
  box-shadow: 0 10rpx 20rpx rgba(67, 85, 124, 0.08);
  backdrop-filter: blur(12rpx);
}

.corner-btn::after {
  border: none;
}

.corner-btn--left {
  left: -10rpx;
}

.corner-btn--right {
  right: -10rpx;
}

.corner-btn-fold {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.62);
}

.corner-btn-arrow {
  position: relative;
  top: -2rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.detail-card {
  margin-top: 26rpx;
  padding: 32rpx 26rpx 34rpx;
  background: rgba(255, 255, 255, 0.96);
}

.detail-card--overview {
  background: rgba(255, 255, 255, 0.96);
}

.detail-title {
  font-size: 42rpx;
}

.detail-copy {
  margin-top: 6rpx;
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  padding: 10rpx 20rpx;
  background: var(--yz-info-soft);
  color: var(--yz-info);
  font-size: 26rpx;
}

.info-card {
  margin-top: 18rpx;
  padding: 24rpx;
  background: rgba(248, 251, 255, 0.98);
}

.block-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.block-copy {
  margin-top: 14rpx;
}

.memory-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.memory-link {
  margin: 0;
  padding: 0 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 24rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 24rpx;
}

.memory-link::after {
  border: none;
}

.memory-list {
  margin-top: 20rpx;
}

.memory-item + .memory-item {
  margin-top: 16rpx;
}

.memory-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.memory-year {
  min-width: 92rpx;
  padding-top: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--yz-brand-primary);
}

.memory-copy {
  flex: 1;
  padding: 18rpx;
  background: var(--yz-bg-card);
  box-shadow: inset 0 0 0 2rpx rgba(232, 238, 250, 0.76);
}

.memory-title {
  font-size: 32rpx;
}

.memory-story {
  margin-top: 10rpx;
}

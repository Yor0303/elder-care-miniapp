/* pages/elder/memory.wxss */
.page{
  padding:40rpx;
  background:#F8F9FB;
  min-height:100vh;
 }
 
 
 /* 顶部按钮 */
 
 .top-bar{
  display:flex;
  justify-content:space-between;
  margin-bottom:40rpx;
 }
 
 .filter-btn,
 .story-btn{
 
  background:#fff;
 
  padding:20rpx 30rpx;
 
  border-radius:20rpx;
 
  font-size:32rpx;
 
  box-shadow:0 6rpx 20rpx rgba(0,0,0,0.08);
 }
 
 
 
 /* 时间线 */
 
 .timeline{
  position:relative;
  padding-left:80rpx;
 }
 
 
 /* 时间轴线 */
 
 .timeline::before{
  content:"";
  position:absolute;
  left:30rpx;
  top:0;
  bottom:0;
  width:4rpx;
  background:#4A90E2;
 }
 
 
 .timeline-item{
  position:relative;
  margin-bottom:80rpx;
 }
 
 
 .year{
  position:absolute;
  left:-80rpx;
  font-size:32rpx;
  color:#4A90E2;
  font-weight:bold;
 }
 
 
 .memory-card{
 
  background:#fff;
 
  border-radius:24rpx;
 
  padding:20rpx;
 
  box-shadow:0 10rpx 30rpx rgba(0,0,0,0.06);
 
 }
 
 
 .memory-img{
  width:100%;
  height:300rpx;
  border-radius:20rpx;
 }
 
 
 .memory-title{
  font-size:34rpx;
  margin-top:10rpx;
  color:#333;
 }
 
 
 
 /* 遮罩 */
 
 .mask{
  position:fixed;
  top:0;
  left:0;
  right:0;
  bottom:0;
  background:rgba(0,0,0,0.4);
 }
 
 
 /* 筛选面板 */
 
 .filter-panel{
 
  position:fixed;
 
  left:0;
  right:0;
  bottom:0;
 
  background:#fff;
 
  border-top-left-radius:30rpx;
  border-top-right-radius:30rpx;
 
  padding:40rpx;
 
  height:50vh;
 
 }
 
 
 .panel-title{
  font-size:38rpx;
  font-weight:bold;
  margin-bottom:20rpx;
 }
 
 
 .filter-item{
  display:flex;
  justify-content:space-between;
  font-size:34rpx;
  padding:20rpx 0;
  border-bottom:1px solid #eee;
 }
 
 
 .options{
  padding-left:20rpx;
 }
 
 
 .option{
  font-size:32rpx;
  padding:20rpx 0;
  color:#666;
 }
 
 
 .reset{
  margin-top:30rpx;
  font-size:32rpx;
  color:#4A90E2;
 }
/* pages/elder/memory.wxss */
.page {
  padding: 36rpx 28rpx 48rpx;
  background: #f7f9fc;
  min-height: 100vh;
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.view-switch {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.08);
  flex: 1;
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #7d8896;
  transition: all 0.2s ease;
}

.switch-item.active {
  background: linear-gradient(135deg, #4a90e2, #6aa6ff);
  color: #ffffff;
  font-weight: 600;
}

.filter-btn {
  min-width: 132rpx;
  text-align: center;
  background: #ffffff;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #2d4f85;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.08);
}

.loading-container,
.error-container,
.empty-container {
  margin-top: 120rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.loading-text,
.empty-title,
.error-text {
  font-size: 32rpx;
  color: #2f3c4d;
}

.empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #7d8896;
  line-height: 1.7;
}

.retry-btn {
  margin-top: 24rpx;
  display: inline-block;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #4a90e2;
  color: #ffffff;
  font-size: 28rpx;
}

.timeline {
  position: relative;
  padding-left: 110rpx;
}

.timeline::before {
  content: "";
  position: absolute;
  left: 48rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: #4a90e2;
}

.timeline-item {
  position: relative;
  margin-bottom: 80rpx;
}

.year {
  position: absolute;
  left: -98rpx;
  top: 4rpx;
  font-size: 32rpx;
  color: #4a90e2;
  font-weight: bold;
  background: #f8f9fb;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  z-index: 2;
}

.memory-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.memory-img {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
}

.memory-title {
  font-size: 34rpx;
  margin-top: 10rpx;
  color: #333;
}

.memory-content {
  padding-top: 16rpx;
}

.memory-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7a8594;
  gap: 16rpx;
}

.memory-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #4a90e2;
}

.memory-person {
  margin-left: 20rpx;
}

.memory-story {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #44505e;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.flip-mode {
  padding-top: 8rpx;
}

.flip-hint {
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #8a94a3;
  text-align: center;
}

.playback-bar {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx 24rpx 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(74, 144, 226, 0.08);
  margin-bottom: 24rpx;
}

.playback-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.playback-group {
  display: flex;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.playback-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  flex: 1;
  padding: 16rpx 18rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #365c96;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}

.playback-btn.primary {
  background: linear-gradient(135deg, #4a90e2, #6aa6ff);
  color: #ffffff;
}

.playback-btn.warn {
  background: #fff4ea;
  color: #d47a1e;
}

.music-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 152rpx;
  flex-shrink: 0;
  padding: 16rpx 18rpx;
  border-radius: 999rpx;
  background: #f4f7ff;
  color: #4a6a9b;
  font-size: 24rpx;
  font-weight: 600;
  border: 2rpx solid transparent;
  white-space: nowrap;
}

.music-btn.active {
  background: #eef5ff;
  color: #2f5faa;
  border-color: rgba(74, 144, 226, 0.26);
}

.playback-status {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #7d8896;
}

.flip-shell {
  position: relative;
  min-height: 760rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1200rpx;
}

.flip-card {
  position: relative;
  width: 100%;
  min-height: 760rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(34, 67, 118, 0.12);
  transform: translateX(0) rotate(0deg);
  transform-origin: center center;
  transition: transform 0.34s ease, opacity 0.34s ease, box-shadow 0.34s ease;
}

.current-card.is-settling {
  transition: none;
  transform: translateX(0) rotate(0deg);
  opacity: 1;
}

.current-card.is-flipping.next {
  opacity: 0.28;
  transform: translateX(-64rpx) rotate(-5deg);
  box-shadow: 0 10rpx 24rpx rgba(34, 67, 118, 0.08);
}

.current-card.is-flipping.prev {
  opacity: 0.28;
  transform: translateX(64rpx) rotate(5deg);
  box-shadow: 0 10rpx 24rpx rgba(34, 67, 118, 0.08);
}

.incoming-card {
  position: absolute;
  inset: 0;
  opacity: 0;
}

.incoming-card.next {
  animation: cardEnterNext 0.26s ease forwards;
}

.incoming-card.prev {
  animation: cardEnterPrev 0.26s ease forwards;
}

.incoming-card.is-hold {
  opacity: 1;
  transform: translateX(0) scale(1);
  animation: none;
}

.flip-image {
  width: 100%;
  height: 760rpx;
}

.flip-card::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  width: 84rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.34s ease;
}

.current-card.is-flipping.next::after {
  right: 0;
  opacity: 1;
  background: linear-gradient(270deg, rgba(8, 21, 43, 0.16) 0%, rgba(8, 21, 43, 0) 100%);
}

.current-card.is-flipping.prev::after {
  left: 0;
  opacity: 1;
  background: linear-gradient(90deg, rgba(8, 21, 43, 0.16) 0%, rgba(8, 21, 43, 0) 100%);
}

.flip-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(12, 25, 44, 0.08) 0%, rgba(12, 25, 44, 0.65) 100%);
}

.flip-content {
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  bottom: 38rpx;
  color: #ffffff;
}

.flip-year {
  font-size: 26rpx;
  opacity: 0.88;
}

.flip-title {
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 700;
}

.flip-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  font-size: 24rpx;
  opacity: 0.94;
}

.flip-tag {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.flip-story {
  margin-top: 22rpx;
  font-size: 28rpx;
  line-height: 1.8;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  opacity: 0.96;
}

.flip-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
}

.page-action {
  min-width: 156rpx;
  text-align: center;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(74, 144, 226, 0.08);
  color: #2d4f85;
  font-size: 28rpx;
}

.page-action.disabled {
  opacity: 0.4;
}

.page-indicator {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #6d7c8e;
  font-weight: 600;
}

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 20;
}

.filter-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  padding: 40rpx;
  z-index: 21;
}

.panel-title {
  font-size: 38rpx;
  font-weight: bold;
  margin-bottom: 28rpx;
  color: #243447;
}

.filter-group + .filter-group {
  margin-top: 28rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1px solid #eef2f6;
}

.filter-row-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #344556;
}

.filter-row-value {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 28rpx;
  color: #6d7b8d;
}

.filter-row-arrow {
  font-size: 24rpx;
  color: #8ea0b8;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.filter-row-arrow--open {
  transform: rotate(180deg);
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f2f5f9;
  color: #6d7b8d;
  font-size: 28rpx;
}

.chip--active {
  background: #e8f1ff;
  color: #2e67c7;
}

.panel-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.panel-btn {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #4a90e2;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.panel-btn--ghost {
  background: #eef3fb;
  color: #4a6687;
}

.story-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 30;
}

.story-modal {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 8vh;
  bottom: 8vh;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  z-index: 31;
  display: flex;
  flex-direction: column;
}

.story-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.story-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  color: #243447;
}

.story-close {
  font-size: 26rpx;
  color: #4a90e2;
}

.story-image {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  margin-top: 24rpx;
}

.story-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #7a8594;
}

.story-content {
  margin-top: 24rpx;
  font-size: 30rpx;
  line-height: 1.9;
  color: #364152;
  overflow: auto;
  flex: 1;
}

@keyframes cardEnterNext {
  from {
    opacity: 0;
    transform: translateX(72rpx) rotate(4deg);
  }

  to {
    opacity: 1;
    transform: translateX(0) rotate(0deg);
  }
}

@keyframes cardEnterPrev {
  from {
    opacity: 0;
    transform: translateX(-72rpx) rotate(-4deg);
  }

  to {
    opacity: 1;
    transform: translateX(0) rotate(0deg);
  }
}

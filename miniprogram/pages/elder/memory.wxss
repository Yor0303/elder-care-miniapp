/* pages/elder/memory.wxss */
.page{
  padding:40rpx;
  background:#F8F9FB;
  min-height:100vh;
 }

.loading-container,
.error-container,
.empty-container{
  margin-top:120rpx;
  background:#fff;
  border-radius:28rpx;
  padding:48rpx 32rpx;
  text-align:center;
  box-shadow:0 10rpx 30rpx rgba(0,0,0,0.06);
}

.loading-text,
.empty-title,
.error-text{
  font-size:32rpx;
  color:#2f3c4d;
}

.empty-desc{
  margin-top:16rpx;
  font-size:26rpx;
  color:#7d8896;
  line-height:1.7;
}

.retry-btn{
  margin-top:24rpx;
  display:inline-block;
  padding:16rpx 28rpx;
  border-radius:999rpx;
  background:#4A90E2;
  color:#fff;
  font-size:28rpx;
}
 
 
 /* 顶部按钮 */
 
 .top-bar{
  display:flex;
  justify-content:space-between;
  margin-bottom:40rpx;
 }
 
 .filter-btn,
 .story-btn{
 
  background:#fff;
 
  padding:20rpx 30rpx;
 
  border-radius:20rpx;
 
  font-size:32rpx;
 
  box-shadow:0 6rpx 20rpx rgba(0,0,0,0.08);
 }
 
 
 
 /* 时间线 */
 
.timeline{
  position:relative;
  padding-left:110rpx;
 }
 
 
 /* 时间轴线 */
 
.timeline::before{
  content:"";
  position:absolute;
  left:48rpx;
  top:0;
  bottom:0;
  width:4rpx;
  background:#4A90E2;
 }
 
 
 .timeline-item{
  position:relative;
  margin-bottom:80rpx;
 }
 
 
.year{
  position:absolute;
  left:-98rpx;
  top:4rpx;
  font-size:32rpx;
  color:#4A90E2;
  font-weight:bold;
  background:#F8F9FB;
  padding:4rpx 10rpx;
  border-radius:12rpx;
  z-index:2;
 }
 
 
.memory-card{

  background:#fff;

  border-radius:24rpx;

  padding:20rpx;

  box-shadow:0 10rpx 30rpx rgba(0,0,0,0.06);
  overflow:hidden;
 }
 
 
 .memory-img{
  width:100%;
  height:300rpx;
  border-radius:20rpx;
 }
 
 
.memory-title{
  font-size:34rpx;
  margin-top:10rpx;
  color:#333;
}

.memory-content{
  padding-top:16rpx;
}

.memory-meta{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-top:12rpx;
  font-size:24rpx;
  color:#7a8594;
}

.memory-tag{
  display:inline-flex;
  align-items:center;
  padding:6rpx 18rpx;
  border-radius:999rpx;
  background:#eef5ff;
  color:#4A90E2;
}

.memory-person{
  margin-left:20rpx;
}

.memory-story{
  margin-top:18rpx;
  font-size:28rpx;
  color:#44505e;
  line-height:1.7;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
 
 
 
 /* 遮罩 */
 
.mask{
  position:fixed;
  top:0;
  left:0;
  right:0;
  bottom:0;
  background:rgba(0,0,0,0.4);
  z-index:20;
 }
 
 
 /* 筛选面板 */
 
 .filter-panel{
 
  position:fixed;
 
  left:0;
  right:0;
  bottom:0;
 
 background:#fff;
 
  border-top-left-radius:30rpx;
  border-top-right-radius:30rpx;
 
  padding:40rpx;
 
 height:50vh;
  z-index:21;
 
 }
 
 
 .panel-title{
  font-size:38rpx;
  font-weight:bold;
  margin-bottom:20rpx;
 }
 
 
 .filter-item{
  display:flex;
  justify-content:space-between;
  font-size:34rpx;
  padding:20rpx 0;
  border-bottom:1px solid #eee;
 }
 
 
 .options{
  padding-left:20rpx;
 }
 
 
 .option{
  font-size:32rpx;
  padding:20rpx 0;
  color:#666;
 }
 
 
.reset{
  margin-top:30rpx;
  font-size:32rpx;
  color:#4A90E2;
}

.story-mask{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.45);
  z-index:30;
}

.story-modal{
  position:fixed;
  left:32rpx;
  right:32rpx;
  top:8vh;
  bottom:8vh;
  background:#fff;
  border-radius:32rpx;
  padding:32rpx;
  z-index:31;
  display:flex;
  flex-direction:column;
}

.story-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:20rpx;
}

.story-title{
  flex:1;
  font-size:36rpx;
  font-weight:bold;
  color:#243447;
}

.story-close{
  font-size:26rpx;
  color:#4A90E2;
}

.story-image{
  width:100%;
  height:320rpx;
  border-radius:24rpx;
  margin-top:24rpx;
}

.story-info{
  display:flex;
  flex-wrap:wrap;
  gap:16rpx;
  margin-top:20rpx;
  font-size:24rpx;
  color:#7a8594;
}

.story-content{
  margin-top:24rpx;
  font-size:30rpx;
  line-height:1.9;
  color:#364152;
  overflow:auto;
  flex:1;
}

<!--pages/elder/family-tree.wxml-->
<view class="page">
  <view class="title">我的家人</view>

  <!-- 横向可滑动 -->
  <scroll-view scroll-x="true" class="tree-scroll">
    <view class="tree">
      <block wx:for="{{treeData}}" wx:key="id">
        <tree-node node="{{item}}" bind:click="showCard"/>
      </block>
    </view>
  </scroll-view>

  <!-- 弹窗 -->
  <view class="mask" wx:if="{{showCard}}">
    <view class="card">
      <image class="avatar" src="{{currentPerson.avatar}}"></image>
      <view class="name">{{currentPerson.name}}</view>
      <view class="relation">{{currentPerson.relation}}</view>
      <view class="age">年龄: {{currentPerson.age}}</view>
      <view class="health">健康: {{currentPerson.health}}</view>
      <view class="desc">{{currentPerson.description}}</view>
      <button class="close" bindtap="closeCard">关闭</button>
    </view>
  </view>
</view>
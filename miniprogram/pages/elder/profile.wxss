.page {
  padding: 32rpx;
}

.avatar {
  width: 220rpx;
  height: 220rpx;
  border-radius: 24rpx;
  display: block;
  margin: 0 auto 24rpx;
  background: #f2f2f2;
}

.name {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.meta {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.section-title {
  margin-top: 32rpx;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.memory-card {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

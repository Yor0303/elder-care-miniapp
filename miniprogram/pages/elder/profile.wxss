.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.loading-card,
.hero-card,
.identity-card,
.memory-card,
.empty {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.loading-card {
  display: flex;
  justify-content: center;
  padding: 64rpx 0;
  background: rgba(255, 255, 255, 0.96);
}

.hero-card {
  margin-bottom: 22rpx;
  padding: 32rpx 28rpx;
  background: var(--yz-gradient-hero);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 136rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.identity-card {
  background: rgba(255, 255, 255, 0.96);
  padding: 30rpx 28rpx;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  display: block;
  margin: 0 auto 20rpx;
  background: var(--yz-bg-section);
}

.name {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16rpx;
  color: var(--yz-text-primary);
}

.basic-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.pill {
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 26rpx;
}

.bind-phone-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--yz-bg-card-soft);
  border: 2rpx solid var(--yz-border-soft);
}

.bind-phone-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.bind-phone-desc {
  margin-top: 8rpx;
  color: var(--yz-text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.bind-phone-input {
  margin-top: 18rpx;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: var(--yz-bg-card);
  border: 2rpx solid var(--yz-border-soft);
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--yz-text-primary);
}

.bind-phone-btn {
  margin-top: 18rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 24rpx;
  border: none;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 28rpx;
  font-weight: 600;
}

.bind-phone-btn::after {
  border: none;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.info-item {
  background: var(--yz-bg-card-soft);
  border-radius: 20rpx;
  border: 2rpx solid var(--yz-border-soft);
  padding: 18rpx;
}

.label {
  font-size: 24rpx;
  color: var(--yz-text-tertiary);
  margin-bottom: 8rpx;
}

.value {
  font-size: 28rpx;
  color: var(--yz-text-primary);
}

.section-title {
  margin-top: 32rpx;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.timeline {
  position: relative;
  padding-left: 110rpx;
}

.timeline::before {
  content: "";
  position: absolute;
  left: 48rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: var(--yz-brand-primary-border);
}

.timeline-item {
  position: relative;
  margin-bottom: 80rpx;
}

.year {
  position: absolute;
  left: -98rpx;
  top: 4rpx;
  font-size: 32rpx;
  color: var(--yz-brand-primary);
  font-weight: bold;
  background: var(--yz-brand-primary-soft);
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  z-index: 2;
}

.memory-card {
  background: rgba(255, 255, 255, 0.96);
  padding: 20rpx;
}

.memory-title {
  font-size: 34rpx;
  color: var(--yz-text-primary);
  font-weight: 700;
}

.memory-story {
  font-size: 28rpx;
  color: var(--yz-text-secondary);
  margin-top: 10rpx;
  line-height: 1.6;
}

.empty {
  text-align: center;
  color: var(--yz-text-secondary);
  font-size: 30rpx;
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.96);
  padding: 40rpx 24rpx;
}

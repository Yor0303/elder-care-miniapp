/* pages/elder/profile.wxss */
.page {
  padding: 32rpx;
  background: #F8F9FB;
  min-height: 100vh;
}

.loading {
  text-align: center;
  color: #888;
  font-size: 30rpx;
  margin-top: 40rpx;
}

.identity-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  display: block;
  margin: 0 auto 20rpx;
  background: #f2f2f2;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16rpx;
  color: #1a3a5f;
}

.basic-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f0f7ff;
  color: #4A90E2;
  font-size: 26rpx;
}

.bind-phone-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f7fbff;
  border: 2rpx solid #dce9f8;
}

.bind-phone-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.bind-phone-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.bind-phone-input {
  margin-top: 18rpx;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 2rpx solid #dbe5f0;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2a37;
}

.bind-phone-btn {
  margin-top: 18rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.bind-phone-btn::after {
  border: none;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.info-item {
  background: #f7f8fa;
  border-radius: 18rpx;
  padding: 18rpx;
}

.label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.section-title {
  margin-top: 32rpx;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.timeline {
  position: relative;
  padding-left: 110rpx;
}

.timeline::before {
  content: "";
  position: absolute;
  left: 48rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: #4A90E2;
}

.timeline-item {
  position: relative;
  margin-bottom: 80rpx;
}

.year {
  position: absolute;
  left: -98rpx;
  top: 4rpx;
  font-size: 32rpx;
  color: #4A90E2;
  font-weight: bold;
  background: #F8F9FB;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  z-index: 2;
}

.memory-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.memory-title {
  font-size: 34rpx;
  color: #333;
  font-weight: 700;
}

.memory-story {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
  line-height: 1.6;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 30rpx;
  margin-top: 40rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

<view class="page">
  <view wx:if="{{previewMode}}" class="preview-banner">
    <view class="preview-copy">
      <view class="preview-title">{{copy.previewTitle}}</view>
      <view class="preview-desc">{{copy.previewDesc}}</view>
    </view>
    <button class="preview-btn" bindtap="exitPreview">{{copy.backToFamily}}</button>
  </view>

  <block wx:if="{{pageTab === 'home'}}">
    <view class="memo-card">
      <view class="memo-head-row">
        <view>
          <view class="memo-title">{{copy.todayCompanion}}</view>
          <view class="board-desc">{{boardTab === 'messages' ? copy.boardMessagesDesc : copy.boardRemindersDesc}}</view>
        </view>
        <view class="memo-badge">
          {{boardTab === 'messages' ? (unreadMessageCount ? unreadMessageCount + copy.unreadSuffix : copy.readDone) : (medicationReminders.length ? medicationReminders.length + copy.todoSuffix : copy.todayDone)}}
        </view>
      </view>

      <view class="memo-tabs">
        <view
          class="memo-tab {{boardTab === 'messages' ? 'memo-tab-active' : ''}}"
          data-tab="messages"
          bindtap="switchBoardTab"
        >
          {{copy.familyMessages}}
        </view>
        <view
          class="memo-tab {{boardTab === 'reminders' ? 'memo-tab-active' : ''}}"
          data-tab="reminders"
          bindtap="switchBoardTab"
        >
          {{copy.todayReminders}}
        </view>
      </view>

      <block wx:if="{{boardTab === 'messages'}}">
        <view wx:if="{{onThisDay}}" class="binding-message-card" bindtap="openPreview">
          <view class="binding-message-icon blue">
            <app-icon name="system-messages-filled" size="34rpx" color="#56B0EB"></app-icon>
          </view>
          <view class="binding-message-copy">
            <view class="binding-message-title">{{onThisDay.title || copy.recallPrompt}}</view>
            <view class="binding-message-desc">{{onThisDay.desc || onThisDay.summary || copy.recallDesc}}</view>
          </view>
        </view>

        <image
          wx:if="{{onThisDay && onThisDay.img}}"
          class="board-image"
          src="{{onThisDay.img}}"
          mode="aspectFill"
          bindtap="openPreview"
        />

        <view wx:if="{{voiceMessages.length}}" class="message-list-spaced">
          <view wx:for="{{voiceMessages}}" wx:key="id" class="message-item">
            <view class="message-main">
              <view class="message-sender">{{item.senderName || copy.familyMessages}}</view>
              <view class="message-meta">
                {{item.displayTime || copy.justNow}}
                {{item.durationText ? (' · ' + item.durationText) : ''}}
              </view>
              <view wx:if="{{item.note}}" class="message-note">{{item.note}}</view>
            </view>

            <button
              wx:if="{{item.hasAudio}}"
              class="message-play-btn"
              data-id="{{item.id}}"
              bindtap="playVoiceMessage"
            >
              {{playingMessageId === item.id ? copy.stop : copy.play}}
            </button>
            <view wx:else class="message-text-tag">{{copy.textTag}}</view>
          </view>
        </view>

        <view wx:elif="{{!onThisDay}}" class="empty-content">{{copy.noMessages}}</view>
      </block>

      <block wx:else>
        <view wx:if="{{medicationReminders.length}}" class="reminder-panel">
          <view wx:for="{{medicationReminders}}" wx:key="id" class="reminder-item">
            <view class="reminder-main">
              <view class="reminder-name">{{item.name}}</view>
              <view class="reminder-meta">
                {{item.time || copy.todayReminders}}
                {{item.frequency ? (' · ' + item.frequency) : ''}}
                {{item.dosage ? (' · ' + item.dosage) : ''}}
              </view>
              <view wx:if="{{item.notes}}" class="reminder-note">{{item.notes}}</view>
            </view>

            <view
              class="reminder-check {{completingReminderId === item.id ? 'reminder-check-loading' : ''}} {{previewMode ? 'reminder-check-disabled' : ''}}"
              data-id="{{item.id}}"
              data-task-type="{{item.taskType}}"
              bindtap="completeReminder"
            >
              {{completingReminderId === item.id ? '...' : ''}}
            </view>
          </view>
        </view>

        <view wx:else class="empty-content">{{copy.noReminders}}</view>
      </block>
    </view>

    <view class="feature-panel">
      <view class="feature-grid">
        <view class="feature-card" bindtap="goToMemory">
          <view class="feature-icon orange">
            <app-icon name="browse-gallery-filled" size="44rpx" color="#F1A563"></app-icon>
          </view>
          <view class="feature-title">{{copy.memoryAlbum}}</view>
        </view>
        <view class="feature-card" bindtap="goToFamily">
          <view class="feature-icon mint">
            <app-icon name="usergroup-filled" size="44rpx" color="#6BD1A8"></app-icon>
          </view>
          <view class="feature-title">{{copy.familyTree}}</view>
        </view>
        <view class="feature-card" bindtap="goToHealth">
          <view class="feature-icon red">
            <app-icon name="heart-filled" size="44rpx" color="#E45B55"></app-icon>
          </view>
          <view class="feature-title">{{copy.healthManage}}</view>
        </view>
        <view class="feature-card" bindtap="goToProfile">
          <view class="feature-icon blue">
            <app-icon name="personal-information-filled" size="44rpx" color="#56B0EB"></app-icon>
          </view>
          <view class="feature-title">{{copy.myProfile}}</view>
        </view>
        <view class="feature-card" bindtap="goToBindingRequests">
          <view class="feature-icon orange">
            <app-icon name="system-messages-filled" size="44rpx" color="#F1A563"></app-icon>
          </view>
          <view class="feature-title">{{copy.bindingMessages}}</view>
        </view>
        <view class="feature-card" bindtap="goToLifeGuides">
          <view class="feature-icon mint">
            <app-icon name="calendar-filled" size="44rpx" color="#6BD1A8"></app-icon>
          </view>
          <view class="feature-title">{{copy.lifeGuide}}</view>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{pageTab === 'mine'}}">
    <view class="hero-card mine-hero">
      <view class="hero-badge">{{copy.appName}}</view>
      <view class="mine-profile">
        <image
          class="mine-avatar"
          src="{{(elderProfile && (elderProfile.avatarUrl || elderProfile.avatar)) || '/assets/images/avatar1.png'}}"
          mode="aspectFill"
        />
        <view class="mine-copy">
          <view class="hero-title">{{(elderProfile && elderProfile.name) || copy.defaultElderName}}</view>
          <view class="hero-desc small">
            {{(elderProfile && elderProfile.phone) || copy.mineDesc}}
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{previewMode}}" class="preview-panel">
      <view class="preview-panel-title">{{copy.previewQrTitle}}</view>
      <view class="preview-panel-desc">{{copy.previewQrDesc}}</view>
    </view>

    <view wx:else class="qr-panel">
      <view class="qr-panel-title">{{copy.qrPanelTitle}}</view>
      <view class="qr-panel-desc">{{copy.qrPanelDesc}}</view>

      <view class="qr-box">
        <image wx:if="{{bindQrCodeFileID}}" class="qr-image" src="{{bindQrCodeFileID}}" mode="aspectFit" />

        <view wx:elif="{{bindQrLoading}}" class="qr-placeholder">
          <mp-loading type="dot-gray"></mp-loading>
          <view class="qr-placeholder-text">{{copy.qrLoading}}</view>
        </view>

        <view wx:else class="qr-placeholder">
          <view class="qr-placeholder-emoji orange">
            <app-icon name="qrcode" size="40rpx" color="#F1A563"></app-icon>
          </view>
          <view class="qr-placeholder-text">{{copy.qrPlaceholder}}</view>
        </view>
      </view>

      <view class="qr-actions">
        <button class="secondary-btn icon-btn" bindtap="refreshBindingQRCode">
          <app-icon name="qrcode" size="28rpx" color="#ffffff"></app-icon>
          <text class="btn-icon-text">{{copy.refreshQr}}</text>
        </button>
        <button class="secondary-btn ghost-btn icon-btn" bindtap="goToBindingRequests">
          <app-icon name="system-messages-filled" size="28rpx" color="#56B0EB"></app-icon>
          <text class="btn-icon-text ghost-text">{{copy.viewBindingMessages}}</text>
        </button>
      </view>
    </view>

    <view class="feature-panel mine-feature-panel">
      <view class="feature-grid">
        <view class="feature-card" bindtap="goToProfile">
          <view class="feature-icon blue">
            <app-icon name="personal-information-filled" size="44rpx" color="#56B0EB"></app-icon>
          </view>
          <view class="feature-title">{{copy.personalProfile}}</view>
        </view>
        <view class="feature-card" bindtap="goToMatch">
          <view class="feature-icon orange">
            <app-icon name="camera-filled" size="44rpx" color="#F1A563"></app-icon>
          </view>
          <view class="feature-title">{{copy.memoryMatch}}</view>
        </view>
        <view class="feature-card" bindtap="goToBindingRequests">
          <view class="feature-icon red">
            <app-icon name="relation" size="44rpx" color="#E45B55"></app-icon>
          </view>
          <view class="feature-title">
            {{copy.bindingRequest}}
            <text wx:if="{{pendingCount}}">({{pendingCount}})</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-nav">
    <view class="nav-item {{pageTab === 'home' ? 'active' : ''}}" data-tab="home" bindtap="switchPageTab">
      <view class="nav-emoji">
        <app-icon name="home-filled" size="34rpx" color="{{pageTab === 'home' ? '#56B0EB' : '#6D736F'}}"></app-icon>
      </view>
      <view class="nav-label">{{copy.home}}</view>
    </view>

    <view class="nav-center" bindtap="goToFaceRecognition">
      <view class="nav-center-btn">
        <app-icon name="camera-filled" size="40rpx" color="#ffffff"></app-icon>
      </view>
      <view class="nav-center-label">{{copy.faceRecognition}}</view>
    </view>

    <view class="nav-item {{pageTab === 'mine' ? 'active' : ''}}" data-tab="mine" bindtap="switchPageTab">
      <view class="nav-emoji">
        <app-icon name="member-filled" size="34rpx" color="{{pageTab === 'mine' ? '#6BD1A8' : '#6D736F'}}"></app-icon>
      </view>
      <view class="nav-label">{{copy.mine}}</view>
    </view>
  </view>

  <view wx:if="{{previewVisible}}" class="preview-mask" catchtap="closePreview">
    <image class="preview-full" src="{{previewImg}}" mode="aspectFit" />
  </view>
</view>

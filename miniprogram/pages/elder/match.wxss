.page {
  padding: 30rpx;
  background: var(--yz-bg-page);
  min-height: 100vh;
  box-sizing: border-box;
}
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--yz-text-primary);
}
.retry {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  border-radius: 12rpx;
  border: none;
}
.empty {
  text-align: center;
  color: var(--yz-text-secondary);
  margin-top: 60rpx;
}
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.card {
  height: 220rpx;
  perspective: 800px;
}
.card .face {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  backface-visibility: hidden;
  position: absolute;
  left: 0;
  top: 0;
}
.card .back {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}
.card .front {
  background: var(--yz-bg-card);
  transform: rotateY(180deg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.card .photo {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.card .name {
  font-size: 36rpx;
  color: var(--yz-text-primary);
}
.card {
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.28s ease;
}
.card.flipped {
  transform: rotateY(180deg);
}
.card.matched {
  opacity: 0.6;
}
.win-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}
.win-box {
  background: var(--yz-bg-card);
  border-radius: 20rpx;
  padding: 40rpx 60rpx;
  text-align: center;
}
.win-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--yz-text-primary);
  margin-bottom: 10rpx;
}
.win-sub {
  color: var(--yz-text-secondary);
  font-size: 28rpx;
}

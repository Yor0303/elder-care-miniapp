.page {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #f7f9fc 0%, #eef3f8 100%);
  box-sizing: border-box;
}

.hero-card,
.request-card,
.empty-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.hero-card {
  padding: 34rpx 32rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #18324b;
  margin-bottom: 12rpx;
}

.hero-desc,
.request-meta,
.request-time,
.status,
.empty-card {
  font-size: 27rpx;
  line-height: 1.7;
  color: #667085;
}

.request-card {
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.request-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.request-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2a37;
}

.request-meta {
  margin-top: 8rpx;
}

.request-time {
  color: #98a2b3;
  white-space: nowrap;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 600;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.reject {
  background: #fff1f0;
  color: #d14343;
}

.action-btn.approve {
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
}

.status {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.status.approved {
  background: #effaf3;
  color: #276749;
}

.status.rejected {
  background: #fff1f0;
  color: #d14343;
}

.empty-card {
  padding: 40rpx 32rpx;
  text-align: center;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 40rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.hero-card,
.section-card,
.request-card,
.empty-card,
.family-card {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-medium);
}

.hero-card {
  padding: 34rpx 30rpx;
  margin-bottom: 28rpx;
  background: var(--yz-info);
  color: var(--yz-bg-card);
}

.hero-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 50rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.86);
}

.section-card {
  padding: 28rpx 26rpx;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.96);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.section-tag {
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 23rpx;
}

.section-tag.soft {
  background: var(--yz-success-soft);
  color: var(--yz-success);
}

.request-list,
.family-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.request-card {
  padding: 28rpx 26rpx;
  background: var(--yz-bg-card-soft);
}

.request-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.request-main,
.family-main {
  flex: 1;
  min-width: 0;
}

.request-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.request-badge.pending {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
}

.request-badge.approved {
  background: var(--yz-success-soft);
  color: var(--yz-success);
}

.request-badge.rejected {
  background: var(--yz-danger-soft);
  color: var(--yz-danger);
}

.request-name,
.family-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.request-meta,
.request-time,
.empty-desc,
.family-meta {
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.request-meta,
.family-meta {
  margin-top: 8rpx;
}

.request-time {
  white-space: nowrap;
  color: var(--yz-text-tertiary);
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-btn {
  flex: 1;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 24rpx;
  font-size: 29rpx;
  font-weight: 700;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.reject {
  background: var(--yz-danger-soft);
  color: var(--yz-danger);
}

.action-btn.approve {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}

.family-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  background: var(--yz-info-soft);
}

.family-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--yz-brand-primary);
  background: rgba(255, 255, 255, 0.9);
  flex-shrink: 0;
}

.family-status {
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: var(--yz-success-soft);
  color: var(--yz-success);
  font-size: 23rpx;
}

.empty-card {
  padding: 44rpx 30rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.96);
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.empty-desc {
  margin-top: 10rpx;
}

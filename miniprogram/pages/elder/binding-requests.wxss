.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 40rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 225, 182, 0.3), transparent 26%),
    linear-gradient(180deg, #f8fbfc 0%, #eef4f5 100%);
}

.hero-card,
.section-card,
.request-card,
.empty-card,
.family-card {
  border-radius: 32rpx;
  box-shadow: 0 18rpx 42rpx rgba(21, 32, 43, 0.08);
}

.hero-card {
  padding: 34rpx 30rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, #25486f 0%, #386f8f 55%, #5da7a6 100%);
  color: #fff;
}

.hero-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 50rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.86);
}

.section-card {
  padding: 28rpx 26rpx;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.96);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.section-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf3ff;
  color: #2563eb;
  font-size: 23rpx;
}

.section-tag.soft {
  background: #effaf3;
  color: #276749;
}

.request-list,
.family-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.request-card {
  padding: 28rpx 26rpx;
  background: #f9fbfc;
}

.request-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.request-main,
.family-main {
  flex: 1;
  min-width: 0;
}

.request-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.request-badge.pending {
  background: #eaf3ff;
  color: #2563eb;
}

.request-badge.approved {
  background: #effaf3;
  color: #276749;
}

.request-badge.rejected {
  background: #fff1f0;
  color: #d14343;
}

.request-name,
.family-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.request-meta,
.request-time,
.empty-desc,
.family-meta {
  font-size: 25rpx;
  line-height: 1.7;
  color: #6f8092;
}

.request-meta,
.family-meta {
  margin-top: 8rpx;
}

.request-time {
  white-space: nowrap;
  color: #98a2b3;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-btn {
  flex: 1;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.reject {
  background: #fff1f0;
  color: #d14343;
}

.action-btn.approve {
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
}

.family-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  background: linear-gradient(145deg, #eef6ff 0%, #ffffff 72%);
}

.family-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  background: rgba(255, 255, 255, 0.9);
  flex-shrink: 0;
}

.family-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #effaf3;
  color: #276749;
  font-size: 23rpx;
}

.empty-card {
  padding: 44rpx 30rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.96);
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.empty-desc {
  margin-top: 10rpx;
}

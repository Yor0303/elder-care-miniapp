.page {
  padding: 40rpx;
  background: var(--yz-bg-page);
  min-height: 100vh;
  box-sizing: border-box;
}
.segment {
  display: flex;
  background: var(--yz-bg-card);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.seg-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--yz-text-secondary);
}
.seg-btn.active {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
}
.card {
  background: var(--yz-bg-card);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--yz-shadow-soft);
}
.hint {
  font-size: 28rpx;
  color: var(--yz-text-secondary);
  margin-bottom: 16rpx;
}
.image-picker {
  width: 100%;
  height: 420rpx;
  background: var(--yz-bg-section);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.picked {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.placeholder {
  color: var(--yz-text-tertiary);
}
.form-item {
  margin-bottom: 20rpx;
}
.label {
  font-size: 28rpx;
  color: var(--yz-text-secondary);
  margin-bottom: 10rpx;
}
.picker {
  background: var(--yz-bg-card-soft);
  padding: 22rpx 26rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--yz-text-primary);
}
.textarea {
  width: 100%;
  height: 220rpx;
  background: var(--yz-bg-card-soft);
  padding: 20rpx 26rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
  color: var(--yz-text-primary);
}
.submit {
  width: 100%;
  height: 100rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 36rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

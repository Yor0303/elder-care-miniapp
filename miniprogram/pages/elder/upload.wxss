.page {
  padding: 40rpx;
  background: #F8F9FB;
  min-height: 100vh;
  box-sizing: border-box;
}
.segment {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.seg-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #666;
}
.seg-btn.active {
  background: #4A90E2;
  color: #fff;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.hint {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.image-picker {
  width: 100%;
  height: 420rpx;
  background: #F2F4F8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.picked {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.placeholder {
  color: #999;
}
.form-item {
  margin-bottom: 20rpx;
}
.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}
.picker {
  background: #F8F9FB;
  padding: 22rpx 26rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}
.textarea {
  width: 100%;
  height: 220rpx;
  background: #F8F9FB;
  padding: 20rpx 26rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.submit {
  width: 100%;
  height: 100rpx;
  background: #4A90E2;
  color: #fff;
  font-size: 36rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

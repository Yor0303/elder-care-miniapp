/* pages/elder/face-recognition.wxss */
.page {
  min-height: 100vh;
  background: var(--yz-bg-page);
  display: flex;
  flex-direction: column;
}

.header {
  padding: 40rpx;
  text-align: center;
  background: var(--yz-bg-card);
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--yz-text-primary);
}

.subtitle {
  font-size: 28rpx;
  color: var(--yz-text-secondary);
  margin-top: 10rpx;
}

/* 摄像头区域 */
.camera-container {
  position: relative;
  margin: 30rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #000;
  height: 760rpx;
  flex-shrink: 0;
}

.camera {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* 人脸框引导 */
.face-guide {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.face-frame {
  width: 350rpx;
  height: 450rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  background: transparent;
}

.guide-text {
  color: var(--yz-bg-card);
  font-size: 28rpx;
  margin-top: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 10rpx 30rpx;
  border-radius: 22rpx;
}

/* 未授权提示 */
.auth-prompt {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--yz-bg-card-soft);
}

.auth-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.auth-text {
  font-size: 32rpx;
  color: var(--yz-text-secondary);
  margin-bottom: 40rpx;
}

.auth-btn {
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 30rpx;
  padding: 20rpx 60rpx;
  border-radius: 24rpx;
}

/* 识别结果 */
.result-section {
  padding: 30rpx;
}

.result-card {
  display: flex;
  align-items: center;
  background: var(--yz-bg-card);
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: var(--yz-shadow-soft);
}

.unknown-card {
  border: 2rpx solid rgba(255, 107, 107, 0.18);
  background: var(--yz-bg-card);
}

.result-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  background: var(--yz-bg-section);
}

.unknown-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  background: #ffd7d7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unknown-avatar-text {
  font-size: 54rpx;
  color: var(--yz-danger);
  font-weight: bold;
}

.result-info {
  flex: 1;
}

.result-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--yz-text-primary);
}

.result-relation {
  font-size: 28rpx;
  color: var(--yz-brand-primary);
  margin-top: 8rpx;
}

.unknown-relation {
  color: var(--yz-danger);
}

.result-desc {
  font-size: 26rpx;
  color: var(--yz-text-tertiary);
  margin-top: 10rpx;
}

/* 识别状态 */
.status-section {
  padding: 20rpx;
  text-align: center;
}

.status-text {
  font-size: 30rpx;
  color: var(--yz-brand-primary);
}

.status-text.no-match {
  color: var(--yz-danger);
}

.retry-btn {
  margin-top: 20rpx;
  background: var(--yz-gradient-primary);
  color: var(--yz-bg-card);
  font-size: 28rpx;
  padding: 15rpx 40rpx;
  border-radius: 24rpx;
}

/* 操作按钮 */
.action-section {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.capture-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100rpx;
  background: var(--yz-brand-primary);
  color: var(--yz-bg-card);
  font-size: 34rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(111, 143, 200, 0.24);
}

.capture-btn[disabled] {
  background: var(--yz-text-tertiary);
  box-shadow: none;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

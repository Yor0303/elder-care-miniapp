.page {
  padding: 40rpx;
  background-color: #f8f9fb;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 220rpx;
}

.card {
  background: #ffffff;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.board-card {
  padding: 40rpx;
  margin-bottom: 32rpx;
}

.board-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.board-header {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a3a5f;
}

.message-bubble {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #4a90e2;
  font-size: 22rpx;
}

.board-tabs {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.board-tab {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #f2f5f8;
  color: #748397;
  font-size: 26rpx;
  position: relative;
}

.board-tab-active {
  background: #eaf2ff;
  color: #2e6eae;
  font-weight: 600;
}

.tab-count {
  margin-left: 10rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #ff8f8f;
  color: #fff;
  font-size: 20rpx;
}

.tab-dot {
  position: absolute;
  top: 10rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff7b7b;
  border: 2rpx solid #fff;
}

.board-image {
  width: 100%;
  height: 420rpx;
  border-radius: 20rpx;
  object-fit: cover;
  margin-bottom: 18rpx;
}

.board-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.board-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
}

.empty-content {
  padding: 44rpx 0 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.feature-list {
  padding-bottom: 20rpx;
}

.feature {
  display: flex;
  align-items: center;
  padding: 44rpx 36rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.feature:active {
  transform: scale(0.98);
  background: #f0f4f8;
}

.icon {
  font-size: 74rpx;
  margin-right: 32rpx;
}

.request-card {
  overflow: hidden;
}

.request-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6ea1ff 0%, #4f7ce6 100%);
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.request-badge {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #ff7b7b;
  color: #fff;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 28rpx;
  color: #888;
  line-height: 1.6;
}

.reminder-panel {
  margin-bottom: 12rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f6f9ff;
}

.reminder-title {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2e6eae;
}

.reminder-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e6eef9;
}

.reminder-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.reminder-main {
  flex: 1;
}

.reminder-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.reminder-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f7f92;
}

.reminder-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7c8b9a;
  line-height: 1.6;
}

.reminder-tag {
  min-width: 96rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 28rpx;
  background: #e8f1ff;
  color: #4a90e2;
  font-size: 22rpx;
  text-align: center;
}

.message-list-spaced {
  margin-top: 12rpx;
}

.message-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.message-item:last-child {
  border-bottom: none;
}

.message-main {
  flex: 1;
}

.message-sender {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.message-meta {
  font-size: 24rpx;
  color: #888;
}

.message-note {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #4f5f73;
  line-height: 1.6;
}

.message-play-btn {
  min-width: 120rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 34rpx;
  background: #eef5ff;
  color: #4a90e2;
  font-size: 26rpx;
  padding: 0 24rpx;
}

.message-text-tag {
  min-width: 120rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 34rpx;
  background: #f2f5f8;
  color: #7c8b9a;
  font-size: 24rpx;
  text-align: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.feature-switch {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: 36rpx;
  display: flex;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 34rpx;
  padding: 14rpx;
  box-shadow: 0 14rpx 36rpx rgba(26, 58, 95, 0.14);
  z-index: 100;
  gap: 12rpx;
}

.switch-item {
  flex: 1;
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  color: #7f8b99;
}

.switch-item-active {
  background: #eef5ff;
  color: #1a3a5f;
}

.switch-label {
  font-size: 28rpx;
  font-weight: 600;
}

.switch-desc {
  font-size: 20rpx;
  margin-top: 8rpx;
}

.preview-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.floating-buttons {
  position: fixed;
  right: 36rpx;
  bottom: 170rpx;
  display: flex;
  gap: 20rpx;
  z-index: 120;
}

.floating-btn {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #fff;
  box-shadow: 0 18rpx 36rpx rgba(38, 70, 132, 0.18);
}

.floating-btn::after {
  border: none;
}

.invite-btn {
  background: linear-gradient(135deg, #2ec082 0%, #22a96f 100%);
}

.face-btn {
  background: linear-gradient(135deg, #4b84ea 0%, #2d66d0 100%);
}

.btn-icon {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.btn-text {
  font-size: 20rpx;
  line-height: 1.2;
}

.preview-full {
  width: 100%;
  height: 100%;
}

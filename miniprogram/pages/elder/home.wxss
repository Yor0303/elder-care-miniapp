.page {
  padding: 80rpx 40rpx;
  background-color: #F8F9FB;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 280rpx;
}

.logo {
  font-size: 72rpx;
  font-weight: bold;
  color: #1A3A5F;
  text-align: center;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
}

.card.feature {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}

.card.feature:active {
  transform: scale(0.97);
  background: #F0F4F8;
}

.icon {
  font-size: 80rpx;
  margin-right: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 30rpx;
  color: #888;
}

/* 悬浮按钮区域 */
.floating-buttons {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 40rpx;
  z-index: 100;
}

.floating-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(74, 144, 226, 0.4);
  transition: transform 0.2s, box-shadow 0.2s;
}

.floating-btn:active {
  transform: scale(0.95);
}

.face-btn {
  background: linear-gradient(135deg, #4A90E2 0%, #1A3A5F 100%);
}

.btn-icon {
  font-size: 45rpx;
}

.btn-text {
  font-size: 20rpx;
  color: #fff;
  margin-top: 6rpx;
  font-weight: 500;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 164rpx;
  box-sizing: border-box;
  background: var(--yz-bg-page);
}

.preview-banner,
.preview-panel,
.memo-card,
.hero-card,
.qr-panel {
  background: var(--yz-bg-card);
  border: 1rpx solid var(--yz-border);
  border-radius: 18rpx;
  box-shadow: none;
}

.preview-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
}

.preview-copy,
.binding-message-copy,
.reminder-main,
.message-main,
.mine-copy {
  flex: 1;
  min-width: 0;
}

.preview-title,
.preview-panel-title,
.memo-title,
.qr-panel-title,
.binding-message-title,
.message-sender,
.feature-title {
  color: var(--yz-text-primary);
  font-weight: 700;
}

.preview-title,
.preview-panel-title,
.memo-title,
.qr-panel-title {
  font-size: 30rpx;
}

.preview-desc,
.preview-panel-desc,
.binding-message-desc,
.reminder-meta,
.reminder-note,
.message-meta,
.message-note,
.board-desc,
.qr-panel-desc,
.empty-content,
.qr-placeholder-text,
.hero-desc {
  color: var(--yz-text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.preview-desc,
.preview-panel-desc,
.binding-message-desc,
.qr-panel-desc,
.hero-desc.small {
  margin-top: 8rpx;
}

.preview-btn {
  min-width: 168rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: var(--yz-brand-primary);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
}

.preview-btn::after,
.message-play-btn::after,
.secondary-btn::after {
  border: none;
}

.memo-card,
.hero-card,
.qr-panel,
.preview-panel {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.memo-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.memo-badge,
.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  font-size: 20rpx;
}

.memo-badge {
  background: var(--yz-warning-soft);
  color: var(--yz-warning);
}

.memo-tabs {
  display: flex;
  margin: 18rpx 0 6rpx;
}

.memo-tab {
  min-width: 116rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 999rpx;
  background: var(--yz-bg-card-soft);
  color: var(--yz-text-secondary);
  font-size: 24rpx;
  font-weight: 600;
}

.memo-tab + .memo-tab {
  margin-left: 12rpx;
}

.memo-tab-active {
  background: var(--yz-info-soft);
  color: var(--yz-info);
}

.binding-message-card,
.reminder-panel {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: var(--yz-bg-card-soft);
  border: 1rpx solid var(--yz-border-soft);
}

.binding-message-card {
  display: flex;
  align-items: flex-start;
}

.binding-message-icon {
  width: 72rpx;
  height: 72rpx;
  margin-right: 16rpx;
  border-radius: 18rpx;
  background: var(--yz-brand-primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-icon.orange {
  border-radius: 22rpx;
  background: rgba(237, 171, 107, 0.16);
}

.feature-icon.mint {
  border-radius: 22rpx;
  background: rgba(127, 200, 160, 0.16);
}

.feature-icon.red {
  border-radius: 22rpx;
  background: rgba(216, 120, 114, 0.14);
}

.feature-icon.blue {
  border-radius: 22rpx;
  background: rgba(124, 152, 200, 0.14);
}

.reminder-item,
.message-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--yz-border-soft);
}

.reminder-item:last-child,
.message-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.reminder-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--yz-text-primary);
}

.reminder-meta,
.message-meta,
.message-note,
.reminder-note {
  margin-top: 8rpx;
}

.reminder-check {
  width: 56rpx;
  height: 56rpx;
  margin-left: 16rpx;
  border-radius: 50%;
  background: var(--yz-brand-primary-soft);
  border: 1rpx solid var(--yz-brand-primary-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 0;
}

.reminder-check::before {
  content: "";
  width: 24rpx;
  height: 24rpx;
  border-right: 4rpx solid var(--yz-brand-primary);
  border-bottom: 4rpx solid var(--yz-brand-primary);
  transform: rotate(45deg) translate(-2rpx, -2rpx);
}

.reminder-check-loading {
  background: var(--yz-info-soft);
  border-color: var(--yz-brand-primary-border);
  font-size: 28rpx;
  color: var(--yz-info);
}

.reminder-check-loading::before {
  content: none;
}

.reminder-check-disabled {
  opacity: 0.6;
}

.message-list-spaced {
  margin-top: 10rpx;
}

.message-play-btn,
.message-text-tag {
  min-width: 104rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  text-align: center;
  box-sizing: border-box;
}

.message-play-btn {
  background: var(--yz-brand-primary-soft);
  color: var(--yz-brand-primary);
  border: none;
}

.message-text-tag {
  background: var(--yz-bg-card-soft);
  color: var(--yz-text-secondary);
}

.board-image {
  width: 100%;
  height: 360rpx;
  margin: 16rpx 0;
  border-radius: 16rpx;
}

.empty-content {
  padding: 26rpx 0 6rpx;
  text-align: center;
}

.feature-panel {
  margin-top: 8rpx;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
}

.feature-card {
  width: calc((100% - 32rpx) / 3);
  padding: 12rpx 8rpx 10rpx;
  box-sizing: border-box;
  text-align: center;
}

.feature-card:nth-child(n + 2) {
  margin-left: 16rpx;
}

.feature-grid .feature-card:nth-child(3n + 1) {
  margin-left: 0;
}

.feature-grid .feature-card:nth-child(n + 4) {
  margin-top: 20rpx;
}

.feature-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.qr-placeholder-emoji.red,
.binding-message-icon.red {
  background: rgba(224, 90, 84, 0.16);
}

.qr-placeholder-emoji.blue,
.binding-message-icon.blue {
  background: rgba(104, 182, 236, 0.16);
}

.qr-placeholder-emoji.mint,
.binding-message-icon.mint {
  background: rgba(127, 217, 180, 0.18);
}

.qr-placeholder-emoji.orange,
.binding-message-icon.orange {
  background: rgba(237, 171, 107, 0.18);
}

.feature-title {
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 600;
}

.mine-hero {
  padding: 22rpx;
}

.mine-profile {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.mine-avatar {
  width: 92rpx;
  height: 92rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.hero-title {
  color: var(--yz-text-primary);
  font-size: 34rpx;
  font-weight: 700;
}

.qr-box {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: var(--yz-bg-card-soft);
  border: 1rpx dashed var(--yz-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-image {
  width: 320rpx;
  height: 320rpx;
}

.qr-placeholder {
  min-height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.qr-placeholder-emoji {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(237, 171, 107, 0.18);
}

.qr-placeholder-text {
  margin-top: 14rpx;
  text-align: center;
}

.qr-actions {
  display: flex;
  margin-top: 18rpx;
}

.secondary-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  background: var(--yz-brand-primary);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
}

.secondary-btn + .secondary-btn {
  margin-left: 12rpx;
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon-text {
  margin-left: 10rpx;
}

.ghost-btn {
  background: var(--yz-info-soft);
  color: var(--yz-info);
}

.ghost-text {
  color: var(--yz-info);
}

.mine-feature-panel {
  margin-top: 18rpx;
}

.bottom-nav {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  padding: 14rpx 18rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(250, 248, 244, 0.98);
  border: 1rpx solid var(--yz-border);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  box-shadow: none;
  z-index: 100;
}

.nav-item {
  width: 28%;
  text-align: center;
}

.nav-item.active .nav-label {
  color: var(--yz-brand-primary);
  font-weight: 700;
}

.nav-emoji {
  width: 40rpx;
  height: 40rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--yz-text-secondary);
}

.nav-center {
  width: 34%;
  text-align: center;
  margin-top: -48rpx;
}

.nav-center-btn {
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: var(--yz-danger);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(216, 120, 114, 0.22);
}

.nav-center-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.preview-mask {
  position: fixed;
  inset: 0;
  background: rgba(33, 32, 33, 0.88);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-full {
  width: 100%;
  height: 100%;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 180rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(255, 225, 182, 0.28), transparent 24%),
    linear-gradient(180deg, #f8fbfc 0%, #eef4f5 100%);
}

.preview-banner,
.preview-panel {
  border-radius: 30rpx;
  box-shadow: 0 16rpx 36rpx rgba(21, 32, 43, 0.08);
}

.preview-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(145deg, #fff4df 0%, #fffdfa 100%);
}

.preview-copy {
  flex: 1;
  min-width: 0;
}

.preview-title,
.preview-panel-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #6e4d1f;
}

.preview-desc,
.preview-panel-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #876d45;
}

.preview-btn {
  flex-shrink: 0;
  min-width: 176rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #315f78;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
}

.preview-btn::after {
  border: none;
}

.preview-panel {
  padding: 26rpx 24rpx;
  background: linear-gradient(145deg, #fff7ea 0%, #ffffff 100%);
}

.hero-card,
.memo-card,
.feature-card,
.face-entry-card,
.qr-panel,
.bottom-nav {
  border-radius: 32rpx;
  box-shadow: 0 18rpx 42rpx rgba(21, 32, 43, 0.08);
}

.hero-card {
  padding: 34rpx 30rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, #25486f 0%, #386f8f 55%, #5da7a6 100%);
  color: #fff;
}

.mine-hero {
  background: linear-gradient(145deg, #21435d 0%, #345875 55%, #4c7d91 100%);
}

.hero-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-title.small {
  margin-top: 0;
  font-size: 40rpx;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.86);
}

.hero-desc.small {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.hero-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-stat {
  flex: 1;
  padding: 18rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.12);
  text-align: center;
}

.hero-stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.mine-profile {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 22rpx;
}

.mine-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.16);
}

.mine-copy {
  min-width: 0;
  flex: 1;
}

.memo-card,
.qr-panel {
  padding: 30rpx 28rpx;
  margin-bottom: 28rpx;
  background: rgba(255, 255, 255, 0.96);
}

.memo-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.memo-title,
.section-title,
.qr-panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.memo-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #3f69c9;
  font-size: 22rpx;
}

.memo-tabs {
  display: flex;
  gap: 14rpx;
  margin: 22rpx 0 8rpx;
}

.memo-tab {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f1f4f7;
  color: #6d7c8c;
  font-size: 25rpx;
  font-weight: 700;
}

.memo-tab-active {
  background: #e9f0ff;
  color: #2f5eb3;
}

.binding-message-card {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #fff4e8 0%, #fffaf6 100%);
  border: 2rpx solid #f3dfc8;
  margin-top: 18rpx;
}

.binding-message-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  background: #fff;
  flex-shrink: 0;
}

.binding-message-copy {
  flex: 1;
}

.binding-message-title,
.reminder-title,
.message-sender,
.board-title,
.feature-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.binding-message-desc,
.reminder-meta,
.reminder-note,
.message-meta,
.message-note,
.board-desc,
.feature-desc,
.qr-panel-desc,
.empty-content,
.qr-placeholder-text {
  font-size: 25rpx;
  line-height: 1.7;
  color: #6f8092;
}

.binding-message-desc,
.qr-panel-desc {
  margin-top: 8rpx;
}

.reminder-panel {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #eef7ff 0%, #f8fbff 100%);
}

.reminder-item,
.message-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e5edf6;
}

.reminder-item:last-child,
.message-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.reminder-main,
.message-main {
  flex: 1;
  min-width: 0;
}

.reminder-meta,
.message-meta {
  margin-top: 8rpx;
}

.reminder-note,
.message-note {
  margin-top: 8rpx;
}

.reminder-check {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #d9f2de 0%, #ecfbf0 100%);
  color: #2f8f54;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: inset 0 0 0 2rpx rgba(47, 143, 84, 0.12);
}

.reminder-check-loading {
  color: #6d7c8c;
  background: #eef3f7;
  box-shadow: inset 0 0 0 2rpx rgba(109, 124, 140, 0.12);
}

.reminder-check-disabled {
  opacity: 0.6;
}

.message-list-spaced {
  margin-top: 14rpx;
}

.message-play-btn,
.message-text-tag {
  min-width: 110rpx;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  text-align: center;
  box-sizing: border-box;
}

.message-play-btn {
  border: none;
  background: #edf4ff;
  color: #3566b4;
  padding: 0 22rpx;
}

.message-play-btn::after {
  border: none;
}

.message-text-tag {
  background: #f2f5f8;
  color: #7b8897;
  padding: 0 18rpx;
}

.board-image {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
  margin-top: 18rpx;
  margin-bottom: 18rpx;
}

.board-title {
  margin-bottom: 8rpx;
}

.empty-content {
  padding: 34rpx 0 12rpx;
  text-align: center;
}

.section {
  margin-bottom: 26rpx;
}

.last-section {
  margin-bottom: 0;
}

.section-title {
  margin-bottom: 18rpx;
  padding-left: 4rpx;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.feature-card {
  width: calc((100% - 18rpx) / 2);
  min-height: 204rpx;
  padding: 24rpx 22rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.96);
}

.wide-card {
  width: 100%;
  min-height: 176rpx;
}

.life-card {
  background: linear-gradient(145deg, #fff4e8 0%, #ffffff 72%);
}

.family-card {
  background: linear-gradient(145deg, #eff6ff 0%, #ffffff 72%);
}

.health-card {
  background: linear-gradient(145deg, #eefaf4 0%, #ffffff 72%);
}

.mine-card {
  background: linear-gradient(145deg, #eef4ff 0%, #ffffff 72%);
}

.bind-card {
  background: linear-gradient(145deg, #f6f2ff 0%, #ffffff 72%);
}

.feature-emoji {
  width: 78rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  margin-bottom: 14rpx;
  font-size: 34rpx;
  background: rgba(255, 255, 255, 0.72);
}

.face-entry-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 26rpx;
  margin-bottom: 26rpx;
  background: linear-gradient(145deg, #eef3ff 0%, #f8fbff 100%);
}

.face-entry-emoji {
  width: 88rpx;
  height: 88rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: linear-gradient(145deg, #436fd7 0%, #25499d 100%);
  color: #fff;
  flex-shrink: 0;
}

.face-entry-copy {
  flex: 1;
}

.face-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.face-entry-desc {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #6f8092;
}

.qr-box {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #eef6ff 0%, #ffffff 72%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-image {
  width: 360rpx;
  height: 360rpx;
}

.qr-placeholder {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.qr-placeholder-emoji {
  font-size: 60rpx;
}

.qr-placeholder-text {
  margin-top: 14rpx;
  text-align: center;
}

.qr-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.secondary-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1f6feb 0%, #2258c2 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.secondary-btn::after {
  border: none;
}

.ghost-btn {
  background: #edf4ff;
  color: #2f5eb3;
}

.bottom-nav {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 16rpx 22rpx 14rpx;
  background: rgba(255, 255, 255, 0.96);
  z-index: 100;
}

.nav-item {
  width: 28%;
  text-align: center;
  color: #8290a1;
}

.nav-item.active .nav-label {
  color: #1d2c3f;
  font-weight: 700;
}

.nav-emoji {
  font-size: 34rpx;
}

.nav-label {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.nav-center {
  width: 34%;
  text-align: center;
  margin-top: -60rpx;
}

.nav-center-btn {
  width: 118rpx;
  height: 118rpx;
  margin: 0 auto;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: linear-gradient(145deg, #436fd7 0%, #25499d 100%);
  color: #fff;
  box-shadow: 0 18rpx 36rpx rgba(37, 73, 157, 0.24);
}

.nav-center-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #1d2c3f;
}

.preview-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.84);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-full {
  width: 100%;
  height: 100%;
}

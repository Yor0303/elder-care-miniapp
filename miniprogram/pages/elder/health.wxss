.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background: var(--yz-bg-page);
}

.hero-panel,
.hero-card,
.chart-card,
.info-card,
.reminder-card,
.loading-container,
.error-container {
  border-radius: 24rpx;
  box-shadow: var(--yz-shadow-soft);
}

.hero-panel {
  margin-bottom: 24rpx;
  padding: 32rpx 28rpx;
  background: var(--yz-gradient-hero);
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--yz-text-secondary);
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.hero-card {
  display: flex;
  gap: 24rpx;
  padding: 36rpx;
  background: var(--yz-brand-primary);
  color: var(--yz-bg-card);
}

.hero-main-card {
  flex: 1;
  transition: transform 120ms ease, opacity 120ms ease;
}

.hero-main-card:active {
  transform: scale(0.99);
  opacity: 0.92;
}

.hero-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.hero-value {
  margin-top: 14rpx;
  font-size: 58rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  opacity: 0.92;
}

.hero-meta {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
  width: 220rpx;
}

.hero-side-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(8rpx);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.hero-side-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 18rpx rgba(23, 46, 99, 0.18);
}

.metric-chip-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.88;
}

.metric-chip-value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.chart-card,
.info-card {
  margin-bottom: 20rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.96);
}

.reminder-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
  padding: 28rpx 30rpx;
  background: rgba(255, 255, 255, 0.96);
}

.reminder-time {
  min-width: 140rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--yz-brand-primary);
}

.reminder-content {
  flex: 1;
}

.reminder-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.reminder-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 18rpx;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--yz-text-secondary);
}

.chart-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.chart-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.chart-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--yz-text-secondary);
}

.chart-current {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--yz-brand-primary);
}

.chart-empty,
.empty-tip {
  padding: 36rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
  color: var(--yz-text-secondary);
}

.pressure-track,
.bar-track {
  width: 100%;
  white-space: nowrap;
}

.pressure-items,
.bar-list {
  display: inline-flex;
  align-items: flex-end;
  gap: 28rpx;
  min-width: 100%;
  padding: 8rpx 8rpx 12rpx;
}

.pressure-item,
.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 116rpx;
}

.pressure-value,
.bar-value {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--yz-brand-primary);
}

.pressure-sticks {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  height: 280rpx;
}

.pressure-stick {
  width: 24rpx;
  min-height: 16rpx;
  border-radius: 0;
  transform-origin: bottom center;
  box-shadow: 0 10rpx 18rpx rgba(111, 143, 200, 0.16);
}

.pressure-stick.systolic {
  background: #78c3a7;
}

.pressure-stick.diastolic {
  background: #f4c97c;
}

.pressure-label,
.bar-label {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--yz-text-tertiary);
}

.bar-column {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 72rpx;
  height: 280rpx;
  padding: 6rpx;
  border-radius: 0;
  background: var(--yz-bg-card-soft);
}

.bar-fill {
  width: 100%;
  min-height: 18rpx;
  border-radius: 0;
  background: var(--yz-brand-primary);
  transform-origin: bottom center;
  box-shadow: inset 0 10rpx 18rpx rgba(255, 255, 255, 0.28), 0 12rpx 22rpx rgba(111, 143, 200, 0.14);
}

.animate-rise {
  animation: rise-up 700ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

@keyframes rise-up {
  0% {
    opacity: 0.25;
    transform: scaleY(0.08);
  }

  65% {
    opacity: 1;
    transform: scaleY(1.04);
  }

  100% {
    opacity: 1;
    transform: scaleY(1);
  }
}

.history {
  font-size: 32rpx;
  color: var(--yz-text-primary);
}

.medicine {
  display: flex;
  flex-direction: column;
}

.med-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--yz-text-primary);
}

.med-info {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: var(--yz-brand-primary);
}

.med-time,
.notes {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--yz-text-secondary);
}

.loading-container,
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: rgba(255, 255, 255, 0.96);
}

.error-msg {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  color: var(--yz-danger);
}

.retry-btn {
  padding: 0 40rpx;
  font-size: 28rpx;
  color: var(--yz-brand-primary);
  background: var(--yz-bg-card);
  border: 2rpx solid var(--yz-brand-primary);
  border-radius: 24rpx;
}

.page {
  min-height: 100vh;
  padding: 40rpx;
  background: #f8f9fb;
  box-sizing: border-box;
}

.title {
  margin-bottom: 36rpx;
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  color: #1a3a5f;
}

.loading-container,
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading,
.error-msg {
  font-size: 30rpx;
  color: #999;
}

.error-msg {
  color: #ff6b6b;
  margin-bottom: 20rpx;
}

.retry-btn {
  background: #4a90e2;
  color: #fff;
  border-radius: 999rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
}

.section {
  margin-bottom: 34rpx;
}

.summary-section,
.empty-tip,
.alert-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06);
}

.summary-section {
  padding: 30rpx;
}

.section-header-card {
  margin-bottom: 22rpx;
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.section-desc {
  margin-top: -6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b97a7;
}

.health-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.overview-card {
  width: calc((100% - 36rpx) / 3);
  background: #f5f8fc;
  border-radius: 22rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.overview-label {
  font-size: 26rpx;
  color: #7c8b9a;
}

.overview-value {
  margin-top: 16rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #1a3a5f;
}

.overview-unit {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #98a5b3;
}

.status-pill {
  display: inline-block;
  margin-top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-normal {
  background: #e9f7ef;
  color: #268a53;
}

.status-high {
  background: #fff1f0;
  color: #d95c54;
}

.status-low {
  background: #eef5ff;
  color: #4a79c8;
}

.latest-note {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #7c8b9a;
}

.alert-card {
  padding: 24rpx 26rpx;
  margin-bottom: 16rpx;
}

.alert-high {
  border-left: 8rpx solid #ff8b7b;
}

.alert-low {
  border-left: 8rpx solid #7ca8ff;
}

.alert-text {
  font-size: 28rpx;
  color: #4f5f73;
  line-height: 1.6;
}

.empty-tip {
  padding: 36rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

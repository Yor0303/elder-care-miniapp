<view class="page">
  <view class="title">今日健康</view>

  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading">加载中...</view>
  </view>

  <view wx:elif="{{errorMsg}}" class="error-container">
    <view class="error-msg">{{errorMsg}}</view>
    <button class="retry-btn" bindtap="loadHealthInfo">重试</button>
  </view>

  <view wx:else>
    <view class="section summary-section">
      <view class="section-header-card">
        <view class="section-title">今天的身体状态</view>
        <view class="section-desc">只保留最常看的内容，方便老人一眼看懂。</view>
      </view>

      <view class="health-grid">
        <view wx:for="{{todayCards}}" wx:key="key" class="overview-card">
          <view class="overview-label">{{item.label}}</view>
          <view class="overview-value">{{item.value}}</view>
          <view wx:if="{{item.unit}}" class="overview-unit">{{item.unit}}</view>
          <view class="status-pill status-{{item.status.type}}">{{item.status.text}}</view>
        </view>
      </view>

      <view wx:if="{{latestMeasurement}}" class="latest-note">
        最近一次记录时间：{{latestMeasurement.recordDate || "--"}}
      </view>
    </view>

    <view class="section">
      <view class="section-title">健康提醒</view>
      <view wx:if="{{!healthAlerts.length}}" class="empty-tip">目前状态平稳，请继续保持。</view>
      <view wx:for="{{healthAlerts}}" wx:key="text" class="alert-card alert-{{item.level}}">
        <view class="alert-text">{{item.text}}</view>
      </view>
    </view>
  </view>
</view>

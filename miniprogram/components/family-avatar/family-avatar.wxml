<!--components/family-avatar/family-avatar.wxml-->
<view class="children-wrapper" wx:if="{{node.children && node.children.length}}">
  <view class="vertical-line"></view>
  <view class="children">
    <view class="horizontal-line"></view> <!-- 横线 -->
    <block wx:for="{{node.children}}" wx:key="id">
      <tree-node node="{{item}}" bind:click="clickNode"/>
    </block>
  </view>
</view>